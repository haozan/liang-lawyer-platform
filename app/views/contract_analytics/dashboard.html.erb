<div class="min-h-screen bg-surface py-8">
  <div class="container-xl mx-auto px-6">
  <!-- Analytics Tabs Navigation -->
  <%= render 'shared/analytics_tabs', current_tab: 'contract' %>
  
  <!-- 🎯 固定顶部栏 - 关键指标快速浏览 -->
  <% sticky_metrics = [
    { 
      name: '合同总数', 
      value: @core_kpis[:total_contracts], 
      icon: 'file-text', 
      color: 'bg-primary/10',
      icon_color: 'text-primary',
      link: contracts_path,
      status: {
        value: @core_kpis[:total_contracts],
        thresholds: { green: 30, yellow: 10 },
        reverse: false
      }
    },
    { 
      name: '执行中', 
      value: @core_kpis[:active_contracts], 
      icon: 'play-circle', 
      color: 'bg-info/10',
      icon_color: 'text-info',
      link: contracts_path(filter: { status: 'active' }),
      status: {
        value: @core_kpis[:active_contracts],
        thresholds: { green: 15, yellow: 5 },
        reverse: false
      }
    },
    { 
      name: '即将到期', 
      value: @risk_alerts[:expiring_soon], 
      icon: 'clock', 
      color: 'bg-warning/10',
      icon_color: 'text-warning',
      link: contracts_path(filter: { expiring_soon: true }),
      status: {
        value: @risk_alerts[:expiring_soon],
        thresholds: { green: 3, yellow: 5 },
        reverse: true
      }
    },
    { 
      name: '高风险', 
      value: @risk_alerts[:high_risk], 
      icon: 'alert-triangle', 
      color: 'bg-danger/10',
      icon_color: 'text-danger',
      link: contracts_path(filter: { risk_level: ['高', '极高'] }),
      status: {
        value: @risk_alerts[:high_risk],
        thresholds: { green: 2, yellow: 5 },
        reverse: true
      }
    }
  ] %>
  
  <%= render 'shared/dashboard_sticky_bar', metrics: sticky_metrics %>

  <!-- Page Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="page-title">合同数据分析仪表盘</h1>
      <p class="text-secondary">
        <% if @company %>
          <%= @company.name %> · 专业合同风险监控与分析
        <% else %>
          全部企业 · 综合合同数据分析
        <% end %>
      </p>
    </div>
    <div class="flex gap-3">
      <%= link_to export_report_contract_analytics_path(
        company_id: params[:company_id],
        date_from: @date_from,
        date_to: @date_to
      ), class: "btn btn-success" do %>
        <%= lucide_icon "download", class: "w-5 h-5 mr-2" %>
        导出报表
      <% end %>
      <%= link_to contracts_path, class: "btn btn-secondary" do %>
        <%= lucide_icon "arrow-left", class: "w-5 h-5 mr-2" %>
        返回列表
      <% end %>
    </div>
  </div>

  <!-- Date Range Filter with Quick Options and Comparison -->
  <div class="card card-elevated mb-6">
    <div class="card-body">
      <%= form_with url: dashboard_contract_analytics_path, method: :get, local: true do |f| %>
        <div class="space-y-4">
          <!-- Quick Date Options -->
          <div class="flex gap-2 flex-wrap">
            <% today = Date.today %>
            <%= link_to "今天", dashboard_contract_analytics_path(company_id: params[:company_id], date_from: today, date_to: today), class: "btn btn-sm btn-secondary" %>
            <%= link_to "本周", dashboard_contract_analytics_path(company_id: params[:company_id], date_from: today.beginning_of_week, date_to: today.end_of_week), class: "btn btn-sm btn-secondary" %>
            <%= link_to "本月", dashboard_contract_analytics_path(company_id: params[:company_id], date_from: today.beginning_of_month, date_to: today.end_of_month), class: "btn btn-sm btn-secondary" %>
            <%= link_to "本季度", dashboard_contract_analytics_path(company_id: params[:company_id], date_from: today.beginning_of_quarter, date_to: today.end_of_quarter), class: "btn btn-sm btn-secondary" %>
            <%= link_to "本年", dashboard_contract_analytics_path(company_id: params[:company_id], date_from: today.beginning_of_year, date_to: today.end_of_year), class: "btn btn-sm btn-secondary" %>
            <%= link_to "最近30天", dashboard_contract_analytics_path(company_id: params[:company_id], date_from: 30.days.ago, date_to: today), class: "btn btn-sm btn-secondary" %>
            <%= link_to "全部", dashboard_contract_analytics_path(company_id: params[:company_id]), class: "btn btn-sm btn-secondary" %>
          </div>

          <div class="flex flex-wrap items-end gap-4">
            <div class="form-group flex-1 min-w-[200px]">
              <%= label_tag "date_from", "开始日期", class: "form-label" %>
              <%= date_field_tag "date_from", @date_from, class: "form-input" %>
            </div>
            
            <div class="form-group flex-1 min-w-[200px]">
              <%= label_tag "date_to", "结束日期", class: "form-label" %>
              <%= date_field_tag "date_to", @date_to, class: "form-input" %>
            </div>
            
            <% if @company.nil? && lawyer? %>
              <div class="form-group flex-1 min-w-[200px]">
                <%= label_tag "company_id", "选择企业", class: "form-label" %>
                <%= select_tag "company_id", 
                    options_for_select([["全部企业", "all"]] + @companies.map { |c| [c.name, c.id] }, params[:company_id]),
                    class: "form-select" %>
              </div>
            <% end %>
            
            <%= f.submit "应用筛选", class: "btn btn-primary" %>
            <%= link_to "重置", dashboard_contract_analytics_path(company_id: params[:company_id]), class: "btn btn-secondary" %>
          </div>

          <!-- Comparison Date Range (Collapsible) -->
          <details class="border-t pt-4" <%= 'open' if @comparison.present? %>>
            <summary class="cursor-pointer text-sm font-medium text-primary hover:text-primary/80 flex items-center gap-2">
              <%= lucide_icon "git-compare", class: "w-4 h-4" %>
              数据对比（可选）
            </summary>
            <div class="mt-4 flex flex-wrap items-end gap-4">
              <div class="form-group flex-1 min-w-[200px]">
                <%= label_tag "compare_date_from", "对比开始日期", class: "form-label" %>
                <%= date_field_tag "compare_date_from", params[:compare_date_from], class: "form-input" %>
              </div>
              
              <div class="form-group flex-1 min-w-[200px]">
                <%= label_tag "compare_date_to", "对比结束日期", class: "form-label" %>
                <%= date_field_tag "compare_date_to", params[:compare_date_to], class: "form-input" %>
              </div>
              
              <p class="text-xs text-secondary flex-1">
                选择对比日期后，系统将显示两个时间段的数据对比
              </p>
            </div>
          </details>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Comparison Results (if enabled) -->
  <% if @comparison.present? %>
    <div class="card card-elevated mb-6 border-info">
      <div class="card-header bg-info/10">
        <h3 class="card-title flex items-center gap-2 text-info">
          <%= lucide_icon "git-compare", class: "w-5 h-5" %>
          数据对比结果
        </h3>
      </div>
      <div class="card-body">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="text-center p-4 bg-surface-secondary rounded-lg">
            <p class="text-sm text-secondary mb-2">当期合同数</p>
            <p class="text-3xl font-bold text-primary mb-1"><%= @comparison[:period_total] %></p>
            <p class="text-sm <%= @comparison[:total_change] >= 0 ? 'text-success' : 'text-danger' %>">
              <%= @comparison[:total_change] >= 0 ? '↑' : '↓' %> <%= @comparison[:total_change].abs %> (<%= @comparison[:total_change_rate] %>%)
            </p>
          </div>
          
          <div class="text-center p-4 bg-surface-secondary rounded-lg">
            <p class="text-sm text-secondary mb-2">对比期合同数</p>
            <p class="text-3xl font-bold text-secondary"><%= @comparison[:compare_total] %></p>
          </div>
          
          <div class="text-center p-4 bg-surface-secondary rounded-lg">
            <p class="text-sm text-secondary mb-2">当期合同金额</p>
            <p class="text-3xl font-bold text-primary mb-1"><%= number_to_currency(@comparison[:period_amount], unit: '¥', precision: 0) %></p>
            <p class="text-sm <%= @comparison[:amount_change] >= 0 ? 'text-success' : 'text-danger' %>">
              <%= @comparison[:amount_change] >= 0 ? '↑' : '↓' %> <%= number_to_currency(@comparison[:amount_change].abs, unit: '¥', precision: 0) %> (<%= @comparison[:amount_change_rate] %>%)
            </p>
          </div>
          
          <div class="text-center p-4 bg-surface-secondary rounded-lg">
            <p class="text-sm text-secondary mb-2">对比期合同金额</p>
            <p class="text-3xl font-bold text-secondary"><%= number_to_currency(@comparison[:compare_amount], unit: '¥', precision: 0) %></p>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- 🤖 智能洞察提示卡 -->
  <% if @risk_alerts[:has_alerts] %>
    <% total_risks = @risk_alerts[:expiring_soon] + @risk_alerts[:high_risk] + @risk_alerts[:overdue_review] + @risk_alerts[:overdue_reconciliation] %>
    <%= render 'shared/smart_insight_card',
      type: 'danger',
      icon: 'alert-triangle',
      title: '风险预警',
      message: "检测到#{total_risks}个风险事项：#{@risk_alerts[:expiring_soon]}个合同即将到期、#{@risk_alerts[:high_risk]}个高风险合同、#{@risk_alerts[:overdue_review]}个逾期未审查、#{@risk_alerts[:overdue_reconciliation]}个对账单逾期。",
      action_text: '查看风险合同',
      action_url: contracts_path(filter: { risk_level: ['高', '极高'] })
    %>
  <% elsif @core_kpis[:active_contracts] > 20 %>
    <%= render 'shared/smart_insight_card',
      type: 'success',
      icon: 'trending-up',
      title: '合同管理良好',
      message: "当前有#{@core_kpis[:active_contracts]}个合同在执行中，合同金额达#{number_to_currency(@core_kpis[:total_amount], unit: '¥', precision: 0)}，合同管理状态良好。"
    %>
  <% elsif @core_kpis[:current_month_new] > 10 %>
    <%= render 'shared/smart_insight_card',
      type: 'info',
      icon: 'lightbulb',
      title: '业务增长提示',
      message: "本月新签#{@core_kpis[:current_month_new]}个合同，业务量呈增长趋势。建议及时完成合同审查，确保合规性。",
      action_text: '查看待审查合同',
      action_url: contracts_path(filter: { reviewed: false })
    %>
  <% end %>

  <!-- 🎯 专业仪表盘组件区 -->
  <div class="grid lg:grid-cols-3 gap-6 mb-6">
    <!-- 审查率仪表盘 -->
    <% review_rate = @core_kpis[:total_contracts] > 0 ? ((@core_kpis[:total_contracts] - @risk_alerts[:overdue_review]).to_f / @core_kpis[:total_contracts] * 100).round(1) : 0 %>
    <% review_gauge_data = {
      value: review_rate,
      max: 100,
      name: '审查率'
    } %>
    <%= render 'shared/dashboard_chart_wrapper',
      type: 'gauge',
      data: review_gauge_data,
      title: '合同审查率',
      height: '280px'
    %>

    <!-- 状态分布环形图 -->
    <% status_donut_data = {
      name: '合同状态',
      data: @distributions[:status_distribution].map do |status, count|
        status_names = {
          'draft' => '草稿',
          'pending_review' => '待审查',
          'active' => '执行中',
          'completed' => '已完成',
          'breach' => '违约',
          'litigation' => '诉讼',
          'terminated' => '已终止'
        }
        { name: status_names[status] || status, value: count }
      end
    } %>
    <%= render 'shared/dashboard_chart_wrapper',
      type: 'donut',
      data: status_donut_data,
      title: '状态分布',
      height: '280px'
    %>

    <!-- 风险等级分布环形图 -->
    <% risk_donut_data = {
      name: '风险等级',
      data: @distributions[:risk_distribution].map do |risk, count|
        { name: risk.present? ? risk : '无', value: count }
      end
    } %>
    <%= render 'shared/dashboard_chart_wrapper',
      type: 'donut',
      data: risk_donut_data,
      title: '风险等级分布',
      height: '280px'
    %>
  </div>

  <!-- Core KPI Panel with Enhanced Design -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <%= link_to contracts_path, class: "card card-elevated hover:shadow-lg transition-shadow bg-gradient-to-br from-primary/5 to-primary/10" do %>
      <div class="card-body text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <%= lucide_icon "file-text", class: "w-6 h-6 text-primary" %>
          <p class="text-sm text-secondary font-medium">合同总数</p>
        </div>
        <p class="font-heading text-5xl font-bold text-primary mb-2"><%= @core_kpis[:total_contracts] %></p>
        <% if @core_kpis[:current_month_new] > 0 %>
          <div class="inline-flex items-center gap-1 px-3 py-1 bg-success/10 rounded-full">
            <%= lucide_icon "trending-up", class: "w-3 h-3 text-success" %>
            <span class="text-xs text-success font-medium">
              +<%= @core_kpis[:current_month_new] %> 本月
            </span>
          </div>
        <% end %>
      </div>
    <% end %>
    
    <%= link_to contracts_path(filter: { status: 'active' }), class: "card card-elevated hover:shadow-lg transition-shadow bg-gradient-to-br from-info/5 to-info/10" do %>
      <div class="card-body text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <%= lucide_icon "play-circle", class: "w-6 h-6 text-info" %>
          <p class="text-sm text-secondary font-medium">执行中</p>
        </div>
        <p class="font-heading text-5xl font-bold text-info mb-2"><%= @core_kpis[:active_contracts] %></p>
        <p class="text-xs text-secondary">
          <%= number_to_currency(@core_kpis[:total_amount], unit: '¥', precision: 0) %>
        </p>
      </div>
    <% end %>
    
    <%= link_to contracts_path(filter: { status: 'completed' }), class: "card card-elevated hover:shadow-lg transition-shadow bg-gradient-to-br from-success/5 to-success/10" do %>
      <div class="card-body text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <%= lucide_icon "check-circle", class: "w-6 h-6 text-success" %>
          <p class="text-sm text-secondary font-medium">已完成</p>
        </div>
        <p class="font-heading text-5xl font-bold text-success mb-2"><%= @core_kpis[:completed_contracts] %></p>
        <p class="text-xs text-secondary">
          正常履约完成
        </p>
      </div>
    <% end %>
    
    <%= link_to contracts_path(filter: { status: ['breach', 'litigation'] }), class: "card card-elevated hover:shadow-lg transition-shadow bg-gradient-to-br from-danger/5 to-danger/10" do %>
      <div class="card-body text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <%= lucide_icon "alert-triangle", class: "w-6 h-6 text-danger" %>
          <p class="text-sm text-secondary font-medium">异常合同</p>
        </div>
        <p class="font-heading text-5xl font-bold text-danger mb-2">
          <%= @core_kpis[:breach_contracts] + @core_kpis[:litigation_contracts] %>
        </p>
        <div class="flex items-center justify-center gap-2 text-xs text-secondary">
          <span>违约 <%= @core_kpis[:breach_contracts] %></span>
          <span>•</span>
          <span>诉讼 <%= @core_kpis[:litigation_contracts] %></span>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Signing Trend Visualization with ECharts -->
  <% if @trends[:signing_daily].any? %>
    <% sorted_trend = @trends[:signing_daily].sort %>
    <% trend_line_data = {
      categories: sorted_trend.map { |date, _| date.strftime('%m/%d') },
      series: [{
        name: '签约数量',
        type: 'line',
        data: sorted_trend.map(&:last),
        smooth: true,
        areaStyle: { opacity: 0.3 },
        lineStyle: { width: 3 },
        itemStyle: { color: '#5470c6' }
      }]
    } %>
    <%= render 'shared/dashboard_chart_wrapper',
      type: 'line',
      data: trend_line_data,
      title: "签约趋势分析 (#{@date_from.strftime('%Y-%m-%d')} 至 #{@date_to.strftime('%Y-%m-%d')})",
      height: '350px'
    %>
  <% end %>

  <!-- 合同类型分布横向条形图 -->
  <% if @distributions[:type_distribution].any? %>
    <% contract_type_bar_data = {
      categories: @distributions[:type_distribution].keys,
      series: [{
        name: '合同数量',
        type: 'bar',
        data: @distributions[:type_distribution].values,
        itemStyle: {
          color: '#5470c6',
          borderRadius: [0, 4, 4, 0]
        },
        label: {
          show: true,
          position: 'right'
        }
      }]
    } %>
    <%= render 'shared/dashboard_chart_wrapper',
      type: 'bar',
      data: contract_type_bar_data,
      title: '合同类型分布（Top 10）',
      height: '400px'
    %>
  <% end %>

  <!-- Amount Statistics -->
  <div class="card card-elevated mb-6">
    <div class="card-header">
      <h3 class="card-title flex items-center gap-2">
        <%= lucide_icon "dollar-sign", class: "w-5 h-5" %>
        金额统计
      </h3>
    </div>
    <div class="card-body">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-4 bg-surface-secondary rounded-lg hover:bg-surface-secondary/80 transition-all hover:scale-105">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center">
              <%= lucide_icon "coins", class: "w-6 h-6 text-primary" %>
            </div>
            <div>
              <p class="text-sm text-secondary">合同总金额</p>
              <p class="text-2xl font-bold text-primary"><%= number_to_currency(@amount_stats[:total_amount], unit: '¥', precision: 0) %></p>
            </div>
          </div>
        </div>
        
        <div class="p-4 bg-surface-secondary rounded-lg hover:bg-surface-secondary/80 transition-all hover:scale-105">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-info/20 flex items-center justify-center">
              <%= lucide_icon "trending-up", class: "w-6 h-6 text-info" %>
            </div>
            <div>
              <p class="text-sm text-secondary">平均金额</p>
              <p class="text-2xl font-bold text-primary"><%= number_to_currency(@amount_stats[:avg_amount], unit: '¥', precision: 0) %></p>
            </div>
          </div>
        </div>
        
        <div class="p-4 bg-surface-secondary rounded-lg hover:bg-surface-secondary/80 transition-all hover:scale-105">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-success/20 flex items-center justify-center">
              <%= lucide_icon "arrow-up", class: "w-6 h-6 text-success" %>
            </div>
            <div>
              <p class="text-sm text-secondary">最高金额</p>
              <p class="text-2xl font-bold text-primary"><%= number_to_currency(@amount_stats[:max_amount], unit: '¥', precision: 0) %></p>
            </div>
          </div>
        </div>
        
        <div class="p-4 bg-surface-secondary rounded-lg hover:bg-surface-secondary/80 transition-all hover:scale-105">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-warning/20 flex items-center justify-center">
              <%= lucide_icon "arrow-down", class: "w-6 h-6 text-warning" %>
            </div>
            <div>
              <p class="text-sm text-secondary">最低金额</p>
              <p class="text-2xl font-bold text-primary"><%= number_to_currency(@amount_stats[:min_amount], unit: '¥', precision: 0) %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Timeline & Lawyer Workload -->
  <div class="grid lg:grid-cols-2 gap-6">
    <!-- Expiration Timeline with Heatmap Style -->
    <% if @expiration_timeline.any? %>
      <div class="card card-elevated">
        <div class="card-header">
          <h3 class="card-title flex items-center gap-2">
            <%= lucide_icon "calendar", class: "w-5 h-5" %>
            到期时间分布
          </h3>
        </div>
        <div class="card-body">
          <div class="space-y-3">
            <% max_count = @expiration_timeline.values.max %>
            <% @expiration_timeline.each do |period, count| %>
              <% percentage = max_count > 0 ? (count.to_f / max_count * 100).round(1) : 0 %>
              <% heat_intensity = (percentage / 100.0 * 0.2).round(2) %>
              <div class="p-3 rounded-lg transition-all hover:shadow-md" style="background: rgba(84, 112, 198, <%= heat_intensity %>);">
                <div class="flex items-center justify-between">
                  <span class="text-sm font-medium text-primary"><%= period %></span>
                  <div class="flex items-center gap-2">
                    <span class="badge badge-primary"><%= count %> 个</span>
                    <div class="w-24 bg-surface-secondary rounded-full h-2">
                      <div class="bg-primary h-2 rounded-full transition-all" style="width: <%= percentage %>%"></div>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Lawyer Workload with Heatmap Style -->
    <% if @lawyer_workload.any? %>
      <div class="card card-elevated">
        <div class="card-header">
          <h3 class="card-title flex items-center gap-2">
            <%= lucide_icon "users", class: "w-5 h-5" %>
            律师审查工作量（Top 10）
          </h3>
        </div>
        <div class="card-body">
          <div class="space-y-3">
            <% max_workload = @lawyer_workload.first[:total_contracts] %>
            <% @lawyer_workload.each_with_index do |workload, index| %>
              <% percentage = max_workload > 0 ? (workload[:total_contracts].to_f / max_workload * 100).round(1) : 0 %>
              <% heat_intensity = (percentage / 100.0 * 0.2).round(2) %>
              <div class="p-3 rounded-lg transition-all hover:shadow-md" style="background: rgba(84, 112, 198, <%= heat_intensity %>);">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-surface-elevated flex items-center justify-center flex-shrink-0 shadow-sm">
                    <span class="text-sm font-bold text-primary"><%= index + 1 %></span>
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center justify-between mb-1">
                      <span class="text-sm font-semibold text-primary"><%= workload[:lawyer_name] %></span>
                      <span class="badge badge-primary">
                        <%= workload[:total_contracts] %> 件
                      </span>
                    </div>
                    <div class="flex items-center gap-3 text-xs text-secondary">
                      <span class="flex items-center gap-1">
                        <%= lucide_icon "check", class: "w-3 h-3" %>
                        已审: <%= workload[:reviewed] %>
                      </span>
                      <span class="flex items-center gap-1">
                        <%= lucide_icon "clock", class: "w-3 h-3" %>
                        待审: <%= workload[:pending_review] %>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Floating Quick Navigation Button -->
  <%= render 'shared/analytics_quick_nav', current_module: 'contract' %>
  </div>
</div>