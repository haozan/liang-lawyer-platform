<div class="min-h-screen bg-surface py-8">
  <div class="container-md mx-auto px-6">
    <div class="mb-6">
      <%= link_to employees_path, class: "inline-flex items-center gap-2 text-secondary hover:text-primary transition-colors" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4" %>
        <span>返回列表</span>
      <% end %>
    </div>

    <div class="card card-elevated">
      <div class="card-header border-b border-border">
        <h2 class="font-heading text-2xl font-bold text-primary"><%= @employee.persisted? ? '编辑员工档案' : '新建员工档案' %></h2>
      </div>
      <div class="card-body">
        <%= form_with model: @employee, class: "space-y-6" do |f| %>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <%= f.label :name, "姓名 *", class: "form-label" %>
              <%= f.text_field :name, required: true, class: "form-input" %>
            </div>
            
            <div>
              <%= f.label :gender, "性别", class: "form-label" %>
              <%= f.select :gender, [['男', '男'], ['女', '女']], { include_blank: '请选择' }, class: "form-select" %>
            </div>
            
            <div>
              <%= f.label :id_number, "身份证号 *", class: "form-label" %>
              <%= f.text_field :id_number, required: true, class: "form-input" %>
            </div>
            
            <div>
              <%= f.label :position, "岗位 *", class: "form-label" %>
              <%= f.text_field :position, required: true, class: "form-input" %>
            </div>
            
            <div>
              <%= f.label :salary, "薪资 (元/月)", class: "form-label" %>
              <%= f.number_field :salary, step: 0.01, class: "form-input" %>
            </div>
            
            <div>
              <%= f.label :hired_at, "入职日期 *", class: "form-label" %>
              <%= f.date_field :hired_at, required: true, class: "form-input" %>
            </div>
            
            <div>
              <%= f.label :probation_end_at, "试用期截止日", class: "form-label" %>
              <%= f.date_field :probation_end_at, class: "form-input" %>
            </div>
            
            <div>
              <%= f.label :social_insurance_at, "社保购买时间", class: "form-label" %>
              <%= f.date_field :social_insurance_at, class: "form-input" %>
            </div>
            
            <div>
              <%= f.label :contract_signed_at, "劳动合同签订日期 *", class: "form-label" %>
              <%= f.date_field :contract_signed_at, required: true, class: "form-input" %>
            </div>
            
            <div>
              <%= f.label :contract_end_at, "劳动合同截止日期 *", class: "form-label" %>
              <%= f.date_field :contract_end_at, required: true, class: "form-input" %>
            </div>
          </div>

          <div class="flex gap-3">
            <%= f.submit @employee.persisted? ? '更新档案' : '创建档案', class: "btn-primary" %>
            <%= link_to "取消", @employee.persisted? ? employee_path(@employee) : employees_path, class: "btn-outline" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
