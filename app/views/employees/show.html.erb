<div class="min-h-screen bg-surface py-8">
  <div class="container-lg mx-auto px-6">
    <div class="mb-6">
      <%= link_to employees_path, class: "inline-flex items-center gap-2 text-secondary hover:text-primary transition-colors" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4" %>
        <span>返回列表</span>
      <% end %>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Employee Info Card -->
      <div class="md:col-span-2 space-y-6">
        <div class="card card-elevated">
          <div class="card-header border-b border-border">
            <h2 class="font-heading text-2xl font-bold text-primary">员工档案信息</h2>
          </div>
          <div class="card-body space-y-4">
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label class="form-label">姓名</label>
                <p class="text-primary font-semibold"><%= @employee.name %></p>
              </div>
              <div>
                <label class="form-label">性别</label>
                <p class="text-secondary"><%= @employee.gender %></p>
              </div>
              <div>
                <label class="form-label">身份证号</label>
                <p class="text-secondary font-mono"><%= @employee.id_number %></p>
              </div>
              <div>
                <label class="form-label">岗位</label>
                <p class="text-secondary"><%= @employee.position %></p>
              </div>
              <div>
                <label class="form-label">薪资</label>
                <p class="text-secondary">¥<%= number_with_delimiter(@employee.salary) %> /月</p>
              </div>
              <div>
                <label class="form-label">入职日期</label>
                <p class="text-secondary"><%= @employee.hired_at&.strftime('%Y年%m月%d日') %></p>
              </div>
              <div>
                <label class="form-label">试用期截止日</label>
                <p class="text-secondary"><%= @employee.probation_end_at&.strftime('%Y年%m月%d日') || '无' %></p>
              </div>
              <div>
                <label class="form-label">社保购买时间</label>
                <p class="text-secondary"><%= @employee.social_insurance_at&.strftime('%Y年%m月%d日') || '未购买' %></p>
              </div>
              <div>
                <label class="form-label">劳动合同签订日期</label>
                <p class="text-secondary"><%= @employee.contract_signed_at&.strftime('%Y年%m月%d日') %></p>
              </div>
              <div>
                <label class="form-label">劳动合同截止日期</label>
                <p class="text-secondary">
                  <%= @employee.contract_end_at&.strftime('%Y年%m月%d日') %>
                  <% if @employee.contract_expiring_soon? %>
                    <span class="badge-warning ml-2">即将到期</span>
                  <% elsif @employee.contract_expired? %>
                    <span class="badge-danger ml-2">已过期</span>
                  <% end %>
                </p>
              </div>
            </div>
          </div>
          <div class="card-footer border-t border-border flex gap-3">
            <%= link_to edit_employee_path(@employee), class: "btn-primary" do %>
              <%= lucide_icon "edit", class: "w-4 h-4" %>
              <span>编辑档案</span>
            <% end %>
            <%= link_to employee_path(@employee), data: { turbo_method: :delete, turbo_confirm: "确定删除该员工档案吗?" }, class: "btn-danger" do %>
              <%= lucide_icon "trash-2", class: "w-4 h-4" %>
              <span>删除档案</span>
            <% end %>
          </div>
        </div>

        <!-- Comments Section -->
        <div class="card card-elevated">
          <div class="card-header border-b border-border">
            <h3 class="font-heading text-xl font-bold text-primary">评论记录</h3>
          </div>
          <div class="card-body">
            <% if @comments.any? %>
              <div class="space-y-4 mb-6">
                <% @comments.each do |comment| %>
                  <div class="border-l-4 border-primary pl-4 py-2">
                    <div class="flex items-center justify-between mb-2">
                      <span class="font-semibold text-primary"><%= comment.author_name %></span>
                      <span class="text-sm text-muted"><%= comment.created_at.strftime('%Y-%m-%d %H:%M') %></span>
                    </div>
                    <p class="text-secondary whitespace-pre-wrap"><%= comment.content %></p>
                    <% if comment.attachments.attached? %>
                      <div class="mt-3 flex flex-wrap gap-2">
                        <% comment.attachments.each do |attachment| %>
                          <%= link_to rails_blob_path(attachment, disposition: "attachment"), class: "inline-flex items-center gap-2 px-3 py-1 bg-surface-elevated rounded text-sm text-secondary hover:text-primary transition-colors" do %>
                            <%= lucide_icon "paperclip", class: "w-4 h-4" %>
                            <span><%= attachment.filename %></span>
                          <% end %>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted text-center py-6">暂无评论记录</p>
            <% end %>

            <!-- Comment Form -->
            <%= form_with model: [@employee, @comment], url: employee_comments_path(@employee), class: "space-y-4" do |f| %>
              <%= f.text_area :content, rows: 4, placeholder: "添加评论或风险提示...", class: "form-textarea", required: true %>
              <div>
                <%= f.label :attachments, "附件上传 (可选)", class: "form-label" %>
                <%= f.file_field :attachments, multiple: true, class: "form-input" %>
                <p class="form-help">支持图片、PDF、Word、Excel格式，单个文件不超过20MB</p>
              </div>
              <%= f.submit "发布评论", class: "btn-primary" %>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <div class="card card-elevated">
          <div class="card-body">
            <h3 class="font-heading text-lg font-bold text-primary mb-4">快捷操作</h3>
            <div class="space-y-2">
              <%= link_to edit_employee_path(@employee), class: "btn-outline w-full justify-start" do %>
                <%= lucide_icon "edit", class: "w-4 h-4" %>
                <span>编辑档案</span>
              <% end %>
              <%= link_to export_pdf_employee_path(@employee, format: :pdf), class: "btn-outline w-full justify-start" do %>
                <%= lucide_icon "download", class: "w-4 h-4" %>
                <span>导出PDF</span>
              <% end %>
            </div>
          </div>
        </div>

        <% if @employee.contract_expiring_soon? || @employee.contract_expired? %>
          <div class="alert-<%= @employee.contract_expired? ? 'danger' : 'warning' %>">
            <%= lucide_icon "alert-circle", class: "w-5 h-5" %>
            <div>
              <h4 class="font-semibold"><%= @employee.contract_expired? ? '合同已过期' : '合同即将到期' %></h4>
              <p class="text-sm">请及时处理劳动合同续签事宜</p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
