<div class="min-h-screen bg-surface py-8">
  <div class="container-xl mx-auto px-6">
    
    <!-- 搜索框 -->
    <div class="mb-8">
      <%= form_with url: search_path, method: :get, class: "flex gap-3" do |f| %>
        <div class="flex-1 relative">
          <%= f.text_field :q, value: @query, 
            placeholder: "搜索合同、案件、问题、对账单、工作记录...", 
            class: "form-input w-full text-lg pr-12",
            autofocus: true %>
          <%= lucide_icon "search", class: "absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-muted pointer-events-none" %>
        </div>
        <%= f.submit "搜索", class: "btn-primary px-8" %>
      <% end %>
      
      <div class="flex items-center gap-2 mt-3 text-sm">
        <% if lawyer? %>
          <%= lucide_icon "shield-check", class: "w-4 h-4 text-success" %>
          <span class="text-secondary">律师模式：可搜索系统内全部企业资料</span>
        <% else %>
          <%= lucide_icon "lock", class: "w-4 h-4 text-primary" %>
          <span class="text-secondary">仅搜索 <strong class="text-primary"><%= viewing_company&.name %></strong> 的资料</span>
        <% end %>
        
        <% if @query.present? %>
          <span class="ml-auto text-muted">找到 <strong class="text-primary"><%= @results.total_count %></strong> 条结果</span>
        <% end %>
      </div>
    </div>
    
    <% if @query.present? %>
      <!-- 分类过滤 -->
      <div class="flex items-center gap-3 mb-6 flex-wrap">
        <%= link_to search_path(q: @query), 
          class: "badge #{@category.blank? ? 'badge-primary' : 'badge-neutral hover:badge-primary'} transition-colors" do %>
          全部 (<%= @results.total_count %>)
        <% end %>
        
        <% @stats.each do |category, count| %>
          <%= link_to search_path(q: @query, category: category),
            class: "badge #{@category == category ? 'badge-primary' : 'badge-neutral hover:badge-primary'} transition-colors" do %>
            <%= category %> (<%= count %>)
          <% end %>
        <% end %>
      </div>
      
      <!-- 搜索结果 -->
      <% if @results.any? %>
        <div class="space-y-4">
          <% @results.each do |result| %>
            <div class="card card-elevated hover:shadow-xl transition-all duration-300">
              <div class="card-body">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-2 flex-wrap">
                      <span class="badge badge-secondary flex-shrink-0"><%= result.category %></span>
                      <h3 class="font-heading text-lg font-bold text-primary">
                        <%= highlight(result.title, @query, highlighter: '<mark class="bg-yellow-200 text-primary">\1</mark>').html_safe %>
                      </h3>
                    </div>
                    
                    <% if result.content.present? %>
                      <p class="text-secondary text-sm mb-3">
                        <%= highlight(truncate(result.content, length: 200), @query, highlighter: '<mark class="bg-yellow-200 text-secondary">\1</mark>').html_safe %>
                      </p>
                    <% end %>
                    
                    <div class="flex items-center gap-4 text-xs text-muted flex-wrap">
                      <% if result.metadata['status'].present? %>
                        <span class="flex items-center gap-1">
                          <%= lucide_icon "tag", class: "w-3 h-3" %>
                          状态：<%= result.metadata['status'] %>
                        </span>
                      <% end %>
                      
                      <% if result.metadata['case_number'].present? %>
                        <span class="flex items-center gap-1">
                          <%= lucide_icon "hash", class: "w-3 h-3" %>
                          案号：<%= result.metadata['case_number'] %>
                        </span>
                      <% end %>
                      
                      <span class="flex items-center gap-1">
                        <%= lucide_icon "clock", class: "w-3 h-3" %>
                        更新于 <%= result.indexed_at.strftime('%Y-%m-%d %H:%M') %>
                      </span>
                    </div>
                  </div>
                  
                  <%# 生成正确的详情链接 %>
                  <% if result.searchable_type == 'Reconciliation' %>
                    <%# 对账单链接到其所属的合同 %>
                    <%= link_to contract_path(result.searchable.contract), 
                      class: "btn-info btn-sm flex-shrink-0" do %>
                      <%= lucide_icon "arrow-right", class: "w-4 h-4" %>
                      <span>查看合同</span>
                    <% end %>
                  <% elsif result.searchable_type == 'WorkLog' %>
                    <%# 工作记录链接到其所属的案件 %>
                    <%= link_to case_path(result.searchable.case), 
                      class: "btn-info btn-sm flex-shrink-0" do %>
                      <%= lucide_icon "arrow-right", class: "w-4 h-4" %>
                      <span>查看案件</span>
                    <% end %>
                  <% else %>
                    <%# 其他模型直接链接到详情页 %>
                    <%= link_to polymorphic_path(result.searchable), 
                      class: "btn-info btn-sm flex-shrink-0" do %>
                      <%= lucide_icon "arrow-right", class: "w-4 h-4" %>
                      <span>查看详情</span>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        
        <!-- 分页 -->
        <% if @results.total_pages > 1 %>
          <div class="mt-8">
            <%= paginate @results %>
          </div>
        <% end %>
      <% else %>
        <div class="card card-elevated">
          <div class="card-body text-center py-16">
            <%= lucide_icon "search-x", class: "w-16 h-16 text-muted mx-auto mb-4" %>
            <h3 class="font-heading text-xl font-semibold text-secondary mb-2">
              没有找到 "<%= @query %>" 的相关结果
            </h3>
            <p class="text-muted mb-6">尝试使用不同的关键词进行搜索</p>
            <div class="flex flex-wrap gap-2 justify-center">
              <span class="text-sm text-muted">建议：</span>
              <span class="badge badge-outline">使用更简短的关键词</span>
              <span class="badge badge-outline">检查拼写是否正确</span>
              <span class="badge badge-outline">尝试相关的同义词</span>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <!-- 空状态提示 -->
      <div class="card card-elevated">
        <div class="card-body text-center py-16">
          <%= lucide_icon "search", class: "w-20 h-20 text-muted mx-auto mb-4" %>
          <h3 class="font-heading text-2xl font-semibold text-primary mb-3">
            全局搜索
          </h3>
          <p class="text-secondary text-lg mb-6">
            搜索合同档案、案件、重大法律问题、对账单、工作大事记...
          </p>
          
          <div class="max-w-2xl mx-auto">
            <div class="grid md:grid-cols-2 gap-4 text-left">
              <div class="p-4 bg-surface-elevated rounded-lg">
                <div class="flex items-center gap-2 mb-2">
                  <%= lucide_icon "zap", class: "w-5 h-5 text-warning" %>
                  <h4 class="font-semibold text-primary">搜索技巧</h4>
                </div>
                <ul class="text-sm text-secondary space-y-1">
                  <li>• 输入关键词即可快速搜索</li>
                  <li>• 支持模糊匹配和中文搜索</li>
                  <li>• 可按分类筛选结果</li>
                </ul>
              </div>
              
              <div class="p-4 bg-surface-elevated rounded-lg">
                <div class="flex items-center gap-2 mb-2">
                  <%= lucide_icon "keyboard", class: "w-5 h-5 text-info" %>
                  <h4 class="font-semibold text-primary">快捷键</h4>
                </div>
                <ul class="text-sm text-secondary space-y-1">
                  <li>• <kbd class="px-2 py-1 bg-surface border border-border rounded text-xs">Ctrl</kbd> + <kbd class="px-2 py-1 bg-surface border border-border rounded text-xs">K</kbd> 快速打开搜索</li>
                  <li>• <kbd class="px-2 py-1 bg-surface border border-border rounded text-xs">ESC</kbd> 关闭搜索</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
