<div class="min-h-screen bg-surface py-8">
  <div class="container-xl mx-auto px-6">
    <% if lawyer? && @company %>
      <div class="mb-6 card card-flat border-l-4 border-secondary">
        <div class="card-body py-3 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <%= lucide_icon "building-2", class: "w-5 h-5 text-secondary" %>
            <span class="text-secondary">当前查看：<strong class="text-primary"><%= @company.name %></strong></span>
          </div>
          <%= link_to "返回企业列表", lawyer_companies_path, class: "btn-outline btn-sm" %>
        </div>
      </div>
    <% elsif lawyer? && !@company %>
      <div class="mb-6 card card-flat border-l-4 border-primary">
        <div class="card-body py-3 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <%= lucide_icon "layers", class: "w-5 h-5 text-primary" %>
            <span class="text-primary">当前模式：<strong>全部企业</strong></span>
          </div>
          <%= link_to "返回企业列表", lawyer_companies_path, class: "btn-outline btn-sm" %>
        </div>
      </div>
    <% end %>

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="font-heading text-4xl font-bold text-primary mb-2">合同风险预警看板</h1>
        <p class="text-secondary">实时监控合同风险状态，及时发现和处理潜在问题</p>
      </div>
      <%= link_to contracts_path, class: "btn-outline flex items-center gap-2" do %>
        <%= lucide_icon "list", class: "w-5 h-5" %>
        <span>返回合同列表</span>
      <% end %>
    </div>

    <!-- 统计卡片 -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
      <div class="card card-elevated hover:shadow-lg transition-shadow">
        <div class="card-body text-center">
          <div class="text-3xl font-bold text-primary mb-1"><%= @summary[:total_active] %></div>
          <div class="text-sm text-muted">执行中合同</div>
        </div>
      </div>
      
      <div class="card card-elevated hover:shadow-lg transition-shadow border-l-4 border-danger">
        <div class="card-body text-center">
          <div class="text-3xl font-bold text-danger mb-1"><%= @summary[:high_risk_count] %></div>
          <div class="text-sm text-muted">高风险合同</div>
        </div>
      </div>
      
      <div class="card card-elevated hover:shadow-lg transition-shadow border-l-4 border-warning">
        <div class="card-body text-center">
          <div class="text-3xl font-bold text-warning mb-1"><%= @summary[:expiring_soon_count] %></div>
          <div class="text-sm text-muted">即将到期</div>
        </div>
      </div>
      
      <div class="card card-elevated hover:shadow-lg transition-shadow border-l-4 border-warning">
        <div class="card-body text-center">
          <div class="text-3xl font-bold text-warning mb-1"><%= @summary[:overdue_reconciliation_count] %></div>
          <div class="text-sm text-muted">待上传对账单</div>
        </div>
      </div>
      
      <div class="card card-elevated hover:shadow-lg transition-shadow border-l-4 border-danger">
        <div class="card-body text-center">
          <div class="text-3xl font-bold text-danger mb-1"><%= @summary[:dispute_count] %></div>
          <div class="text-sm text-muted">存在争议</div>
        </div>
      </div>
      
      <div class="card card-elevated hover:shadow-lg transition-shadow border-l-4 border-info">
        <div class="card-body text-center">
          <div class="text-3xl font-bold text-info mb-1"><%= @summary[:unreviewed_count] %></div>
          <div class="text-sm text-muted">待审查</div>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">
      <!-- 高风险合同 -->
      <div class="card card-elevated">
        <div class="card-header border-b border-border">
          <h3 class="font-heading text-xl font-bold text-danger flex items-center gap-2">
            <%= lucide_icon "alert-triangle", class: "w-5 h-5" %>
            <span>高风险合同</span>
          </h3>
        </div>
        <div class="card-body">
          <% if @high_risk_contracts.any? %>
            <div class="space-y-3">
              <% @high_risk_contracts.each do |contract| %>
                <div class="p-3 border border-border rounded-lg hover:bg-surface-elevated transition-colors">
                  <div class="flex items-start justify-between mb-2">
                    <%= link_to contract[:name], contract_path(contract[:id]), class: "font-semibold text-primary hover:underline" %>
                    <span class="badge-danger text-xs flex-shrink-0"><%= contract[:legal_risk_level] %></span>
                  </div>
                  <div class="text-sm text-muted space-y-1">
                    <div>对方：<%= contract[:counterparty_name] %></div>
                    <div>到期：<%= contract[:end_at]&.strftime('%Y-%m-%d') %></div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-center text-muted py-8">暂无高风险合同</p>
          <% end %>
        </div>
      </div>

      <!-- 即将到期合同 -->
      <div class="card card-elevated">
        <div class="card-header border-b border-border">
          <h3 class="font-heading text-xl font-bold text-warning flex items-center gap-2">
            <%= lucide_icon "clock", class: "w-5 h-5" %>
            <span>即将到期合同</span>
          </h3>
        </div>
        <div class="card-body">
          <% if @expiring_contracts.any? %>
            <div class="space-y-3">
              <% @expiring_contracts.each do |contract| %>
                <div class="p-3 border border-border rounded-lg hover:bg-surface-elevated transition-colors">
                  <div class="flex items-start justify-between mb-2">
                    <%= link_to contract[:name], contract_path(contract[:id]), class: "font-semibold text-primary hover:underline" %>
                    <% days_left = (contract[:end_at] - Date.today).to_i %>
                    <span class="badge-warning text-xs flex-shrink-0"><%= days_left %>天</span>
                  </div>
                  <div class="text-sm text-muted space-y-1">
                    <div>对方：<%= contract[:counterparty_name] %></div>
                    <div>到期：<%= contract[:end_at]&.strftime('%Y-%m-%d') %></div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-center text-muted py-8">暂无即将到期合同</p>
          <% end %>
        </div>
      </div>

      <!-- 待上传对账单 -->
      <div class="card card-elevated">
        <div class="card-header border-b border-border">
          <h3 class="font-heading text-xl font-bold text-warning flex items-center gap-2">
            <%= lucide_icon "calendar-x", class: "w-5 h-5" %>
            <span>待上传对账单</span>
          </h3>
        </div>
        <div class="card-body">
          <% if @overdue_reconciliations.any? %>
            <div class="space-y-3">
              <% @overdue_reconciliations.each do |contract| %>
                <div class="p-3 border border-border rounded-lg hover:bg-surface-elevated transition-colors">
                  <div class="flex items-start justify-between mb-2">
                    <%= link_to contract[:name], contract_path(contract[:id]), class: "font-semibold text-primary hover:underline" %>
                    <span class="badge-warning text-xs flex-shrink-0">逾期</span>
                  </div>
                  <div class="text-sm text-muted space-y-1">
                    <div>对方：<%= contract[:counterparty_name] %></div>
                    <div>账期：<%= Time.current.strftime('%Y年%m月') %></div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-center text-muted py-8">所有合同对账单均已上传</p>
          <% end %>
        </div>
      </div>

      <!-- 存在争议合同 -->
      <div class="card card-elevated">
        <div class="card-header border-b border-border">
          <h3 class="font-heading text-xl font-bold text-danger flex items-center gap-2">
            <%= lucide_icon "alert-circle", class: "w-5 h-5" %>
            <span>存在争议合同</span>
          </h3>
        </div>
        <div class="card-body">
          <% if @dispute_contracts.any? %>
            <div class="space-y-3">
              <% @dispute_contracts.each do |contract| %>
                <div class="p-3 border border-border rounded-lg hover:bg-surface-elevated transition-colors">
                  <div class="flex items-start justify-between mb-2">
                    <%= link_to contract[:name], contract_path(contract[:id]), class: "font-semibold text-primary hover:underline" %>
                    <span class="badge-danger text-xs flex-shrink-0"><%= contract[:dispute_status] %></span>
                  </div>
                  <div class="text-sm text-muted space-y-1">
                    <div>对方：<%= contract[:counterparty_name] %></div>
                    <div>履行：<%= contract[:performance_status] || '未记录' %></div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-center text-muted py-8">暂无争议合同</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
