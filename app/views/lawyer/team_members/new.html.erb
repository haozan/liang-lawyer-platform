<div class="max-w-2xl mx-auto py-8">
  <div class="mb-6">
    <div class="flex items-center gap-3 mb-2">
      <%= link_to lawyer_team_path, class: "text-muted hover:text-primary transition-colors" do %>
        <%= lucide_icon "arrow-left", class: "w-5 h-5" %>
      <% end %>
      <h1 class="text-2xl font-bold">创建团队成员账户</h1>
    </div>
    <p class="text-muted">为 <%= @team.name %> 创建新的律师账户</p>
  </div>

  <div class="card">
    <div class="card-body">
      <%= form_with model: @lawyer_account, url: lawyer_team_members_path, method: :post, class: "space-y-6" do |f| %>
        <%= render 'shared/form_errors', object: @lawyer_account %>

        <!-- 姓名 -->
        <div class="form-group">
          <%= f.label :name, "姓名", class: "form-label required" %>
          <%= f.text_field :name, class: "form-input", placeholder: "请输入姓名", autofocus: true, required: true %>
        </div>

        <!-- 手机号 -->
        <div class="form-group">
          <%= f.label :phone, "手机号", class: "form-label required" %>
          <%= f.telephone_field :phone, class: "form-input", placeholder: "请输入11位手机号", pattern: "1[3-9]\\d{9}", required: true %>
          <p class="form-hint">此手机号将作为登录账号</p>
        </div>

        <!-- 角色 -->
        <div class="form-group">
          <%= f.label :role, "角色", class: "form-label required" %>
          <%= f.select :role, 
                       [
                         ['律师助理', 'assistant'],
                         ['律师', 'lawyer'],
                         ['资深律师', 'senior_lawyer']
                       ],
                       { include_blank: '请选择角色' },
                       { class: "form-select", required: true } %>
        </div>

        <!-- 密码 -->
        <div class="form-group">
          <%= f.label :password, "初始密码", class: "form-label required" %>
          <%= f.password_field :password, class: "form-input", placeholder: "请设置初始密码（至少6位）", minlength: 6, required: true %>
          <p class="form-hint">成员首次登录后可自行修改密码</p>
        </div>

        <!-- 确认密码 -->
        <div class="form-group">
          <%= f.label :password_confirmation, "确认密码", class: "form-label required" %>
          <%= f.password_field :password_confirmation, class: "form-input", placeholder: "请再次输入密码", minlength: 6, required: true %>
        </div>

        <!-- 提示信息 -->
        <div class="alert alert-info">
          <%= lucide_icon "info", class: "w-5 h-5" %>
          <div>
            <h4 class="font-semibold mb-1">温馨提示</h4>
            <ul class="text-sm space-y-1 ml-4 list-disc">
              <li>新成员账户将自动加入 <%= @team.name %></li>
              <li>成员可使用手机号和密码登录系统</li>
              <li>请妥善保管初始密码并告知新成员</li>
              <li>建议新成员首次登录后立即修改密码</li>
            </ul>
          </div>
        </div>

        <!-- 操作按钮 -->
        <div class="flex items-center gap-3">
          <%= f.submit "创建账户", class: "btn-primary" %>
          <%= link_to "取消", lawyer_team_path, class: "btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
