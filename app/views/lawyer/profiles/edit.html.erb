<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <h1 class="page-title">账户设置</h1>
    <p class="text-secondary">管理您的个人信息和密码</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- 个人信息卡片 -->
    <div class="lg:col-span-2">
      <div class="card card-elevated">
        <div class="card-body">
          <h2 class="text-2xl font-semibold mb-6 flex items-center text-primary">
            <%= lucide_icon "user", class: "w-6 h-6 mr-2" %>
            个人信息
          </h2>

          <%= form_with model: current_lawyer, url: lawyer_profile_path, method: :patch, class: "space-y-6" do |f| %>
            <!-- 姓名字段 -->
            <div class="form-group">
              <%= f.label :name, "姓名" %>
              <%= f.text_field :name, placeholder: "请输入您的姓名", class: "form-input" %>
            </div>

            <!-- 手机号字段 -->
            <div class="form-group">
              <%= f.label :phone, "手机号" %>
              <%= f.text_field :phone, placeholder: "请输入手机号（如：13800138000）", class: "form-input" %>
              <p class="form-help">手机号用于登录和接收通知</p>
            </div>

            <!-- 当前密码字段 -->
            <div class="form-group">
              <%= f.label :current_password, "当前密码" %>
              <%= f.password_field :current_password, placeholder: "请输入当前密码以验证身份", class: "form-input" %>
              <p class="form-help">为了安全起见，修改信息需要验证当前密码</p>
            </div>

            <!-- 新密码字段 -->
            <div class="form-group">
              <%= f.label :password, "新密码（留空则不修改）" %>
              <%= f.password_field :password, placeholder: "请输入新密码（可选）", class: "form-input" %>
              <p class="form-help">密码长度至少 6 位字符</p>
            </div>

            <!-- 确认密码字段 -->
            <div class="form-group">
              <%= f.label :password_confirmation, "确认新密码" %>
              <%= f.password_field :password_confirmation, placeholder: "再次输入新密码", class: "form-input" %>
            </div>

            <!-- 操作按钮 -->
            <div class="flex items-center justify-end space-x-4 pt-4">
              <%= link_to lawyer_companies_path, class: "btn-ghost" do %>
                <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
                返回首页
              <% end %>
              <%= f.submit "保存修改", class: "btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- 账户信息卡片 -->
    <div>
      <div class="card card-elevated">
        <div class="card-body">
          <h2 class="text-xl font-semibold mb-4 flex items-center text-primary">
            <%= lucide_icon "info", class: "w-5 h-5 mr-2" %>
            账户信息
          </h2>

          <div class="space-y-4">


            <!-- 账户角色 -->
            <div class="flex items-center p-3 bg-info/10 border border-info/30 rounded-lg">
              <div class="flex-shrink-0">
                <%= lucide_icon "briefcase", class: "w-6 h-6 text-info" %>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-secondary">账户角色</p>
                <p class="text-xs text-info font-semibold">
                  <%= current_lawyer.lawyer? ? '律师' : '律师助理' %>
                </p>
              </div>
            </div>

            <!-- 账户状态 -->
            <div class="flex items-center p-3 bg-success/10 border border-success/30 rounded-lg">
              <div class="flex-shrink-0">
                <%= lucide_icon "check-circle", class: "w-6 h-6 text-success" %>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-secondary">账户状态</p>
                <p class="text-xs text-success font-semibold">正常使用中</p>
              </div>
            </div>

            <!-- 注册时间 -->
            <div class="flex items-center p-3 bg-surface rounded-lg border border-border">
              <div class="flex-shrink-0">
                <%= lucide_icon "calendar", class: "w-6 h-6 text-muted" %>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-secondary">注册时间</p>
                <p class="text-xs text-muted">
                  <%= current_lawyer.created_at.strftime("%Y年%m月%d日") %>
                </p>
              </div>
            </div>

            <!-- 安全提示 -->
            <div class="flex items-center p-3 bg-warning/10 border border-warning/30 rounded-lg">
              <div class="flex-shrink-0">
                <%= lucide_icon "shield-alert", class: "w-6 h-6 text-warning" %>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-secondary">安全提示</p>
                <p class="text-xs text-warning">定期更换密码以保障账户安全</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
