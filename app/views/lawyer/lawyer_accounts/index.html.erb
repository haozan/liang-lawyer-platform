<div class="container-xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-heading font-bold text-primary">律师账号管理</h1>
    <%= link_to "添加律师账号", new_lawyer_lawyer_account_path, class: "btn-primary" %>
  </div>

  <div class="card">
    <div class="card-body">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-3 px-4">姓名</th>
              <th class="text-left py-3 px-4">手机号</th>
              <th class="text-left py-3 px-4">角色</th>
              <th class="text-left py-3 px-4">创建时间</th>
              <th class="text-left py-3 px-4">操作</th>
            </tr>
          </thead>
          <tbody>
            <% @lawyer_accounts.each do |account| %>
              <tr class="border-b border-border hover:bg-surface">
                <td class="py-3 px-4"><%= account.name %></td>
                <td class="py-3 px-4"><%= account.phone %></td>
                <td class="py-3 px-4">
                  <span class="badge badge-<%= account.lawyer? ? 'primary' : 'secondary' %>">
                    <%= account.lawyer? ? '律师' : '律师助理' %>
                  </span>
                </td>
                <td class="py-3 px-4"><%= account.created_at.strftime('%Y-%m-%d') %></td>
                <td class="py-3 px-4">
                  <%= link_to "编辑", edit_lawyer_lawyer_account_path(account), class: "text-primary hover:underline mr-3" %>
                  <%= link_to "删除", lawyer_lawyer_account_path(account), 
                      data: { turbo_method: :delete, turbo_confirm: "确定删除这个账号吗？" }, 
                      class: "text-error hover:underline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
