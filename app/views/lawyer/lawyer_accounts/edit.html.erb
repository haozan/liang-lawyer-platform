<div class="container-md mx-auto px-4 py-8">
  <div class="card">
    <div class="card-body">
      <h1 class="text-2xl font-heading font-bold text-primary mb-6">编辑律师账号</h1>

      <%= form_with model: @lawyer_account, url: lawyer_lawyer_account_path(@lawyer_account), method: :patch, class: "space-y-6" do |f| %>
        <% if @lawyer_account.errors.any? %>
          <div class="alert alert-error">
            <ul class="list-disc list-inside">
              <% @lawyer_account.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "姓名", class: "form-label" %>
          <%= f.text_field :name, class: "form-input", required: true %>
        </div>

        <div>
          <%= f.label :phone, "手机号", class: "form-label" %>
          <%= f.telephone_field :phone, class: "form-input", required: true, placeholder: "请输入11位手机号" %>
        </div>

        <div>
          <%= f.label :role, "角色", class: "form-label" %>
          <%= f.select :role, [['律师', 'lawyer'], ['律师助理', 'assistant']], {}, class: "form-select" %>
        </div>

        <div class="border-t border-border pt-6 mt-6">
          <h2 class="text-lg font-medium text-primary mb-4">修改密码（可选）</h2>
          <p class="form-hint mb-4">如果不需要修改密码，请留空</p>

          <div class="space-y-4">
            <div>
              <%= f.label :password, "新密码", class: "form-label" %>
              <%= f.password_field :password, class: "form-input", placeholder: "留空表示不修改" %>
            </div>

            <div>
              <%= f.label :password_confirmation, "确认新密码", class: "form-label" %>
              <%= f.password_field :password_confirmation, class: "form-input" %>
            </div>
          </div>
        </div>

        <div class="flex gap-3">
          <%= f.submit "更新账号", class: "btn-primary" %>
          <%= link_to "取消", lawyer_lawyer_accounts_path, class: "btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
