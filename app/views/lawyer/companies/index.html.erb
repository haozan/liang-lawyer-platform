<div class="min-h-screen bg-surface py-8">
  <div class="container-xl mx-auto px-6">
    
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="font-heading text-4xl font-bold text-primary mb-2">首页</h1>
        <p class="text-secondary">今日工作概览</p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to lawyer_team_path, class: "btn-outline" do %>
          <%= lucide_icon "users", class: "w-5 h-5" %>
          <span>我的团队</span>
        <% end %>
        <div data-controller="dropdown" class="relative">
          <button type="button"
                  data-dropdown-target="trigger"
                  data-action="click->dropdown#toggle"
                  class="btn-outline">
            <%= lucide_icon "settings", class: "w-5 h-5" %>
            <span>管理企业</span>
            <%= lucide_icon "chevron-down", class: "w-4 h-4" %>
          </button>
          
          <div data-dropdown-target="menu"
               class="hidden absolute right-0 top-full mt-2 w-72 bg-surface-elevated rounded-lg shadow-xl border border-surface-elevated z-50 max-h-96 overflow-y-auto">
            <div class="p-3">
              <p class="text-xs text-secondary font-semibold px-3 py-2">编辑企业信息</p>
              <% @companies.each do |company| %>
                <div class="flex items-center justify-between p-2 hover:bg-surface rounded transition-colors">
                  <div class="flex items-center gap-2 flex-1 min-w-0">
                    <%= lucide_icon "building-2", class: "w-4 h-4 text-secondary flex-shrink-0" %>
                    <span class="text-sm text-primary truncate"><%= company.name %></span>
                  </div>
                  <% if company.can_be_managed_by?(current_lawyer) %>
                    <%= link_to edit_lawyer_company_path(company), class: "btn-outline btn-sm", title: "编辑企业" do %>
                      <%= lucide_icon "edit", class: "w-3 h-3" %>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
              <div class="border-t border-surface-elevated mt-2 pt-2">
                <% if current_lawyer.super_admin? || current_lawyer.team_leader? %>
                  <%= link_to new_lawyer_company_path, class: "flex items-center gap-2 p-2 hover:bg-surface rounded transition-colors text-primary" do %>
                    <%= lucide_icon "plus", class: "w-4 h-4" %>
                    <span class="text-sm">新建企业</span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
        <%= link_to lawyer_company_accounts_path, class: "btn-outline" do %>
          <%= lucide_icon "users", class: "w-5 h-5" %>
          <span>管理企业账户</span>
        <% end %>
        <% if current_lawyer.super_admin? || current_lawyer.team_leader? %>
          <%= link_to new_lawyer_company_path, class: "btn-primary" do %>
            <%= lucide_icon "plus", class: "w-5 h-5" %>
            <span>新建企业</span>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- 企业导航栏 -->
    <div class="card card-elevated mb-8">
      <div class="card-body p-4">
        <div class="flex items-center gap-4">
          <%= lucide_icon "building-2", class: "w-5 h-5 text-primary flex-shrink-0" %>
          
          <!-- "全部企业"按钮 -->
          <div class="flex-shrink-0">
            <%= link_to lawyer_companies_path, 
                class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition-all #{@selected_company_id ? 'bg-surface-hover text-secondary hover:bg-surface-elevated' : 'bg-primary text-white'}" do %>
              <%= lucide_icon "layers", class: "w-4 h-4" %>
              <span>全部企业</span>
              <% total_announcements = @announcements.count %>
              <% if @selected_company_id.nil? && total_announcements > 0 %>
                <span class="inline-flex items-center justify-center min-w-[1.5rem] h-6 px-2 bg-white/20 text-white rounded-full text-xs font-bold">
                  <%= total_announcements %>
                </span>
              <% end %>
            <% end %>
          </div>
          
          <!-- 分隔线 -->
          <div class="w-px h-8 bg-border flex-shrink-0"></div>
          
          <!-- 企业选择器 -->
          <div class="flex-1 relative" data-controller="company-selector">
            <button type="button" 
                    data-action="click->company-selector#toggle"
                    class="inline-flex items-center justify-between gap-3 px-4 py-2 rounded-lg font-medium transition-all w-full max-w-md bg-surface-hover text-secondary hover:bg-surface-elevated hover:text-primary border border-border">
              <div class="flex items-center gap-2 flex-1 min-w-0">
                <%= lucide_icon "building", class: "w-4 h-4 flex-shrink-0" %>
                <span class="truncate" data-company-selector-target="selectedText">
                  <% if @selected_company_id %>
                    <% selected_company = @companies_with_announcement_count.find { |c| c.id == @selected_company_id.to_i } %>
                    <%= selected_company&.name || '选择企业' %>
                  <% else %>
                    选择企业
                  <% end %>
                </span>
                <% if @selected_company_id %>
                  <% selected_company = @companies_with_announcement_count.find { |c| c.id == @selected_company_id.to_i } %>
                  <% if selected_company && selected_company.announcement_count > 0 %>
                    <span class="inline-flex items-center justify-center min-w-[1.5rem] h-5 px-1.5 bg-primary text-white rounded-full text-xs font-bold">
                      <%= selected_company.announcement_count %>
                    </span>
                  <% end %>
                <% end %>
              </div>
              <%= lucide_icon "chevron-down", class: "w-4 h-4 flex-shrink-0" %>
            </button>
            
            <!-- 下拉菜单 -->
            <div data-company-selector-target="menu" 
                 data-action="click->company-selector#preventClose"
                 class="hidden absolute left-0 mt-2 w-full max-w-md bg-surface border border-border rounded-lg shadow-xl z-50 max-h-[32rem] overflow-hidden flex flex-col">
              
              <!-- 搜索框 -->
              <div class="p-3 border-b border-border bg-surface-elevated">
                <div class="relative">
                  <%= lucide_icon "search", class: "absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted" %>
                  <input type="text" 
                         data-company-selector-target="searchInput"
                         data-action="input->company-selector#search"
                         placeholder="搜索企业名称..."
                         class="w-full pl-10 pr-3 py-2 bg-surface border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                </div>
              </div>
              
              <!-- 企业列表 -->
              <div data-company-selector-target="companyList" class="overflow-y-auto flex-1">
                <div class="py-2">
                  <% @companies_with_announcement_count.each do |company_data| %>
                    <% is_selected = @selected_company_id.to_i == company_data.id %>
                    <%= link_to lawyer_companies_path(company_id: company_data.id), 
                        data: { 
                          company_selector_target: 'companyItem',
                          company_name: company_data.name 
                        },
                        class: "flex items-center justify-between px-4 py-2.5 hover:bg-surface-hover transition-colors #{is_selected ? 'bg-primary/10' : ''}" do %>
                      <div class="flex items-center gap-3 flex-1 min-w-0">
                        <%= lucide_icon "building", class: "w-4 h-4 flex-shrink-0 #{is_selected ? 'text-primary' : 'text-muted'}" %>
                        <span class="truncate #{is_selected ? 'text-primary font-semibold' : 'text-secondary'}">
                          <%= company_data.name %>
                        </span>
                      </div>
                      <div class="flex items-center gap-2 flex-shrink-0">
                        <% if company_data.announcement_count > 0 %>
                          <span class="inline-flex items-center justify-center min-w-[1.5rem] h-5 px-1.5 bg-primary text-white rounded-full text-xs font-bold">
                            <%= company_data.announcement_count %>
                          </span>
                        <% end %>
                        <% if is_selected %>
                          <%= lucide_icon "check", class: "w-4 h-4 text-primary" %>
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                </div>
              </div>
              
              <!-- 底部提示 -->
              <div class="px-4 py-2 border-t border-border bg-surface-elevated text-xs text-muted">
                <%= lucide_icon "info", class: "w-3 h-3 inline mr-1" %>
                共 <%= @companies_with_announcement_count.count %> 家企业
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 公告区域 - 可折叠版本 -->
    <%= render 'compact_announcements' %>

    <!-- 今日重点待办 -->
    <% urgent_and_today = (@urgent_items + @pending_contracts.select { |item| item[:record].created_at >= Time.current.beginning_of_day }).take(5) %>
    <% if urgent_and_today.any? %>
      <div class="card card-elevated mb-8 border-l-4 border-red-500">
        <div class="card-body">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <%= lucide_icon "alert-circle", class: "w-6 h-6 text-red-600" %>
              <h2 class="font-heading text-xl font-bold text-primary">🔥 今日重点</h2>
              <span class="badge badge-error"><%= urgent_and_today.count %> 项</span>
            </div>
            <%= link_to todos_path, class: "btn-outline btn-sm" do %>
              <%= lucide_icon "list", class: "w-4 h-4" %>
              <span>查看全部待办</span>
            <% end %>
          </div>
          
          <div class="space-y-3">
            <% urgent_and_today.each do |item| %>
              <div class="flex items-start gap-3 p-3 bg-surface rounded-lg hover:bg-surface-hover transition-colors">
                <% icon_color_class = item[:priority] == 0 ? 'text-red-600' : 'text-orange-600' %>
                <%= lucide_icon(
                  case item[:type]
                  when :contract then "file-text"
                  when :case then "briefcase"
                  when :major_issue then "message-square"
                  else "alert-circle"
                  end, 
                  class: "w-5 h-5 #{icon_color_class} flex-shrink-0 mt-0.5"
                ) %>
                <div class="flex-1 min-w-0">
                  <%= link_to item[:link], class: "block" do %>
                    <p class="font-medium text-primary hover:text-primary-dark mb-1">
                      <% if item[:company] %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded bg-surface-elevated text-xs font-medium text-secondary mr-2">
                          <%= lucide_icon "building-2", class: "w-3 h-3 mr-1 inline" %>
                          <%= item[:company].name %>
                        </span>
                      <% end %>
                      <%= item[:message] %>
                    </p>
                    <% if item[:created_ago] %>
                      <p class="text-sm text-muted"><%= item[:created_ago] %>创建</p>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="card card-elevated mb-8">
        <div class="card-body py-8">
          <div class="flex flex-col items-center justify-center">
            <%= lucide_icon "check-circle", class: "w-16 h-16 text-green-500 mb-3" %>
            <p class="text-lg font-semibold text-primary mb-1">✅ 今日暂无紧急事项</p>
            <p class="text-sm text-secondary">一切正常，继续保持！</p>
          </div>
        </div>
      </div>
    <% end %>

    <!-- 快捷入口 -->
    <div class="mb-8">
      <h2 class="font-heading text-2xl font-bold text-primary mb-4">快捷入口</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Contracts -->
        <%= link_to contracts_path(@selected_company_id.present? ? { company_id: @selected_company_id } : { company_id: 'all' }), class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300 border-l-4 border-success">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-success/10 rounded-lg">
                  <%= lucide_icon "file-text", class: "w-8 h-8 text-success" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">合同档案</h3>
                  <p class="text-sm text-secondary">审查合同、管理合同档案</p>
                </div>
                <%= lucide_icon "arrow-right", class: "w-6 h-6 text-muted" %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Cases -->
        <%= link_to cases_path(@selected_company_id.present? ? { company_id: @selected_company_id } : { company_id: 'all' }), class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300 border-l-4 border-info">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-info/10 rounded-lg">
                  <%= lucide_icon "briefcase", class: "w-8 h-8 text-info" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">案件管理</h3>
                  <p class="text-sm text-secondary">创建案件、跟踪案件进展</p>
                </div>
                <%= lucide_icon "arrow-right", class: "w-6 h-6 text-muted" %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Major Issues -->
        <%= link_to major_issues_path(@selected_company_id.present? ? { company_id: @selected_company_id } : { company_id: 'all' }), class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300 border-l-4 border-warning">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-warning/10 rounded-lg">
                  <%= lucide_icon "message-square", class: "w-8 h-8 text-warning" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">重大事项</h3>
                  <p class="text-sm text-secondary">处理重大事项、协调讨论</p>
                </div>
                <%= lucide_icon "arrow-right", class: "w-6 h-6 text-muted" %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Data Analytics -->
        <%= link_to dashboard_major_issue_analytics_path, class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300 border-l-4 border-primary">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-primary/10 rounded-lg">
                  <%= lucide_icon "bar-chart-3", class: "w-8 h-8 text-primary" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">数据分析</h3>
                  <p class="text-sm text-secondary">查看重大事项数据分析</p>
                </div>
                <%= lucide_icon "arrow-right", class: "w-6 h-6 text-muted" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>
