<div class="min-h-screen bg-surface py-8">
  <div class="container-xl mx-auto px-6">
    
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="font-heading text-4xl font-bold text-primary mb-2">首页</h1>
        <p class="text-secondary">欢迎回来，<%= current_lawyer.name %></p>
      </div>
      <div class="flex items-center gap-3">
        <% if current_lawyer.super_admin? || current_lawyer.admin? %>
          <%= link_to new_lawyer_company_path, class: "btn-primary" do %>
            <%= lucide_icon "plus", class: "w-5 h-5" %>
            <span>新建企业</span>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- 统计概览 -->
    <div class="grid md:grid-cols-4 gap-6 mb-8">
      <div class="card card-elevated">
        <div class="card-body flex items-center gap-4">
          <div class="p-3 bg-primary/10 rounded-lg">
            <%= lucide_icon "building-2", class: "w-6 h-6 text-primary" %>
          </div>
          <div>
            <p class="text-2xl font-bold text-primary"><%= @stats[:companies] %></p>
            <p class="text-sm text-secondary">负责企业</p>
          </div>
        </div>
      </div>
      <div class="card card-elevated">
        <div class="card-body flex items-center gap-4">
          <div class="p-3 bg-info/10 rounded-lg">
            <%= lucide_icon "briefcase", class: "w-6 h-6 text-info" %>
          </div>
          <div>
            <p class="text-2xl font-bold text-info"><%= @stats[:pending_cases] %></p>
            <p class="text-sm text-secondary">进行中案件</p>
          </div>
        </div>
      </div>
      <div class="card card-elevated">
        <div class="card-body flex items-center gap-4">
          <div class="p-3 bg-warning/10 rounded-lg">
            <%= lucide_icon "message-square", class: "w-6 h-6 text-warning" %>
          </div>
          <div>
            <p class="text-2xl font-bold text-warning"><%= @stats[:pending_issues] %></p>
            <p class="text-sm text-secondary">待处理事项</p>
          </div>
        </div>
      </div>
      <div class="card card-elevated">
        <div class="card-body flex items-center gap-4">
          <div class="p-3 bg-success/10 rounded-lg">
            <%= lucide_icon "file-text", class: "w-6 h-6 text-success" %>
          </div>
          <div>
            <p class="text-2xl font-bold text-success"><%= @stats[:active_contracts] %></p>
            <p class="text-sm text-secondary">有效合同</p>
          </div>
        </div>
      </div>
    </div>

    <% if @companies.empty? %>
      <!-- 无负责企业时的空状态 -->
      <div class="card card-elevated">
        <div class="card-body py-20 text-center">
          <%= lucide_icon "building-2", class: "w-16 h-16 mx-auto mb-4 text-muted opacity-30" %>
          <h2 class="font-heading text-xl font-semibold text-primary mb-2">暂无负责企业</h2>
          <p class="text-secondary text-sm">你目前尚未被分配任何企业，请联系管理员进行分配。</p>
        </div>
      </div>
    <% else %>

    <!-- 快捷入口 -->
    <div class="mb-8">
      <h2 class="font-heading text-2xl font-bold text-primary mb-4">快捷入口</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Contracts -->
        <%= link_to contracts_path, class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300 border-l-4 border-success">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-success/10 rounded-lg">
                  <%= lucide_icon "file-text", class: "w-8 h-8 text-success" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">合同档案</h3>
                  <p class="text-sm text-secondary">审查合同、管理合同档案</p>
                </div>
                <%= lucide_icon "arrow-right", class: "w-6 h-6 text-muted" %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Cases -->
        <%= link_to cases_path, class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300 border-l-4 border-info">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-info/10 rounded-lg">
                  <%= lucide_icon "briefcase", class: "w-8 h-8 text-info" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">案件管理</h3>
                  <p class="text-sm text-secondary">创建案件、跟踪案件进展</p>
                </div>
                <%= lucide_icon "arrow-right", class: "w-6 h-6 text-muted" %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Major Issues -->
        <%= link_to major_issues_path, class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300 border-l-4 border-warning">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-warning/10 rounded-lg">
                  <%= lucide_icon "message-square", class: "w-8 h-8 text-warning" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">重大事项</h3>
                  <p class="text-sm text-secondary">处理重大事项、协调讨论</p>
                </div>
                <%= lucide_icon "arrow-right", class: "w-6 h-6 text-muted" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 企业列表 -->
    <div class="card card-elevated">
      <div class="card-body">
        <h2 class="font-heading text-xl font-bold text-primary mb-4">负责企业</h2>
        <div class="space-y-3">
          <% @companies.each do |company| %>
            <div class="flex items-center justify-between p-4 bg-surface rounded-lg hover:bg-surface-hover transition-colors">
              <div class="flex items-center gap-3">
                <%= lucide_icon "building", class: "w-5 h-5 text-primary" %>
                <div>
                  <p class="font-semibold text-primary"><%= company.name %></p>
                  <% if company.service_expires_at %>
                    <p class="text-xs text-muted">服务到期：<%= company.service_expires_at.strftime('%Y-%m-%d') %></p>
                  <% end %>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <%= link_to enter_lawyer_company_path(company), method: :post, class: "btn-primary btn-sm" do %>
                  <%= lucide_icon "log-in", class: "w-4 h-4" %>
                  <span>进入</span>
                <% end %>
                <%= link_to edit_lawyer_company_path(company), class: "btn-outline btn-sm" do %>
                  <%= lucide_icon "settings", class: "w-4 h-4" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <% end %>

  </div>
</div>
