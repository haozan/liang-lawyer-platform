<div class="card card-elevated mb-8 border-l-4 border-primary" data-controller="collapsible">
  <div class="card-body p-4">
    <!-- 标题栏 -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <%= lucide_icon "megaphone", class: "w-6 h-6 text-primary" %>
        <h2 class="font-heading text-xl font-bold text-primary">📢 重要公告</h2>
        <% if @announcement_stats[:total] > 0 %>
          <span class="badge badge-primary text-base"><%= @announcement_stats[:total] %> 条</span>
        <% end %>
        <span class="text-sm text-muted">(<%= @announcement_scope %>)</span>
      </div>
      <div class="flex items-center gap-2">
        <% if @announcement_stats[:total] > 0 %>
          <%= link_to lawyer_announcements_path, class: "btn-outline btn-sm" do %>
            <%= lucide_icon "list", class: "w-4 h-4" %>
            <span>查看全部</span>
          <% end %>
          <button type="button"
                  data-action="click->collapsible#toggle"
                  class="btn-ghost btn-sm">
            <span data-collapsible-target="icon" class="transition-transform duration-200">
              <%= lucide_icon "chevron-up", class: "w-5 h-5" %>
            </span>
          </button>
        <% end %>
      </div>
    </div>

    <% if @announcement_stats[:total] > 0 %>
      <!-- 可折叠内容 -->
      <div data-collapsible-target="content">
        <!-- 紧凑统计面板 -->
        <div class="grid grid-cols-4 gap-3 mb-4 p-3 bg-surface rounded-lg">
          <div class="text-center">
            <p class="text-xs text-secondary mb-1">🔴 紧急</p>
            <p class="text-xl font-bold text-red-600"><%= @announcement_stats[:urgent] %></p>
          </div>
          <div class="text-center">
            <p class="text-xs text-secondary mb-1">🟠 重要</p>
            <p class="text-xl font-bold text-orange-600"><%= @announcement_stats[:important] %></p>
          </div>
          <div class="text-center">
            <p class="text-xs text-secondary mb-1">🔵 普通</p>
            <p class="text-xl font-bold text-blue-600"><%= @announcement_stats[:normal] %></p>
          </div>
          <div class="text-center border-l border-border pl-3">
            <p class="text-xs text-secondary mb-1">开庭相关</p>
            <p class="text-xl font-bold text-red-600"><%= @announcement_stats[:by_group][:hearing_related] || 0 %></p>
          </div>
        </div>

        <!-- 只显示最新3条公告 -->
        <div class="space-y-2">
          <% recent_announcements = @announcements.take(3) %>
          <% if recent_announcements.any? %>
            <% recent_announcements.each do |announcement| %>
              <div class="flex items-start gap-3 p-3 bg-surface rounded-lg hover:bg-surface-hover transition-colors group">
                <!-- 优先级图标 -->
                <div class="flex-shrink-0 mt-1">
                  <%= lucide_icon announcement[:icon], class: "w-5 h-5 #{announcement[:priority] == 'urgent' ? 'text-red-600' : announcement[:priority] == 'important' ? 'text-orange-600' : 'text-blue-600'}" %>
                </div>
                
                <!-- 公告内容 -->
                <div class="flex-1 min-w-0">
                  <%= link_to enter_lawyer_announcements_path(
                        announcement_id: announcement[:id],
                        related_type: announcement[:related]&.class&.name,
                        related_id: announcement[:related]&.id,
                        redirect_to: announcement[:link]
                      ), 
                      method: :post,
                      class: "block" do %>
                    <div class="flex items-start justify-between gap-3 mb-1">
                      <h4 class="text-sm font-medium text-primary group-hover:text-primary-dark">
                        <% if @selected_company_id.blank? && announcement[:related].respond_to?(:company) %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded bg-surface-elevated text-xs font-medium text-secondary mr-2">
                            <%= lucide_icon "building-2", class: "w-3 h-3 mr-1 inline" %>
                            <%= announcement[:related].company.name %>
                          </span>
                        <% end %>
                        <span class="mr-2"><%= announcement[:priority] == 'urgent' ? '🔴' : announcement[:priority] == 'important' ? '🟠' : '🔵' %></span>
                        <%= announcement[:title] %>
                      </h4>
                      <span class="text-xs text-muted whitespace-nowrap">
                        <%= announcement[:published_at].strftime('%m-%d %H:%M') %>
                      </span>
                    </div>
                  <% end %>
                </div>
                
                <!-- 消除按钮 -->
                <div class="flex-shrink-0">
                  <%= button_to dismiss_lawyer_announcements_path(
                        announcement_type: announcement[:announcement_type],
                        related_type: announcement[:related]&.class&.name,
                        related_id: announcement[:related]&.id
                      ),
                      method: :post,
                      class: "btn-ghost btn-sm opacity-0 group-hover:opacity-100 transition-opacity",
                      data: { turbo_confirm: "确定消除此公告？" },
                      title: "消除此公告" do %>
                    <%= lucide_icon "x", class: "w-4 h-4" %>
                  <% end %>
                </div>
              </div>
            <% end %>
            
            <!-- 查看更多提示 -->
            <% if @announcements.count > 3 %>
              <div class="text-center py-2">
                <%= link_to lawyer_announcements_path, class: "text-sm text-primary hover:text-primary-dark font-medium" do %>
                  还有 <%= @announcements.count - 3 %> 条公告
                  <%= lucide_icon "arrow-right", class: "w-4 h-4 inline ml-1" %>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="flex items-center justify-center py-6">
        <%= lucide_icon "check-circle", class: "w-12 h-12 text-green-500 mb-2" %>
        <p class="text-base font-semibold text-primary ml-3">✅ 暂无重要公告</p>
      </div>
    <% end %>
  </div>
</div>
