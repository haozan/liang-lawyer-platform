<div class="min-h-screen bg-surface py-8">
  <div class="container-xl mx-auto px-6">
    
    <!-- Page Header -->
    <div class="flex items-center gap-4 mb-8">
      <%= link_to lawyer_companies_path, class: "btn-outline btn-sm" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4" %>
        <span>返回企业列表</span>
      <% end %>
      
      <div>
        <h1 class="font-heading text-4xl font-bold text-primary mb-2">新建企业</h1>
        <p class="text-secondary">创建新的企业客户</p>
      </div>
    </div>

    <!-- Form Card -->
    <div class="max-w-2xl">
      <div class="card card-elevated">
        <div class="card-body">
          <%= form_with model: @company, url: lawyer_companies_path, class: "space-y-6" do |f| %>
            
            <!-- Company Name Field -->
            <div class="form-group">
              <%= f.label :name, "企业名称", class: "form-label required" %>
              <%= f.text_field :name, 
                  class: "form-input", 
                  placeholder: "请输入企业名称",
                  autofocus: true,
                  required: true %>
              <% if @company.errors[:name].any? %>
                <p class="form-error"><%= @company.errors[:name].first %></p>
              <% end %>
              <p class="form-hint">企业的全称或简称</p>
            </div>
            
            <!-- Lawyer Team Selection Field -->
            <div class="form-group">
              <%= f.label :lawyer_team_id, "归属律师团队", class: "form-label required" %>
              <%= f.select :lawyer_team_id,
                  options_for_select(
                    @lawyer_teams.map { |team| [team.name, team.id] },
                    selected: f.object.lawyer_team_id || current_lawyer.lawyer_team_id
                  ),
                  {},
                  { class: "form-input", required: true } %>
              <% if @company.errors[:lawyer_team_id].any? %>
                <p class="form-error"><%= @company.errors[:lawyer_team_id].first %></p>
              <% end %>
              <p class="form-hint">
                <%= lucide_icon "alert-circle", class: "w-4 h-4 inline" %>
                该企业的所有合同、案件、重大事项将只对选定的团队可见
              </p>
            </div>

            <!-- Form Actions -->
            <div class="flex items-center gap-3 pt-4">
              <%= f.submit "创建企业", class: "btn-primary" %>
              <%= link_to "取消", lawyer_companies_path, class: "btn-outline" %>
            </div>

          <% end %>
        </div>
      </div>
    </div>

  </div>
</div>
