<div class="container-fluid px-4 py-6">
  <!-- 页面标题 -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-foreground">我的团队</h1>
      <p class="text-muted mt-1">查看团队信息和成员列表</p>
    </div>
  </div>

  <!-- 团队基本信息卡片 -->
  <div class="card mb-6">
    <div class="card-header">
      <h2 class="text-lg font-semibold">团队信息</h2>
    </div>
    <div class="card-body">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- 团队名称 -->
        <div>
          <label class="text-sm text-muted mb-1 block">团队名称</label>
          <p class="text-foreground font-medium"><%= @team.name %></p>
        </div>

        <!-- 团队编号 -->
        <div>
          <label class="text-sm text-muted mb-1 block">团队编号</label>
          <p class="text-foreground font-mono"><%= @team.code %></p>
        </div>

        <!-- 隔离策略 -->
        <div>
          <label class="text-sm text-muted mb-1 block">数据隔离策略</label>
          <% if @team.data_isolation_level == 'strict' %>
            <span class="badge badge-warning"><%= lucide_icon "shield-alert", class: "w-4 h-4" %> 严格隔离</span>
          <% else %>
            <span class="badge badge-success"><%= lucide_icon "shield-check", class: "w-4 h-4" %> 灵活隔离</span>
          <% end %>
        </div>

        <!-- 团队状态 -->
        <div>
          <label class="text-sm text-muted mb-1 block">团队状态</label>
          <% if @team.active? %>
            <span class="badge badge-success"><%= lucide_icon "check-circle", class: "w-4 h-4" %> 正常</span>
          <% else %>
            <span class="badge badge-muted"><%= lucide_icon "archive", class: "w-4 h-4" %> 已归档</span>
          <% end %>
        </div>
      </div>

      <!-- 团队负责人 -->
      <% if @team.leader.present? %>
        <div class="mt-6 pt-6 border-t border-border">
          <label class="text-sm text-muted mb-2 block">团队负责人</label>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
              <%= lucide_icon "user", class: "w-5 h-5 text-primary" %>
            </div>
            <div>
              <p class="font-medium text-foreground"><%= @team.leader.name %></p>
              <p class="text-sm text-muted"><%= @team.leader.phone %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 业务统计卡片 -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <!-- 合同数量 -->
    <div class="card">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-muted mb-1">团队合同</p>
            <p class="text-3xl font-bold text-foreground"><%= @contracts_count %></p>
          </div>
          <div class="w-12 h-12 rounded-full bg-blue-500/10 flex items-center justify-center">
            <%= lucide_icon "file-text", class: "w-6 h-6 text-blue-500" %>
          </div>
        </div>
      </div>
    </div>

    <!-- 案件数量 -->
    <div class="card">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-muted mb-1">团队案件</p>
            <p class="text-3xl font-bold text-foreground"><%= @cases_count %></p>
          </div>
          <div class="w-12 h-12 rounded-full bg-purple-500/10 flex items-center justify-center">
            <%= lucide_icon "briefcase", class: "w-6 h-6 text-purple-500" %>
          </div>
        </div>
      </div>
    </div>

    <!-- 重大事项数量 -->
    <div class="card">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-muted mb-1">重大事项</p>
            <p class="text-3xl font-bold text-foreground"><%= @major_issues_count %></p>
          </div>
          <div class="w-12 h-12 rounded-full bg-orange-500/10 flex items-center justify-center">
            <%= lucide_icon "alert-triangle", class: "w-6 h-6 text-orange-500" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 团队成员列表 -->
  <div class="card">
    <div class="card-header">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold">团队成员</h2>
        <div class="flex items-center gap-3">
          <span class="badge badge-primary">共 <%= @team_members.count %> 人</span>
          <% if current_lawyer.team_leader_of?(@team) %>
            <div data-controller="dropdown" class="relative">
              <button type="button" 
                      data-action="click->dropdown#toggle"
                      class="btn-primary btn-sm">
                <%= lucide_icon "user-plus", class: "w-4 h-4" %>
                添加成员
              </button>
              <!-- 添加成员下拉菜单 -->
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-64 rounded-lg shadow-lg bg-surface border border-border z-10">
                <div class="p-2">
                  <%= link_to new_lawyer_team_member_path, class: "w-full text-left px-3 py-2 text-sm hover:bg-surface-hover rounded transition-colors flex items-center gap-2 text-primary font-medium mb-2" do %>
                    <%= lucide_icon "user-plus", class: "w-4 h-4" %>
                    <span>创建新账户</span>
                  <% end %>
                  <% if @available_lawyers.any? %>
                    <div class="border-t border-border pt-2 mt-2">
                      <p class="text-sm text-muted px-3 py-2">选择律师加入团队</p>
                      <div class="max-h-64 overflow-y-auto">
                        <% @available_lawyers.each do |lawyer| %>
                          <%= button_to add_member_lawyer_team_path(lawyer_id: lawyer.id), 
                                        method: :post,
                                        class: "w-full text-left px-3 py-2 text-sm hover:bg-surface-hover rounded transition-colors flex items-center justify-between group" do %>
                            <span class="text-foreground"><%= lawyer.name %></span>
                            <span class="text-xs text-muted group-hover:text-primary"><%= lawyer.phone %></span>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  <% else %>
                    <div class="px-3 py-4 text-center border-t border-border mt-2 pt-4">
                      <div class="mb-2">
                        <%= lucide_icon "users", class: "w-8 h-8 text-muted mx-auto" %>
                      </div>
                      <p class="text-sm text-muted mb-1">暂无可添加的律师</p>
                      <p class="text-xs text-muted">所有律师已分配到团队</p>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <div class="card-body p-0">
      <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr>
              <th>姓名</th>
              <th>联系电话</th>
              <th>角色</th>
              <th>加入时间</th>
              <th>状态</th>
              <% if current_lawyer.team_leader_of?(@team) %>
                <th class="text-right">操作</th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @team_members.each do |member| %>
              <tr>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
                      <%= lucide_icon "user", class: "w-4 h-4 text-primary" %>
                    </div>
                    <div>
                      <p class="font-medium text-foreground">
                        <%= member.name %>
                        <% if member.id == @team.leader_id %>
                          <span class="badge badge-warning ml-2 text-xs"><%= lucide_icon "crown", class: "w-3 h-3" %> 负责人</span>
                        <% end %>
                        <% if member.id == current_lawyer.id %>
                          <span class="badge badge-info ml-2 text-xs">我</span>
                        <% end %>
                      </p>
                    </div>
                  </div>
                </td>
                <td class="text-muted"><%= member.phone %></td>
                <td>
                  <% if member.role.present? %>
                    <span class="badge badge-muted"><%= member.role_display %></span>
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
                <td class="text-muted"><%= member.created_at.strftime('%Y-%m-%d') %></td>
                <td>
                  <span class="badge badge-success"><%= lucide_icon "check-circle", class: "w-3 h-3" %> 在职</span>
                </td>
                <% if current_lawyer.team_leader_of?(@team) %>
                  <td class="text-right">
                    <% if member.id != @team.leader_id %>
                      <%= button_to remove_member_lawyer_team_path(lawyer_id: member.id), 
                                    method: :delete,
                                    data: { confirm: "确定要将#{member.name}移出团队吗？" },
                                    class: "btn-sm text-danger hover:bg-danger/10" do %>
                        <%= lucide_icon "user-minus", class: "w-4 h-4" %>
                      <% end %>
                    <% else %>
                      <span class="text-xs text-muted">-</span>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- 说明卡片 -->
  <div class="alert alert-info mt-6">
    <%= lucide_icon "info", class: "w-5 h-5" %>
    <div>
      <h4 class="font-semibold mb-1">关于团队数据隔离</h4>
      <ul class="text-sm space-y-1 ml-4 list-disc">
        <li><strong>严格隔离：</strong>团队成员只能访问本团队的业务数据，无法跨团队查看</li>
        <li><strong>灵活隔离：</strong>团队成员主要访问本团队数据，但可通过授权临时访问其他团队的业务</li>
        <li><strong>权限层级：</strong>所有者（完全控制）> 协作者（可编辑）> 查看者（只读）</li>
        <li>如需加入其他团队或调整权限，请联系系统管理员</li>
      </ul>
    </div>
  </div>
</div>
