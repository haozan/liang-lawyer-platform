<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <meta name="turbo-cache-control" content="no-cache">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="renderer" content="webkit">
    <meta http-equiv="cleartype" content="on">
    <meta name="HandheldFriendly" content="True">
    <meta name="MobileOptimized" content="320">
    <% if @disable_error_tracking %>
      <meta name="disable-error-tracking" content="true">
    <% end %>
    <title>
    <%- if content_for?(:title) %>
      <%= yield(:title) + ' | ' + Rails.application.config.x.appname %>
    <%- else %>
      <%= Rails.application.config.x.appname %>
    <%- end %>
    </title>
    <%= csrf_meta_tags %>
    <%= action_cable_meta_tag %>
    <%= content_for?(:head) ? yield(:head) : '' %>
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <!-- Load error handler early to catch all errors -->
    <%= javascript_include_tag 'error_handler' if Rails.env.development? %>
    <%= javascript_include_tag 'application', type: "module" %>
    <!-- Generate new favicon at `images/app-favicon.svg` at the first time, remove this line after generated  -->
    <%= favicon_link_tag asset_path("app-favicon.svg") unless Rails.env.test? %>
  </head>
  <body class="flex flex-col min-h-screen text-foreground <%= body_class %>" data-controller="search-shortcut">
    <!-- 版本号（全站统一，始终显示在左上角） -->
    <div class="fixed top-0 left-0 z-[9999] pointer-events-none">
      <span class="inline-block text-[10px] text-muted font-mono bg-white/70 backdrop-blur-sm px-1.5 py-0.5 rounded-br opacity-50 hover:opacity-100 transition-opacity pointer-events-auto select-none">v<%= AppVersion::VERSION %></span>
    </div>
    <main class="flex-1 flex flex-col bg-surface">
      <%= render 'shared/navbar' unless @full_render %>
      <%= render 'shared/flash_messages' unless @full_render %>
      <%= yield %>
    </main>
    
    <!-- Floating Search Button (Mobile + Global) -->
    <% if current_user && request.path != '/search' %>
      <div data-controller="floating-search" class="fixed bottom-6 right-6 z-40 md:hidden">
        <button type="button" 
          data-action="click->floating-search#openSearch"
          data-floating-search-target="button"
          class="w-14 h-14 bg-primary hover:bg-primary-dark text-white rounded-full shadow-2xl flex items-center justify-center transition-all duration-300 hover:scale-110 active:scale-95"
          aria-label="搜索">
          <%= lucide_icon "search", class: "w-6 h-6" %>
        </button>
      </div>
    <% end %>
    <% if Rails.env.development? %>
      <div id="system-monitor-stream"
           data-controller="system-monitor"
           data-system-monitor-signed-name-value="<%= Turbo::StreamsChannel.signed_stream_name("system_monitor") %>"
           data-turbo-permanent>
      </div>
    <% end %>
  </body>
</html>
