<div class="container-main">
  <!-- Page Header -->
  <div class="mb-6">
    <h1 class="font-heading text-3xl font-bold text-primary mb-2">待办事项</h1>
    <p class="text-secondary">查看和管理所有待办任务</p>
  </div>

  <!-- Filter Tabs -->
  <div class="mb-6">
    <div class="flex gap-2 border-b border-border overflow-x-auto">
      <%= link_to todos_path(filter: 'all'), 
          class: "px-4 py-3 font-medium whitespace-nowrap #{@filter == 'all' ? 'text-primary border-b-2 border-primary' : 'text-secondary hover:text-primary'}" do %>
        全部 (<%= @stats[:total_pending] %>)
      <% end %>
      
      <%= link_to todos_path(filter: 'today'), 
          class: "px-4 py-3 font-medium whitespace-nowrap #{@filter == 'today' ? 'text-primary border-b-2 border-primary' : 'text-secondary hover:text-primary'}" do %>
        今日新增 (<%= @stats[:today_new] %>)
      <% end %>
      
      <%= link_to todos_path(filter: 'pending'), 
          class: "px-4 py-3 font-medium whitespace-nowrap #{@filter == 'pending' ? 'text-primary border-b-2 border-primary' : 'text-secondary hover:text-primary'}" do %>
        待处理 (<%= @stats[:total_pending] %>)
      <% end %>
      
      <%= link_to todos_path(filter: 'urgent'), 
          class: "px-4 py-3 font-medium whitespace-nowrap #{@filter == 'urgent' ? 'text-primary border-b-2 border-primary' : 'text-secondary hover:text-primary'}" do %>
        紧急待办 (<%= @stats[:urgent] %>)
      <% end %>
      
      <%= link_to todos_path(filter: 'reviewed'), 
          class: "px-4 py-3 font-medium whitespace-nowrap #{@filter == 'reviewed' ? 'text-primary border-b-2 border-primary' : 'text-secondary hover:text-primary'}" do %>
        本周已处理 (<%= @stats[:this_week_reviewed] %>)
      <% end %>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="card card-elevated">
      <div class="card-body text-center">
        <p class="text-sm text-secondary mb-1">今日新增</p>
        <p class="font-heading text-3xl font-bold text-primary"><%= @stats[:today_new] %></p>
      </div>
    </div>
    
    <div class="card card-elevated">
      <div class="card-body text-center">
        <p class="text-sm text-secondary mb-1">待处理</p>
        <p class="font-heading text-3xl font-bold text-blue-600"><%= @stats[:total_pending] %></p>
      </div>
    </div>
    
    <div class="card card-elevated">
      <div class="card-body text-center">
        <p class="text-sm text-secondary mb-1">本周已处理</p>
        <p class="font-heading text-3xl font-bold text-green-600"><%= @stats[:this_week_reviewed] %></p>
      </div>
    </div>
    
    <div class="card card-elevated">
      <div class="card-body text-center">
        <p class="text-sm text-secondary mb-1">紧急待办</p>
        <p class="font-heading text-3xl font-bold text-red-600"><%= @stats[:urgent] %></p>
      </div>
    </div>
  </div>

  <!-- Content based on filter -->
  <% if @filter == 'reviewed' %>
    <!-- Show Recent Comments for Reviewed Items -->
    <div class="card card-elevated">
      <div class="card-header">
        <h2 class="card-title">
          <%= lucide_icon "check-circle", class: "w-5 h-5 mr-2 text-green-600" %>
          本周已处理事项
        </h2>
      </div>
      <div class="card-body">
        <% if @recent_comments.any? %>
          <div class="space-y-4">
            <% @recent_comments.each do |comment| %>
              <div class="border-l-4 border-green-500 pl-4 py-3 bg-surface-secondary rounded-r-lg">
                <div class="flex items-start justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <span class="font-semibold text-primary"><%= comment.author_name %></span>
                    <span class="badge badge-success badge-sm"><%= comment.author_role == 'lawyer' ? '律师' : '助理' %></span>
                  </div>
                  <span class="text-sm text-secondary"><%= time_ago_in_words(comment.created_at) %>前</span>
                </div>
                
                <div class="mb-2">
                  <% begin %>
                    <% if comment.commentable.present? %>
                      <% commentable_type = comment.commentable_type %>
                      <% commentable = comment.commentable %>
                      
                      <% type_info = case commentable_type
                           when 'Contract'
                             { icon: 'file-text', label: '合同', color: 'green', name: commentable.name }
                           when 'Case'
                             { icon: 'briefcase', label: '案件', color: 'blue', name: commentable.name }
                           when 'MajorIssue'
                             { icon: 'message-square', label: '重大事项', color: 'purple', name: commentable.title }
                           else
                             { icon: 'circle', label: '其他', color: 'gray', name: '未知' }
                           end %>
                      
                      <%= link_to polymorphic_path(commentable), class: "inline-flex items-center gap-1 text-sm text-#{type_info[:color]}-600 hover:underline" do %>
                        <%= lucide_icon type_info[:icon], class: "w-4 h-4" %>
                        <span><%= type_info[:label] %>: <%= type_info[:name] %></span>
                      <% end %>
                    <% end %>
                  <% rescue NameError => e %>
                    <span class="text-sm text-secondary">
                      <%= lucide_icon "circle", class: "w-4 h-4 inline" %>
                      <span>已删除的项目</span>
                    </span>
                  <% end %>
                </div>
                
                <p class="text-secondary text-sm line-clamp-2"><%= comment.content %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <%= lucide_icon "inbox", class: "w-12 h-12 text-secondary mx-auto mb-3" %>
            <p class="text-secondary">本周暂无处理记录</p>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <!-- Show Todo Items -->
    <% if @todo_items.any? %>
      <div class="space-y-3">
        <% @todo_items.each do |item| %>
          <%= link_to item[:link], class: "block" do %>
            <div class="card card-elevated hover:shadow-lg transition-shadow">
              <div class="card-body">
                <div class="flex items-start gap-4">
                  <!-- Icon based on type -->
                  <div class="flex-shrink-0">
                    <% icon_config = case item[:type]
                         when :contract
                           { icon: 'file-text', bg: 'bg-green-100', text: 'text-green-600' }
                         when :case
                           { icon: 'briefcase', bg: 'bg-blue-100', text: 'text-blue-600' }
                         when :major_issue
                           { icon: 'message-square', bg: 'bg-purple-100', text: 'text-purple-600' }
                         else
                           { icon: 'circle', bg: 'bg-gray-100', text: 'text-gray-600' }
                         end %>
                    
                    <div class="w-12 h-12 <%= icon_config[:bg] %> rounded-lg flex items-center justify-center">
                      <%= lucide_icon icon_config[:icon], class: "w-6 h-6 #{icon_config[:text]}" %>
                    </div>
                  </div>
                  
                  <!-- Content -->
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between mb-2">
                      <div class="flex-1">
                        <p class="font-semibold text-primary mb-1"><%= item[:message] %></p>
                        
                        <div class="flex items-center gap-3 text-sm text-secondary">
                          <% if lawyer? && item[:company].present? %>
                            <span><%= lucide_icon "building", class: "w-4 h-4 inline mr-1" %><%= item[:company].name %></span>
                          <% end %>
                          
                          <% if item[:created_ago].present? %>
                            <span><%= lucide_icon "clock", class: "w-4 h-4 inline mr-1" %><%= item[:created_ago] %></span>
                          <% end %>
                        </div>
                      </div>
                      
                      <!-- Priority Badge -->
                      <% if item[:priority] == 0 %>
                        <span class="badge badge-danger badge-sm flex-shrink-0 ml-2">紧急</span>
                      <% end %>
                    </div>
                    
                    <!-- Type Badge -->
                    <% type_badge = case item[:type]
                         when :contract
                           { text: '合同', class: 'badge-success' }
                         when :case
                           { text: '案件', class: 'badge-info' }
                         when :major_issue
                           { text: '重大事项', class: 'badge-warning' }
                         else
                           { text: '其他', class: 'badge-secondary' }
                         end %>
                    <span class="badge <%= type_badge[:class] %> badge-sm"><%= type_badge[:text] %></span>
                  </div>
                  
                  <!-- Arrow Icon -->
                  <div class="flex-shrink-0">
                    <%= lucide_icon "chevron-right", class: "w-5 h-5 text-secondary" %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="card card-elevated text-center py-12">
        <%= lucide_icon "inbox", class: "w-16 h-16 text-secondary mx-auto mb-4" %>
        <p class="text-secondary text-lg">
          <% case @filter
             when 'today' %>
            今天暂无新增待办事项
          <% when 'urgent' %>
            暂无紧急待办事项
          <% else %>
            暂无待办事项
          <% end %>
        </p>
        <p class="text-secondary text-sm mt-2">继续保持！</p>
      </div>
    <% end %>
  <% end %>
</div>
