<div class="card card-elevated mb-8 border-l-4 border-primary">
  <div class="card-body p-4">
    <!-- 标题栏：包含统计数据和操作按钮 -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <%= lucide_icon "megaphone", class: "w-6 h-6 text-primary" %>
        <h2 class="font-heading text-xl font-bold text-primary">📢 重要公告</h2>
        <span class="badge badge-primary text-base"><%= @announcement_stats[:total] %> 条</span>
      </div>
      <div class="flex items-center gap-2">
        <% if @announcement_stats[:total] > 0 %>
          <%= link_to announcements_path, class: "btn-outline btn-sm" do %>
            <%= lucide_icon "list", class: "w-4 h-4" %>
            <span>查看全部</span>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- 统计面板 -->
    <% if @announcement_stats[:total] > 0 %>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-6 p-4 bg-surface rounded-lg">
        <div class="text-center">
          <p class="text-xs text-secondary mb-1">总计</p>
          <p class="text-2xl font-bold text-primary"><%= @announcement_stats[:total] %></p>
        </div>
        <div class="text-center">
          <p class="text-xs text-secondary mb-1">🔴 紧急</p>
          <p class="text-2xl font-bold text-danger"><%= @announcement_stats[:urgent] %></p>
        </div>
        <div class="text-center">
          <p class="text-xs text-secondary mb-1">🟠 重要</p>
          <p class="text-2xl font-bold text-warning"><%= @announcement_stats[:important] %></p>
        </div>
        <div class="text-center">
          <p class="text-xs text-secondary mb-1">🔵 普通</p>
          <p class="text-2xl font-bold text-info"><%= @announcement_stats[:normal] %></p>
        </div>
        <div class="text-center border-l border-border pl-3">
          <p class="text-xs text-secondary mb-1">开庭相关</p>
          <p class="text-2xl font-bold text-danger"><%= @announcement_stats[:by_group][:hearing_related] || 0 %></p>
        </div>
      </div>
    <% end %>

    <!-- 分组公告列表 -->
    <% if @grouped_announcements.any? %>
      <div class="space-y-4">
        <% @grouped_announcements.each do |group_data| %>
          <% group = group_data[:group] %>
          <% announcements = group_data[:announcements] %>
          
          <div data-controller="announcement-group-toggle" 
               data-announcement-group-toggle-group-key-value="<%= group.group_key %>"
               class="border border-border rounded-lg overflow-hidden">
            
            <!-- 分组标题栏 -->
            <div class="flex items-center justify-between p-3 bg-<%= group.color_class %>-50 border-b border-<%= group.color_class %>-200">
              <div class="flex items-center gap-3">
                <%= lucide_icon group.icon, class: "w-5 h-5 #{group.text_color_class}" %>
                <h3 class="font-semibold <%= group.text_color_class %>"><%= group.group_name %></h3>
                <span class="badge badge-sm bg-<%= group.color_class %>-100 <%= group.text_color_class %>">
                  <%= announcements.count %> 条
                </span>
              </div>
              <button type="button"
                      data-action="click->announcement-group-toggle#toggle"
                      class="btn-ghost btn-sm">
                <span data-announcement-group-toggle-target="icon" class="transition-transform duration-200">
                  <%= lucide_icon "chevron-down", class: "w-5 h-5" %>
                </span>
              </button>
            </div>
            
            <!-- 分组内容 -->
            <div data-announcement-group-toggle-target="content" class="bg-background">
              <div class="divide-y divide-border">
                <% announcements.each do |announcement| %>
                  <div class="flex items-start gap-3 p-4 hover:bg-surface transition-colors group">
                    <!-- 优先级图标 -->
                    <div class="flex-shrink-0 mt-1">
                      <%= lucide_icon announcement[:icon], class: "w-5 h-5 #{announcement[:priority] == 'urgent' ? 'text-danger' : announcement[:priority] == 'important' ? 'text-warning' : 'text-info'}" %>
                    </div>
                    
                    <!-- 公告内容 -->
                    <div class="flex-1 min-w-0">
                      <%= link_to enter_announcements_path(
                            announcement_id: announcement[:id],
                            related_type: announcement[:related]&.class&.name,
                            related_id: announcement[:related]&.id,
                            redirect_to: announcement[:link]
                          ), 
                          method: :post,
                          class: "block" do %>
                        <div class="flex items-start justify-between gap-3 mb-1">
                          <h4 class="text-base font-medium text-primary group-hover:text-primary-dark">
                            <span class="mr-2"><%= announcement[:priority] == 'urgent' ? '🔴' : announcement[:priority] == 'important' ? '🟠' : '🔵' %></span>
                            <%= announcement[:title] %>
                          </h4>
                          <span class="text-xs text-muted whitespace-nowrap">
                            <%= announcement[:published_at].strftime('%m-%d %H:%M') %>
                          </span>
                        </div>
                        <% if announcement[:content].present? %>
                          <p class="text-sm text-secondary line-clamp-2"><%= announcement[:content] %></p>
                        <% end %>
                      <% end %>
                    </div>
                    
                    <!-- 消除按钮 -->
                    <div class="flex-shrink-0">
                      <%= button_to dismiss_announcements_path(
                            announcement_type: announcement[:announcement_type],
                            related_type: announcement[:related]&.class&.name,
                            related_id: announcement[:related]&.id
                          ),
                          method: :post,
                          class: "btn-ghost btn-sm opacity-0 group-hover:opacity-100 transition-opacity",
                          data: { turbo_confirm: "确定消除此公告？" },
                          title: "消除此公告" do %>
                        <%= lucide_icon "x", class: "w-4 h-4" %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center py-12">
        <%= lucide_icon "check-circle", class: "w-16 h-16 text-success mb-3" %>
        <p class="text-lg font-semibold text-primary mb-1">✅ 暂无重要公告</p>
        <p class="text-sm text-secondary">当前没有需要关注的事项，一切正常</p>
      </div>
    <% end %>
  </div>
</div>
