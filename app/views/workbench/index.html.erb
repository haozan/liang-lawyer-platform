<div class="min-h-screen bg-surface py-8">
  <div class="container-xl mx-auto px-6">
    
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="font-heading text-4xl font-bold text-primary mb-2">首页</h1>
        <p class="text-secondary"><%= @company.name %> · 今日工作概览</p>
      </div>
    </div>

    <!-- 公告区域 - 可折叠版本 -->
    <%= render 'compact_announcements' %>

    <!-- 今日重点待办 -->
    <% urgent_and_today = (@urgent_items + @pending_contracts.select { |item| item[:record].created_at >= Time.current.beginning_of_day }).take(5) %>
    <% if urgent_and_today.any? %>
      <div class="card card-elevated mb-8 border-l-4 border-danger">
        <div class="card-body">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <%= lucide_icon "alert-circle", class: "w-6 h-6 text-danger" %>
              <h2 class="font-heading text-xl font-bold text-primary">🔥 今日重点</h2>
              <span class="badge badge-error"><%= urgent_and_today.count %> 项</span>
            </div>
            <%= link_to todos_path, class: "btn-outline btn-sm" do %>
              <%= lucide_icon "list", class: "w-4 h-4" %>
              <span>查看全部待办</span>
            <% end %>
          </div>
          
          <div class="space-y-3">
            <% urgent_and_today.each do |item| %>
              <div class="flex items-center bg-surface rounded-lg hover:bg-surface-hover transition-colors overflow-hidden">
                <!-- 左侧可点击区域 -->
                <%= link_to item[:link], class: "flex items-start gap-3 p-3 flex-1 min-w-0" do %>
                  <%= lucide_icon(
                    case item[:type]
                    when :contract then "file-text"
                    when :case then "briefcase"
                    when :major_issue then "message-square"
                    else "alert-circle"
                    end,
                    class: "w-5 h-5 text-#{item[:priority] == 0 ? 'red' : 'orange'}-600 flex-shrink-0 mt-0.5"
                  ) %>
                  <div class="min-w-0">
                    <p class="font-medium text-primary hover:text-primary-dark mb-1"><%= item[:message] %></p>
                    <% if item[:created_ago] %>
                      <p class="text-sm text-muted"><%= item[:created_ago] %>创建</p>
                    <% end %>
                  </div>
                <% end %>

                <!-- 完成按钮（律师 + 重大事项） -->
                <% if lawyer? && item[:type] == :major_issue %>
                  <div class="flex-shrink-0 pr-3">
                    <%= button_to mark_as_reviewed_major_issue_path(item[:record]),
                          method: :post,
                          data: { turbo_confirm: "标记《#{item[:record].title}》为已处理？" },
                          class: "btn-sm btn-success inline-flex items-center gap-1 whitespace-nowrap" do %>
                      <%= lucide_icon "check", class: "w-3.5 h-3.5" %>
                      <span>完成</span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="card card-elevated mb-8">
        <div class="card-body py-8">
          <div class="flex flex-col items-center justify-center">
            <%= lucide_icon "check-circle", class: "w-16 h-16 text-success mb-3" %>
            <p class="text-lg font-semibold text-primary mb-1">✅ 今日暂无紧急事项</p>
            <p class="text-sm text-secondary">一切正常，继续保持！</p>
          </div>
        </div>
      </div>
    <% end %>

    <!-- 快捷入口 -->
    <div class="mb-8">
      <h2 class="font-heading text-2xl font-bold text-primary mb-4">快捷入口</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Contracts -->
        <%= link_to contracts_path, class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300 border-l-4 border-success">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-success/10 rounded-lg">
                  <%= lucide_icon "file-text", class: "w-8 h-8 text-success" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">合同档案</h3>
                  <p class="text-sm text-secondary">查看合同、管理合同档案</p>
                </div>
                <%= lucide_icon "arrow-right", class: "w-6 h-6 text-muted" %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Cases -->
        <%= link_to cases_path, class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300 border-l-4 border-info">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-info/10 rounded-lg">
                  <%= lucide_icon "briefcase", class: "w-8 h-8 text-info" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">案件管理</h3>
                  <p class="text-sm text-secondary">查看案件、跟踪案件进展</p>
                </div>
                <%= lucide_icon "arrow-right", class: "w-6 h-6 text-muted" %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Major Issues -->
        <%= link_to major_issues_path, class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300 border-l-4 border-warning">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-warning/10 rounded-lg">
                  <%= lucide_icon "message-square", class: "w-8 h-8 text-warning" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">重大事项</h3>
                  <p class="text-sm text-secondary">参与重大事项、协调讨论</p>
                </div>
                <%= lucide_icon "arrow-right", class: "w-6 h-6 text-muted" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>


    <!-- 届满提醒详情（可折叠） -->
    <% if @expiry_total_count > 0 %>
      <div class="mb-8" data-controller="workbench-expiry">
        <div class="card card-elevated border-l-4 border-danger">
          <div class="card-body">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <%= lucide_icon "bell", class: "w-6 h-6 text-danger" %>
                <h2 class="font-heading text-xl font-bold text-primary">⏰ 届满提醒</h2>
                <span class="badge badge-error"><%= @expiry_total_count %> 项</span>
              </div>
              <button data-action="click->workbench-expiry#toggle" 
                      data-workbench-expiry-target="toggleButton"
                      class="btn-outline btn-sm">
                <span data-workbench-expiry-target="toggleText">展开</span>
                <%= lucide_icon "chevron-down", class: "w-4 h-4", data: { workbench_expiry_target: "toggleIcon" } %>
              </button>
            </div>

            <!-- 可折叠内容 -->
            <div class="hidden space-y-4" data-workbench-expiry-target="content">
              <!-- 即将到期合同 -->
              <% if @expiring_contracts.any? %>
                <div>
                  <h3 class="text-sm font-semibold text-secondary mb-2 flex items-center gap-2">
                    <%= lucide_icon "file-text", class: "w-4 h-4" %>
                    <span>即将到期合同 (<%= @expiring_contracts.count %>)</span>
                  </h3>
                  <div class="space-y-2">
                    <% @expiring_contracts.each do |item| %>
                      <div class="flex items-center justify-between p-3 bg-surface rounded-lg hover:bg-surface-hover transition-colors">
                        <div class="flex-1 min-w-0">
                          <%= link_to item[:link], class: "block" do %>
                            <p class="font-medium text-primary hover:text-primary-dark truncate"><%= item[:record].name %></p>
                            <p class="text-sm text-muted">到期日期：<%= item[:due_date].strftime('%Y年%m月%d日') %></p>
                          <% end %>
                        </div>
                        <span class="badge badge-warning flex-shrink-0"><%= item[:days_left] %>天后到期</span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- 即将开庭案件 -->
              <% if @upcoming_hearings.any? %>
                <div>
                  <h3 class="text-sm font-semibold text-secondary mb-2 flex items-center gap-2">
                    <%= lucide_icon "calendar", class: "w-4 h-4" %>
                    <span>即将开庭案件 (<%= @upcoming_hearings.count %>)</span>
                  </h3>
                  <div class="space-y-2">
                    <% @upcoming_hearings.each do |item| %>
                      <div class="flex items-center justify-between p-3 bg-surface rounded-lg hover:bg-surface-hover transition-colors">
                        <div class="flex-1 min-w-0">
                          <%= link_to item[:link], class: "block" do %>
                            <p class="font-medium text-primary hover:text-primary-dark truncate"><%= item[:record].name %></p>
                            <p class="text-sm text-muted">开庭日期：<%= item[:due_date].strftime('%Y年%m月%d日') %><% if item[:due_time].present? %>  <%= item[:due_time] %><% end %></p>
                          <% end %>
                        </div>
                        <span class="badge badge-info flex-shrink-0"><%= item[:days_left] %>天后开庭</span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- 待收集判决书 -->
              <% if @pending_judgement_collections.any? %>
                <div>
                  <h3 class="text-sm font-semibold text-secondary mb-2 flex items-center gap-2">
                    <%= lucide_icon "file-check", class: "w-4 h-4" %>
                    <span>待收集判决书 (<%= @pending_judgement_collections.count %>)</span>
                  </h3>
                  <div class="space-y-2">
                    <% @pending_judgement_collections.each do |item| %>
                      <div class="flex items-center justify-between p-3 bg-surface rounded-lg hover:bg-surface-hover transition-colors">
                        <div class="flex-1 min-w-0">
                          <%= link_to item[:link], class: "block" do %>
                            <p class="font-medium text-primary hover:text-primary-dark truncate"><%= item[:record].name %></p>
                            <p class="text-sm text-muted">判决书待领取</p>
                          <% end %>
                        </div>
                        <span class="badge badge-warning flex-shrink-0">待收集</span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- 待归档案件 -->
              <% if @pending_archives.any? %>
                <div>
                  <h3 class="text-sm font-semibold text-secondary mb-2 flex items-center gap-2">
                    <%= lucide_icon "archive", class: "w-4 h-4" %>
                    <span>待归档案件 (<%= @pending_archives.count %>)</span>
                  </h3>
                  <div class="space-y-2">
                    <% @pending_archives.each do |item| %>
                      <div class="flex items-center justify-between p-3 bg-surface rounded-lg hover:bg-surface-hover transition-colors">
                        <div class="flex-1 min-w-0">
                          <%= link_to item[:link], class: "block" do %>
                            <p class="font-medium text-primary hover:text-primary-dark truncate"><%= item[:record].name %></p>
                            <p class="text-sm text-muted">已领取判决书 <%= item[:pending_days] %> 天，待归档</p>
                          <% end %>
                        </div>
                        <span class="badge badge-neutral flex-shrink-0">待归档</span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- 分析看板 -->
    <div class="mb-8">
      <h2 class="font-heading text-2xl font-bold text-primary mb-4">数据分析</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- 合同分析 -->
        <%= link_to dashboard_contract_analytics_path, class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-success/10 rounded-lg">
                  <%= lucide_icon "pie-chart", class: "w-8 h-8 text-success" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">合同分析看板</h3>
                  <p class="text-sm text-secondary">查看合同统计数据与趋势</p>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <!-- 案件分析 -->
        <%= link_to dashboard_case_analytics_path, class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-info/10 rounded-lg">
                  <%= lucide_icon "bar-chart-3", class: "w-8 h-8 text-info" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">案件分析看板</h3>
                  <p class="text-sm text-secondary">查看案件统计数据与分析</p>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <!-- 重大事项分析 -->
        <%= link_to dashboard_major_issue_analytics_path, class: "block" do %>
          <div class="card card-elevated hover:shadow-xl transition-all duration-300">
            <div class="card-body">
              <div class="flex items-center gap-4">
                <div class="p-4 bg-warning/10 rounded-lg">
                  <%= lucide_icon "trending-up", class: "w-8 h-8 text-warning" %>
                </div>
                <div class="flex-1">
                  <h3 class="font-heading text-lg font-semibold text-primary mb-1">重大事项分析</h3>
                  <p class="text-sm text-secondary">查看重大事项数据分析</p>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>
