<% content_for :title, "创建律师团队" %>

<div class="container-md">
  <div class="flex items-center space-x-4">
    <%= link_to admin_lawyer_teams_path, class: "btn-ghost text-sm py-1 px-3" do %>
      <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
      返回团队列表
    <% end %>
  </div>

  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50 mt-4 mb-8">创建律师团队</h1>

  <!-- Form -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <%= form_with model: [:admin, @lawyer_team], local: true, class: "space-y-6" do |form| %>
        <!-- Name -->
        <div class="form-group">
          <%= form.label :name, "团队名称" %>
          <%= form.text_field :name, placeholder: "例如：诉讼一部、企业法务组...", class: "form-input" %>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">团队的正式名称，用于显示和识别</p>
        </div>

        <!-- Code -->
        <div class="form-group">
          <%= form.label :code, "团队代码" %>
          <%= form.text_field :code, placeholder: "例如：LITIGATION_TEAM_1", class: "form-input font-mono" %>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">团队的唯一标识代码，仅支持大写字母和下划线</p>
        </div>

        <!-- Data isolation level -->
        <div class="form-group">
          <%= form.label :data_isolation_level, "数据隔离策略" %>
          <div class="space-y-3 mt-2">
            <div class="flex items-start">
              <%= form.radio_button :data_isolation_level, 'flexible', class: "mt-1 mr-3", checked: true %>
              <div>
                <label for="lawyer_team_data_isolation_level_flexible" class="font-medium text-gray-900 dark:text-gray-100 cursor-pointer">
                  灵活隔离（推荐）
                </label>
                <p class="text-sm text-gray-500 dark:text-gray-400">允许跨团队协作，团队负责人可以授权其他团队访问特定业务</p>
              </div>
            </div>
            <div class="flex items-start">
              <%= form.radio_button :data_isolation_level, 'strict', class: "mt-1 mr-3" %>
              <div>
                <label for="lawyer_team_data_isolation_level_strict" class="font-medium text-gray-900 dark:text-gray-100 cursor-pointer">
                  严格隔离
                </label>
                <p class="text-sm text-gray-500 dark:text-gray-400">团队之间完全隔离，任何情况下都不能访问其他团队的数据</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Status -->
        <div class="form-group">
          <%= form.label :status, "团队状态" %>
          <div class="space-y-3 mt-2">
            <div class="flex items-start">
              <%= form.radio_button :status, 'active', class: "mt-1 mr-3", checked: true %>
              <div>
                <label for="lawyer_team_status_active" class="font-medium text-gray-900 dark:text-gray-100 cursor-pointer">
                  活跃
                </label>
                <p class="text-sm text-gray-500 dark:text-gray-400">团队正常运作，成员可以访问和处理业务</p>
              </div>
            </div>
            <div class="flex items-start">
              <%= form.radio_button :status, 'archived', class: "mt-1 mr-3" %>
              <div>
                <label for="lawyer_team_status_archived" class="font-medium text-gray-900 dark:text-gray-100 cursor-pointer">
                  已归档
                </label>
                <p class="text-sm text-gray-500 dark:text-gray-400">团队已停用，成员无法再访问团队数据</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Leader -->
        <div class="form-group">
          <%= form.label :leader_id, "团队负责人" %>
          <%= form.select :leader_id,
              options_for_select([['请选择负责人', '']] + LawyerAccount.all.map { |item| [item.name, item.id] }, @lawyer_team.leader_id),
              {}, { class: "form-select" } %>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">团队负责人可以管理团队成员和授权业务访问权限</p>
        </div>

        <!-- Form Actions -->
        <div class="flex justify-end space-x-3 pt-6 border-t border-gray-200 dark:border-gray-700">
          <%= link_to admin_lawyer_teams_path, class: "btn-ghost" do %>
            取消
          <% end %>
          <%= form.submit "创建团队", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>