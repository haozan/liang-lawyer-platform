<% content_for :title, @lawyer_team.name %>

<div class="container-lg">
  <div class="mb-6">
    <div class="flex items-center space-x-4">
      <%= link_to admin_lawyer_teams_path, class: "btn-ghost text-sm py-1 px-3" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
        返回团队列表
      <% end %>
    </div>

    <div class="mt-4 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @lawyer_team.name %></h1>
        <p class="text-gray-500 dark:text-gray-400 mt-2">
          <code class="px-2 py-1 bg-gray-200 dark:bg-gray-700 rounded text-sm"><%= @lawyer_team.code %></code>
        </p>
      </div>

      <div class="flex items-center space-x-3">
        <%= link_to edit_admin_lawyer_team_path(@lawyer_team), class: "btn-primary" do %>
          <%= lucide_icon "pencil", class: "w-5 h-5 mr-2" %>
          编辑团队
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Info Card -->
    <div class="lg:col-span-2 space-y-6">
      <!-- 基本信息 -->
      <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
        <div class="card-body">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-50 mb-6">基本信息</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- 团队名称 -->
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">团队名称</label>
              <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @lawyer_team.name %></div>
            </div>

            <!-- 团队代码 -->
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">团队代码</label>
              <div class="text-lg font-mono text-gray-900 dark:text-gray-100"><%= @lawyer_team.code %></div>
            </div>

            <!-- 负责人 -->
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">团队负责人</label>
              <div class="text-lg font-medium text-gray-900 dark:text-gray-100">
                <%= @lawyer_team.leader&.name || '未指定' %>
              </div>
            </div>

            <!-- 成员数量 -->
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">成员数量</label>
              <div class="text-lg font-medium text-gray-900 dark:text-gray-100">
                <span class="badge badge-info"><%= @lawyer_team.lawyer_accounts.count %> 人</span>
              </div>
            </div>

            <!-- 隔离策略 -->
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">数据隔离策略</label>
              <div>
                <% if @lawyer_team.data_isolation_level == 'strict' %>
                  <span class="badge badge-danger">严格隔离</span>
                  <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">团队之间完全隔离，不能访问其他团队的数据</p>
                <% else %>
                  <span class="badge badge-success">灵活隔离</span>
                  <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">允许跨团队协作，可授权访问特定业务</p>
                <% end %>
              </div>
            </div>

            <!-- 状态 -->
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">团队状态</label>
              <div>
                <% if @lawyer_team.status == 'active' %>
                  <span class="badge badge-success">活跃</span>
                  <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">团队正常运作中</p>
                <% else %>
                  <span class="badge badge-secondary">已归档</span>
                  <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">团队已停用</p>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 团队成员列表 -->
      <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
        <div class="card-body">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-50">团队成员</h2>
            <span class="badge badge-info"><%= @lawyer_team.lawyer_accounts.count %> 人</span>
          </div>

          <% if @lawyer_team.lawyer_accounts.any? %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-800">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">姓名</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">邮箱</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">角色</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">加入时间</th>
                  </tr>
                </thead>
                <tbody class="bg-gray-50 dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
                  <% @lawyer_team.lawyer_accounts.each do |member| %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
                      <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">
                        <%= member.name %>
                        <% if member.id == @lawyer_team.leader_id %>
                          <span class="badge badge-warning ml-2">负责人</span>
                        <% end %>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                        <%= member.email %>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                        <% if member.super_admin? %>
                          <span class="badge badge-danger">超级管理员</span>
                        <% else %>
                          <span class="badge badge-secondary">律师</span>
                        <% end %>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                        <%= member.created_at.strftime("%Y-%m-%d") %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-8">
              <div class="w-16 h-16 mx-auto mb-4 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center">
                <%= lucide_icon "users", class: "w-8 h-8 text-gray-400" %>
              </div>
              <p class="text-gray-500 dark:text-gray-400">该团队暂无成员</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Sidebar - Statistics -->
    <div class="lg:col-span-1 space-y-6">
      <!-- 业务数据统计 -->
      <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
        <div class="card-body">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-50 mb-4">业务数据统计</h3>
          <div class="space-y-4">
            <!-- 合同数量 -->
            <div class="flex items-center justify-between p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
              <div>
                <p class="text-sm text-gray-600 dark:text-gray-400">合同数量</p>
                <p class="text-2xl font-bold text-blue-600 dark:text-blue-400">
                  <%= BusinessTeamOwnership.where(lawyer_team_id: @lawyer_team.id, business_type: 'Contract').count %>
                </p>
              </div>
              <%= lucide_icon "file-text", class: "w-8 h-8 text-blue-600 dark:text-blue-400" %>
            </div>

            <!-- 案件数量 -->
            <div class="flex items-center justify-between p-3 bg-green-50 dark:bg-green-900/20 rounded-lg">
              <div>
                <p class="text-sm text-gray-600 dark:text-gray-400">案件数量</p>
                <p class="text-2xl font-bold text-green-600 dark:text-green-400">
                  <%= BusinessTeamOwnership.where(lawyer_team_id: @lawyer_team.id, business_type: 'Case').count %>
                </p>
              </div>
              <%= lucide_icon "briefcase", class: "w-8 h-8 text-green-600 dark:text-green-400" %>
            </div>

            <!-- 重大问题数量 -->
            <div class="flex items-center justify-between p-3 bg-orange-50 dark:bg-orange-900/20 rounded-lg">
              <div>
                <p class="text-sm text-gray-600 dark:text-gray-400">重大问题</p>
                <p class="text-2xl font-bold text-orange-600 dark:text-orange-400">
                  <%= BusinessTeamOwnership.where(lawyer_team_id: @lawyer_team.id, business_type: 'MajorIssue').count %>
                </p>
              </div>
              <%= lucide_icon "alert-triangle", class: "w-8 h-8 text-orange-600 dark:text-orange-400" %>
            </div>
          </div>
        </div>
      </div>

      <!-- 元数据 -->
      <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
        <div class="card-body">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-50 mb-4">元数据</h3>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ID</label>
              <div class="text-sm text-gray-900 dark:text-gray-100 font-mono"><%= @lawyer_team.id %></div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">创建时间</label>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                <%= @lawyer_team.created_at.strftime("%Y年%-m月%-d日 %H:%M") %>
                <div class="text-xs text-gray-400 mt-1"><%= time_ago_in_words(@lawyer_team.created_at) %> 前</div>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">最后更新</label>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                <%= @lawyer_team.updated_at.strftime("%Y年%-m月%-d日 %H:%M") %>
                <div class="text-xs text-gray-400 mt-1"><%= time_ago_in_words(@lawyer_team.updated_at) %> 前</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
