<% content_for :title, "编辑管理员" %>

<div class="container-md">
  <!-- Page Title -->
  <div class="flex items-center space-x-4 mb-6">
    <%= link_to admin_administrators_path, class: "btn-ghost text-sm py-1 px-3" do %>
      <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
      返回管理员列表
    <% end %>
  </div>

  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50 mt-4 mb-8">编辑管理员</h1>

  <!-- Form -->
  <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <%= form_with model: [:admin, @administrator], local: true, class: "space-y-6" do |form| %>
        <!-- Name -->
        <div class="form-group">
          <%= form.label :name %>
          <%= form.text_field :name, placeholder: "请输入管理员姓名..." %>
        </div>

        <!-- Phone -->
        <div class="form-group">
          <%= form.label :phone, "手机号" %>
          <%= form.telephone_field :phone, placeholder: "请输入11位手机号", required: true %>
        </div>

        <!-- Password -->
        <div class="form-group">
          <%= form.label :password, "新密码（留空保持原密码）" %>
          <%= form.password_field :password, placeholder: "请输入新密码..." %>
        </div>

        <!-- Password Confirmation -->
        <div class="form-group">
          <%= form.label :password_confirmation %>
          <%= form.password_field :password_confirmation, placeholder: "确认新密码..." %>
        </div>

        <!-- Role (only for super admins) -->
        <% if current_admin.can_manage_administrators? %>
          <div class="form-group">
            <%= form.label :role %>
            <%= form.select :role, Administrator.role_options, { selected: @administrator.role } %>
          </div>
        <% end %>

        <!-- Metadata -->
        <div class="border-t border-gray-200 dark:border-gray-600 pt-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">创建时间</label>
              <p class="text-sm text-gray-900 dark:text-gray-100"><%= @administrator.created_at.strftime("%Y年%-m月%-d日 %H:%M") %></p>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">最后更新</label>
              <p class="text-sm text-gray-900 dark:text-gray-100"><%= @administrator.updated_at.strftime("%Y年%-m月%-d日 %H:%M") %></p>
            </div>
          </div>
        </div>

        <!-- Form Actions -->
        <div class="flex justify-end space-x-3">
          <%= link_to admin_administrators_path, class: "btn-ghost" do %>
            取消
          <% end %>
          <%= form.submit "更新管理员", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>