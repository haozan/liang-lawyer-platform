<% content_for :title, @company_user.name %>

<div class="container-xl max-w-2xl">
  <div class="flex items-center gap-4 mb-8">
    <%= link_to admin_company_users_path, class: "p-2 text-muted hover:text-gray-900 hover:bg-surface-elevated rounded-lg transition-colors" do %>
      <%= lucide_icon "arrow-left", class: "w-5 h-5" %>
    <% end %>
    <div class="flex-1">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @company_user.name %></h1>
      <p class="text-muted font-mono mt-1"><%= @company_user.phone %></p>
    </div>
    <%= link_to edit_admin_company_user_path(@company_user), class: "btn-outline btn-sm" do %>
      <%= lucide_icon "pencil", class: "w-4 h-4 mr-1" %>编辑
    <% end %>
  </div>

  <!-- 所属企业 -->
  <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-50 mb-4">
        所属企业 <span class="text-muted font-normal">（<%= @memberships.count %> 个）</span>
      </h2>

      <% if @memberships.any? %>
        <div class="space-y-3">
          <% @memberships.each do |membership| %>
            <div class="flex items-center justify-between p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
              <div class="flex items-center gap-3">
                <%= lucide_icon "building-2", class: "w-5 h-5 text-muted" %>
                <div>
                  <%= link_to membership.company.name, admin_company_path(membership.company),
                      class: "font-medium text-gray-900 dark:text-gray-100 hover:text-info hover:underline" %>
                  <p class="text-xs text-muted">加入于 <%= membership.created_at.strftime('%Y-%m-%d') %></p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= membership.boss? ? 'bg-secondary/10 text-purple-800' : 'bg-surface-elevated text-gray-700' %>">
                  <%= membership.role_display %>
                </span>
                <%= button_to admin_company_company_membership_path(membership.company, membership),
                    method: :delete,
                    data: { turbo_confirm: "确定将此用户从「#{membership.company.name}」移除？" },
                    class: "p-1.5 text-red-400 hover:text-danger hover:bg-danger/10 rounded transition-colors" do %>
                  <%= lucide_icon "x", class: "w-4 h-4" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted text-sm text-center py-4">该用户尚未关联任何企业</p>
      <% end %>
    </div>
  </div>
</div>
