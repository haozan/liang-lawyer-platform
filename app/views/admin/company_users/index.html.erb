<% content_for :title, "用户管理" %>

<div class="container-xl">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50">用户管理</h1>
    <%= link_to new_admin_company_user_path, class: "btn-primary" do %>
      <%= lucide_icon "plus", class: "w-5 h-5 mr-2" %>
      新建用户
    <% end %>
  </div>

  <%= form_with url: admin_company_users_path, method: :get, class: "mb-6 flex gap-3" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "搜索姓名或手机号…", class: "form-input w-72" %>
    <%= f.submit "搜索", class: "btn-outline" %>
    <% if params[:q].present? %>
      <%= link_to "清除", admin_company_users_path, class: "btn-outline" %>
    <% end %>
  <% end %>

  <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body p-0">
      <% if @company_users.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-surface-elevated dark:bg-gray-800">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted uppercase">姓名</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted uppercase">手机号</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted uppercase">所属企业</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted uppercase">状态</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-muted uppercase">操作</th>
              </tr>
            </thead>
            <tbody class="bg-surface-elevated dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
              <% @company_users.each do |user| %>
                <tr class="hover:bg-surface-elevated dark:hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 font-semibold text-gray-900 dark:text-gray-100">
                    <%= link_to user.name, admin_company_user_path(user), class: "hover:text-info hover:underline" %>
                  </td>
                  <td class="px-6 py-4 text-sm font-mono text-gray-700 dark:text-gray-300"><%= user.phone %></td>
                  <td class="px-6 py-4 text-sm text-secondary dark:text-muted">
                    <% companies = user.companies %>
                    <% if companies.any? %>
                      <%= companies.map(&:name).join('、') %>
                    <% else %>
                      <span class="text-muted">未关联企业</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4">
                    <% if user.locked_at.present? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-danger/10 text-danger">已锁定</span>
                    <% else %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-success/10 text-green-800">正常</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-center">
                    <div class="flex justify-center gap-2">
                      <%= link_to edit_admin_company_user_path(user), class: "p-2 text-muted hover:text-gray-900 hover:bg-surface-elevated rounded transition-colors" do %>
                        <%= lucide_icon "pencil", class: "w-4 h-4" %>
                      <% end %>
                      <%= button_to admin_company_user_path(user), method: :delete,
                          data: { turbo_confirm: "确定删除用户「#{user.name}」？" },
                          class: "p-2 text-danger hover:text-danger hover:bg-danger/10 rounded transition-colors" do %>
                        <%= lucide_icon "trash-2", class: "w-4 h-4" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12">
          <%= lucide_icon "users", class: "w-12 h-12 text-muted mx-auto mb-4" %>
          <h3 class="text-lg font-medium text-gray-900 dark:text-gray-50 mb-2">暂无企业用户</h3>
        </div>
      <% end %>
    </div>
  </div>

  <% if @company_users.respond_to?(:current_page) %>
    <div class="mt-6"><%= paginate @company_users %></div>
  <% end %>
</div>
