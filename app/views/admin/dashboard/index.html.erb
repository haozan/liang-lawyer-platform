<% content_for :title, "仪表盘" %>

<div class="container-xl">
  <!-- Page Title -->
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50">Admin Dashboard</h1>
    <p class="text-secondary dark:text-muted mt-2">系统概览</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    <!-- Companies -->
    <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
      <div class="card-body flex items-center p-6">
        <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center mr-4">
          <%= lucide_icon "building-2", class: "w-6 h-6 text-blue-600 dark:text-blue-400" %>
        </div>
        <div>
          <div class="text-sm font-medium text-muted dark:text-muted">企业数量</div>
          <div class="text-2xl font-bold text-gray-900 dark:text-gray-50"><%= @stats[:companies] %></div>
        </div>
      </div>
    </div>

    <!-- Lawyer Accounts -->
    <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
      <div class="card-body flex items-center p-6">
        <div class="w-12 h-12 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center mr-4">
          <%= lucide_icon "scale", class: "w-6 h-6 text-green-600 dark:text-green-400" %>
        </div>
        <div>
          <div class="text-sm font-medium text-muted dark:text-muted">律师账号</div>
          <div class="text-2xl font-bold text-gray-900 dark:text-gray-50"><%= @stats[:lawyer_accounts] %></div>
        </div>
      </div>
    </div>

    <!-- Company Users -->
    <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
      <div class="card-body flex items-center p-6">
        <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center mr-4">
          <%= lucide_icon "users", class: "w-6 h-6 text-purple-600 dark:text-purple-400" %>
        </div>
        <div>
          <div class="text-sm font-medium text-muted dark:text-muted">企业用户</div>
          <div class="text-2xl font-bold text-gray-900 dark:text-gray-50"><%= @stats[:company_users] %></div>
        </div>
      </div>
    </div>

    <!-- Cases -->
    <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
      <div class="card-body flex items-center p-6">
        <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900 rounded-lg flex items-center justify-center mr-4">
          <%= lucide_icon "folder-open", class: "w-6 h-6 text-orange-600 dark:text-orange-400" %>
        </div>
        <div>
          <div class="text-sm font-medium text-muted dark:text-muted">案件数量</div>
          <div class="text-2xl font-bold text-gray-900 dark:text-gray-50"><%= @stats[:cases] %></div>
        </div>
      </div>
    </div>

    <!-- Contracts -->
    <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
      <div class="card-body flex items-center p-6">
        <div class="w-12 h-12 bg-red-100 dark:bg-red-900 rounded-lg flex items-center justify-center mr-4">
          <%= lucide_icon "file-text", class: "w-6 h-6 text-red-600 dark:text-red-400" %>
        </div>
        <div>
          <div class="text-sm font-medium text-muted dark:text-muted">合同数量</div>
          <div class="text-2xl font-bold text-gray-900 dark:text-gray-50"><%= @stats[:contracts] %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-header bg-surface-elevated dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-4">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-50">快捷操作</h3>
    </div>
    <div class="card-body p-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <%= link_to new_admin_company_path, class: "flex items-center justify-center p-4 bg-blue-50 dark:bg-blue-900/20 hover:bg-blue-100 dark:hover:bg-blue-900/30 rounded-lg transition-colors" do %>
          <%= lucide_icon "plus", class: "w-5 h-5 text-blue-600 dark:text-blue-400 mr-2" %>
          <span class="text-sm font-medium text-blue-700 dark:text-blue-300">新建企业</span>
        <% end %>

        <%= link_to admin_announcements_path, class: "flex items-center justify-center p-4 bg-green-50 dark:bg-green-900/20 hover:bg-green-100 dark:hover:bg-green-900/30 rounded-lg transition-colors" do %>
          <%= lucide_icon "megaphone", class: "w-5 h-5 text-green-600 dark:text-green-400 mr-2" %>
          <span class="text-sm font-medium text-green-700 dark:text-green-300">管理公告</span>
        <% end %>

        <%= link_to admin_good_job_path, target: '_blank', class: "flex items-center justify-center p-4 bg-orange-50 dark:bg-orange-900/20 hover:bg-orange-100 dark:hover:bg-orange-900/30 rounded-lg transition-colors" do %>
          <%= lucide_icon "clock", class: "w-5 h-5 text-orange-600 dark:text-orange-400 mr-2" %>
          <span class="text-sm font-medium text-orange-700 dark:text-orange-300">定时任务</span>
        <% end %>
      </div>
    </div>
  </div>
</div>
