<% content_for :title, @company.name %>

<div class="container-xl">
  <!-- Header -->
  <div class="flex items-center gap-4 mb-8">
    <%= link_to admin_companies_path, class: "p-2 text-muted hover:text-gray-900 hover:bg-surface-elevated rounded-lg transition-colors" do %>
      <%= lucide_icon "arrow-left", class: "w-5 h-5" %>
    <% end %>
    <div class="flex-1">
      <div class="flex items-center gap-3">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @company.name %></h1>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
          <%= @company.active? ? 'bg-success/10 text-green-800' : 'bg-surface-elevated text-secondary' %>">
          <%= @company.status_text %>
        </span>
      </div>
      <p class="text-muted mt-1">
        创建于 <%= @company.created_at.strftime('%Y年%m月%d日') %>
        <% if @company.service_expires_at %>
          · 服务到期 <%= @company.service_expires_at.strftime('%Y年%m月%d日') %>
        <% else %>
          · 永久服务
        <% end %>
        <% lawyers = @company.assigned_lawyers %>
        <% if lawyers.any? %>
          · 负责律师：<% lawyers.each_with_index do |l, i| %><%= i > 0 ? '、' : '' %><%= link_to l.name, edit_admin_lawyer_account_path(l), class: "text-info hover:underline font-medium" %><% end %>
        <% end %>
      </p>
    </div>
    <div class="flex gap-2">
      <%= link_to edit_admin_company_path(@company), class: "btn-outline btn-sm" do %>
        <%= lucide_icon "pencil", class: "w-4 h-4 mr-1" %>编辑
      <% end %>
      <% if @company.active? %>
        <%= button_to suspend_admin_company_path(@company), method: :post,
            data: { turbo_confirm: '确定暂停该企业服务？' },
            class: "btn-outline btn-sm text-warning border-orange-300 hover:bg-warning/10" do %>
          <%= lucide_icon "pause-circle", class: "w-4 h-4 mr-1" %>暂停
        <% end %>
      <% elsif @company.suspended? %>
        <%= button_to resume_admin_company_path(@company), method: :post, class: "btn-primary btn-sm" do %>
          <%= lucide_icon "play-circle", class: "w-4 h-4 mr-1" %>恢复
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- 企业成员 -->
  <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700 mb-6">
    <div class="card-body">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-50">
          企业成员 <span class="text-muted font-normal text-base">（<%= @memberships.count %> 人）</span>
        </h2>
        <%= link_to new_admin_company_company_membership_path(@company), class: "btn-primary btn-sm" do %>
          <%= lucide_icon "user-plus", class: "w-4 h-4 mr-1" %>添加成员
        <% end %>
      </div>

      <% if @memberships.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead>
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-muted uppercase">姓名</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-muted uppercase">手机号</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-muted uppercase">角色</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-muted uppercase">加入时间</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-muted uppercase">操作</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              <% @memberships.each do |membership| %>
                <tr class="hover:bg-surface-elevated dark:hover:bg-gray-800 transition-colors">
                  <td class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100">
                    <%= link_to membership.company_user.name, admin_company_user_path(membership.company_user),
                        class: "hover:text-info hover:underline" %>
                  </td>
                  <td class="px-4 py-3 text-sm text-secondary dark:text-muted font-mono">
                    <%= membership.company_user.phone %>
                  </td>
                  <td class="px-4 py-3">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                      <%= membership.boss? ? 'bg-secondary/10 text-purple-800' : 'bg-surface-elevated text-gray-700' %>">
                      <%= membership.role_display %>
                    </span>
                  </td>
                  <td class="px-4 py-3 text-sm text-muted">
                    <%= membership.created_at.strftime('%Y-%m-%d') %>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <%= button_to admin_company_company_membership_path(@company, membership),
                        method: :delete,
                        data: { turbo_confirm: "确定将「#{membership.company_user.name}」从此企业移除？" },
                        class: "p-2 text-danger hover:text-danger hover:bg-danger/10 rounded transition-colors" do %>
                      <%= lucide_icon "user-minus", class: "w-4 h-4" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-8 text-muted">
          <p>暂无成员</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 数据概览 -->
  <div class="grid grid-cols-3 gap-4">
    <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
      <div class="card-body text-center">
        <p class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @company.cases.not_deleted.count %></p>
        <p class="text-sm text-muted mt-1">案件</p>
      </div>
    </div>
    <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
      <div class="card-body text-center">
        <p class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @company.contracts.count %></p>
        <p class="text-sm text-muted mt-1">合同</p>
      </div>
    </div>
    <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
      <div class="card-body text-center">
        <p class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @company.major_issues.not_deleted.count %></p>
        <p class="text-sm text-muted mt-1">重大事项</p>
      </div>
    </div>
  </div>
</div>
