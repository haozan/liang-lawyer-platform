<% content_for :title, "企业管理" %>

<div class="container-xl">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50">企业管理</h1>
    <%= link_to new_admin_company_path, class: "btn-primary" do %>
      <%= lucide_icon "plus", class: "w-5 h-5 mr-2" %>
      新建企业
    <% end %>
  </div>

  <!-- 搜索 -->
  <%= form_with url: admin_companies_path, method: :get, class: "mb-6 flex gap-3" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "搜索企业名称…",
        class: "form-input w-72" %>
    <%= f.submit "搜索", class: "btn-outline" %>
    <% if params[:q].present? %>
      <%= link_to "清除", admin_companies_path, class: "btn-outline" %>
    <% end %>
  <% end %>

  <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body p-0">
      <% if @companies.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-surface-elevated dark:bg-gray-800">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted uppercase tracking-wider">企业名称</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted uppercase tracking-wider">成员数</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted uppercase tracking-wider">状态</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted uppercase tracking-wider">服务到期</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted uppercase tracking-wider">创建时间</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-muted uppercase tracking-wider">操作</th>
              </tr>
            </thead>
            <tbody class="bg-surface-elevated dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
              <% @companies.each do |company| %>
                <tr class="hover:bg-surface-elevated dark:hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <%= link_to company.name, admin_company_path(company),
                        class: "font-semibold text-info hover:underline" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">
                    <%= company.company_memberships.count %> 人
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                      <%= company.active? ? 'bg-success/10 text-green-800' : 'bg-surface-elevated text-secondary' %>">
                      <%= company.status_text %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary dark:text-muted">
                    <%= company.service_expires_at&.strftime('%Y-%m-%d') || '永久' %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-muted">
                    <%= company.created_at.strftime('%Y-%m-%d') %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <div class="flex justify-center gap-2">
                      <%= link_to admin_company_path(company), class: "p-2 text-muted hover:text-info hover:bg-info/10 rounded transition-colors", title: "查看" do %>
                        <%= lucide_icon "eye", class: "w-4 h-4" %>
                      <% end %>
                      <%= link_to edit_admin_company_path(company), class: "p-2 text-muted hover:text-gray-900 hover:bg-surface-elevated rounded transition-colors", title: "编辑" do %>
                        <%= lucide_icon "pencil", class: "w-4 h-4" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12">
          <%= lucide_icon "building-2", class: "w-12 h-12 text-muted mx-auto mb-4" %>
          <h3 class="text-lg font-medium text-gray-900 dark:text-gray-50 mb-2">暂无企业</h3>
          <%= link_to new_admin_company_path, class: "btn-primary mt-4" do %>
            <%= lucide_icon "plus", class: "w-4 h-4 mr-2" %>新建企业
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <% if @companies.respond_to?(:current_page) %>
    <div class="mt-6"><%= paginate @companies %></div>
  <% end %>
</div>
