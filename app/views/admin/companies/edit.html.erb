<% content_for :title, "编辑企业 - #{@company.name}" %>

<div class="container-xl max-w-2xl">
  <div class="flex items-center gap-4 mb-8">
    <%= link_to admin_company_path(@company), class: "p-2 text-muted hover:text-gray-900 hover:bg-surface-elevated rounded-lg transition-colors" do %>
      <%= lucide_icon "arrow-left", class: "w-5 h-5" %>
    <% end %>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50">编辑企业</h1>
  </div>

  <div class="card bg-surface-elevated dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <%= form_with model: [:admin, @company], class: "space-y-6" do |f| %>
        <% if @company.errors.any? %>
          <div class="alert alert-danger">
            <ul class="list-disc list-inside text-sm">
              <% @company.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "企业名称", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.text_field :name, class: "form-input w-full", required: true %>
        </div>

        <div>
          <%= f.label :service_expires_at, "服务到期日期", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.date_field :service_expires_at, class: "form-input w-full" %>
          <p class="text-xs text-muted mt-1">留空表示永久服务</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">负责律师</label>
          <div class="grid grid-cols-2 gap-2">
            <% @lawyer_options.each do |name, lid| %>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-600 cursor-pointer hover:bg-info/5 hover:border-info/40 transition-colors <%= @company.assigned_lawyer_ids.include?(lid) ? 'bg-info/10 border-info/50' : '' %>">
                <input type="checkbox"
                       name="company[assigned_lawyer_ids][]"
                       value="<%= lid %>"
                       <%= 'checked' if @company.assigned_lawyer_ids.include?(lid) %>
                       class="rounded border-gray-300 text-info focus:ring-info">
                <span class="text-sm text-gray-900 dark:text-gray-100"><%= name %></span>
              </label>
            <% end %>
          </div>
          <p class="text-xs text-muted mt-1">可选择多名律师共同负责该企业</p>
        </div>

        <div class="flex gap-3 justify-end pt-4 border-t border-gray-200 dark:border-gray-700">
          <%= link_to "取消", admin_company_path(@company), class: "btn-outline" %>
          <%= f.submit "保存修改", class: "btn-primary cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
