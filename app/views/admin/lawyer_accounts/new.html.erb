<% content_for :title, "新建律师账号" %>

<div class="container-md">
  <div class="flex items-center space-x-4">
    <%= link_to admin_lawyer_accounts_path, class: "btn-ghost text-sm py-1 px-3" do %>
      <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
      返回律师账号列表
    <% end %>
  </div>

  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50 mt-4 mb-8">创建律师账号</h1>

  <!-- Form -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <%= form_with model: [:admin, @lawyer_account], local: true, class: "space-y-6" do |form| %>
        <% if @lawyer_account.errors.any? %>
          <div class="bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
            <h3 class="text-red-900 dark:text-red-200 font-semibold mb-2">表单存在 <%= pluralize(@lawyer_account.errors.count, "个错误") %>:</h3>
            <ul class="list-disc list-inside text-red-700 dark:text-red-300">
              <% @lawyer_account.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Name -->
        <div class="form-group">
          <%= form.label :name, "姓名" %>
          <%= form.text_field :name, placeholder: "请输入姓名", required: true %>
        </div>

        <!-- Phone -->
        <div class="form-group">
          <%= form.label :phone, "手机号" %>
          <%= form.telephone_field :phone, placeholder: "请输入11位手机号", required: true %>
        </div>

        <!-- Role -->
        <div class="form-group">
          <%= form.label :role, "角色" %>
          <%= form.select :role, [["律师", "lawyer"], ["律师助理", "assistant"]], {}, class: "form-select" %>
        </div>

        <!-- Password -->
        <div class="form-group">
          <%= form.label :password, "密码" %>
          <%= form.password_field :password, placeholder: "至少6位字符", required: true %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">密码长度至少6个字符</p>
        </div>

        <!-- Password Confirmation -->
        <div class="form-group">
          <%= form.label :password_confirmation, "确认密码" %>
          <%= form.password_field :password_confirmation, placeholder: "请再次输入密码", required: true %>
        </div>

        <!-- Form Actions -->
        <div class="flex justify-end space-x-3">
          <%= link_to admin_lawyer_accounts_path, class: "btn-ghost" do %>
            取消
          <% end %>
          <%= form.submit "创建账号", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>