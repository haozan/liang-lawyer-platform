<% content_for :title, "审计日志" %>

<div class="container-xl">
  <!-- Page Title -->
  <div class="mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50">审计日志</h1>
      <p class="text-gray-500 dark:text-gray-400 mt-2">查看所有业务数据访问的审计记录</p>
    </div>
  </div>

  <!-- Filters -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 mb-6">
    <div class="card-body">
      <%= form_with url: admin_data_access_logs_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do |f| %>
        <!-- 资源类型 -->
        <div class="form-group mb-0">
          <%= f.label :resource_type, "资源类型", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= f.select :resource_type, 
              options_for_select([['全部类型', ''], ['合同', 'Contract'], ['案件', 'Case'], ['重大问题', 'MajorIssue']], params[:resource_type]),
              {}, { class: "form-select" } %>
        </div>

        <!-- 操作类型 -->
        <div class="form-group mb-0">
          <%= f.label :action_type, "操作类型", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= f.select :action_type,
              options_for_select([['全部操作', ''], ['查看', 'show'], ['创建', 'create'], ['更新', 'update'], ['删除', 'destroy']], params[:action_type]),
              {}, { class: "form-select" } %>
        </div>

        <!-- 访问方式 -->
        <div class="form-group mb-0">
          <%= f.label :access_method, "访问方式", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= f.select :access_method,
              options_for_select([['全部方式', ''], ['所有者', 'owner'], ['协作者', 'collaborator'], ['查看者', 'viewer'], ['未授权', 'unauthorized_attempt']], params[:access_method]),
              {}, { class: "form-select" } %>
        </div>

        <!-- 律师 -->
        <div class="form-group mb-0">
          <%= f.label :lawyer_id, "律师", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= f.select :lawyer_id,
              options_for_select([['全部律师', '']] + LawyerAccount.all.map { |l| [l.name, l.id] }, params[:lawyer_id]),
              {}, { class: "form-select" } %>
        </div>

        <!-- 开始日期 -->
        <div class="form-group mb-0">
          <%= f.label :start_date, "开始日期", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= f.date_field :start_date, value: params[:start_date], class: "form-input" %>
        </div>

        <!-- 结束日期 -->
        <div class="form-group mb-0">
          <%= f.label :end_date, "结束日期", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= f.date_field :end_date, value: params[:end_date], class: "form-input" %>
        </div>

        <div class="flex items-end space-x-2 md:col-span-3">
          <%= f.submit "筛选", class: "btn-primary" %>
          <%= link_to "重置", admin_data_access_logs_path, class: "btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Data Access Logs Table -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body p-0">
      <% if @data_access_logs.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">时间</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">律师</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">操作</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">资源</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">访问方式</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">IP地址</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">操作</th>
              </tr>
            </thead>
            <tbody class="bg-gray-50 dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
              <% @data_access_logs.each do |log| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                  <!-- 时间 -->
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                    <%= log.created_at.strftime("%Y-%m-%d %H:%M:%S") %>
                  </td>

                  <!-- 律师 -->
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900 dark:text-gray-100">
                      <%= log.lawyer&.name || '未知' %>
                    </div>
                    <div class="text-xs text-gray-500 dark:text-gray-400">
                      ID: <%= log.lawyer_id %>
                    </div>
                  </td>

                  <!-- 操作 -->
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% case log.action %>
                    <% when 'show' %>
                      <span class="badge badge-info">查看</span>
                    <% when 'create' %>
                      <span class="badge badge-success">创建</span>
                    <% when 'update' %>
                      <span class="badge badge-warning">更新</span>
                    <% when 'destroy' %>
                      <span class="badge badge-danger">删除</span>
                    <% else %>
                      <span class="badge badge-secondary"><%= log.action %></span>
                    <% end %>
                  </td>

                  <!-- 资源 -->
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-900 dark:text-gray-100">
                      <% case log.resource_type %>
                      <% when 'Contract' %>
                        <span class="badge badge-info text-xs">合同</span>
                      <% when 'Case' %>
                        <span class="badge badge-success text-xs">案件</span>
                      <% when 'MajorIssue' %>
                        <span class="badge badge-warning text-xs">重大问题</span>
                      <% else %>
                        <span class="badge badge-secondary text-xs"><%= log.resource_type %></span>
                      <% end %>
                    </div>
                    <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                      ID: <%= log.resource_id %>
                    </div>
                  </td>

                  <!-- 访问方式 -->
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% case log.access_method %>
                    <% when 'owner' %>
                      <span class="badge badge-danger">所有者</span>
                    <% when 'collaborator' %>
                      <span class="badge badge-warning">协作者</span>
                    <% when 'viewer' %>
                      <span class="badge badge-info">查看者</span>
                    <% when 'unauthorized_attempt' %>
                      <span class="badge badge-danger">⚠️ 未授权</span>
                    <% else %>
                      <span class="badge badge-secondary"><%= log.access_method %></span>
                    <% end %>
                  </td>

                  <!-- IP地址 -->
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900 dark:text-gray-100">
                    <%= log.ip_address %>
                  </td>

                  <!-- 操作 -->
                  <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                    <%= link_to admin_data_access_log_path(log), class: "p-2 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-50 hover:bg-gray-100 dark:hover:bg-gray-700 rounded transition-colors", title: "查看详情" do %>
                      <%= lucide_icon "eye", class: "w-4 h-4" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Statistics -->
        <div class="p-6 border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
          <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="text-center">
              <div class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @data_access_logs.total_count %></div>
              <div class="text-sm text-gray-500 dark:text-gray-400">总记录数</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">
                <%= @data_access_logs.where(resource_type: 'Contract').count %>
              </div>
              <div class="text-sm text-gray-500 dark:text-gray-400">合同访问</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-green-600 dark:text-green-400">
                <%= @data_access_logs.where(resource_type: 'Case').count %>
              </div>
              <div class="text-sm text-gray-500 dark:text-gray-400">案件访问</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-red-600 dark:text-red-400">
                <%= @data_access_logs.where(access_method: 'unauthorized_attempt').count %>
              </div>
              <div class="text-sm text-gray-500 dark:text-gray-400">未授权尝试</div>
            </div>
          </div>
        </div>
      <% else %>
        <div class="text-center py-12">
          <div class="w-24 h-24 mx-auto mb-4 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center">
            <%= lucide_icon "file-search", class: "w-12 h-12 text-gray-400" %>
          </div>
          <h3 class="text-lg font-medium text-gray-900 dark:text-gray-50 mb-2">暂无审计日志</h3>
          <p class="text-gray-500 dark:text-gray-400">系统会自动记录所有业务数据访问</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Pagination -->
  <% if @data_access_logs.respond_to?(:current_page) %>
    <div class="mt-6">
      <%= paginate @data_access_logs %>
    </div>
  <% end %>
</div>
