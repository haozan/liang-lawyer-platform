<% content_for :title, @data_access_log.respond_to?(:name) ? @data_access_log.name : "Data access log" %>

<div class="container-lg">
  <div class="mb-6">
    <div class="flex items-center space-x-4">
      <%= link_to admin_data_access_logs_path, class: "btn-ghost text-sm py-1 px-3" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
        Back to Data access logs
      <% end %>
    </div>

    <div class="mt-4 flex items-center justify-between">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @data_access_log.respond_to?(:name) ? @data_access_log.name : "Data access log ##{@data_access_log.id}" %></h1>

      <div class="flex items-center space-x-3">
        <%= link_to edit_admin_data_access_log_path(@data_access_log.id), class: "btn-primary" do %>
          <%= lucide_icon "pencil", class: "w-5 h-5 mr-2" %>
          Edit
        <% end %>

        <%= link_to admin_data_access_log_path(@data_access_log.id),
            method: :delete,
            data: { confirm: "Are you sure you want to delete this data_access_log?" },
            class: "btn-danger" do %>
          <%= lucide_icon "trash-2", class: "w-5 h-5 mr-2" %>
          Delete
        <% end %>
      </div>
    </div>
  </div>

  <!-- Data access log Content -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <div class="space-y-6">
        <!-- Resource type -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Resource type</label>
          <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @data_access_log.resource_type %></div>
        </div>

        <!-- Action -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Action</label>
          <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @data_access_log.action %></div>
        </div>

        <!-- Access method -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Access method</label>
          <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @data_access_log.access_method %></div>
        </div>

        <!-- Ip address -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Ip address</label>
          <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @data_access_log.ip_address %></div>
        </div>

        <!-- Lawyer -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Lawyer</label>
          <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @data_access_log.lawyer&.name %></div>
        </div>

        <!-- Resource -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Resource</label>
          <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @data_access_log.resource&.id %></div>
        </div>

        <!-- Metadata -->
        <div class="pt-6 border-t border-gray-200 dark:border-gray-600">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">ID</label>
              <div class="text-sm text-gray-900 dark:text-gray-100 font-mono"><%= @data_access_log.id %></div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Created</label>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                <%= @data_access_log.created_at.strftime("%Y年%-m月%-d日 %H:%M") %>
                <span class="text-gray-400">(<%= time_ago_in_words(@data_access_log.created_at) %> ago)</span>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Last Updated</label>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                <%= @data_access_log.updated_at.strftime("%Y年%-m月%-d日 %H:%M") %>
                <span class="text-gray-400">(<%= time_ago_in_words(@data_access_log.updated_at) %> ago)</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
