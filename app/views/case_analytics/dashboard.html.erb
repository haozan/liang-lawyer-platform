<div class="min-h-screen bg-surface py-8">
  <div class="container-xl mx-auto px-6">
  <!-- Analytics Tabs Navigation -->
  <%= render 'shared/analytics_tabs', current_tab: 'case' %>
  
  <!-- 🎯 固定顶部栏 - 关键指标快速浏览 -->
  <% sticky_metrics = [
    { 
      name: '总案件数', 
      value: @core_kpis[:total_cases], 
      icon: 'folder', 
      color: 'bg-primary/10',
      icon_color: 'text-primary',
      link: cases_path,
      status: {
        value: @core_kpis[:total_cases],
        thresholds: { green: 50, yellow: 20 },
        reverse: false
      }
    },
    { 
      name: '待处理', 
      value: @urgent_alerts[:urgent_pending] + @urgent_alerts[:overdue_hearings], 
      icon: 'alert-circle', 
      color: 'bg-warning/10',
      icon_color: 'text-warning',
      link: cases_path(filter: { status: ['preparing', 'filed'] }),
      status: {
        value: @urgent_alerts[:urgent_pending],
        thresholds: { green: 5, yellow: 10 },
        reverse: true
      }
    },
    { 
      name: '完成率', 
      value: "#{@core_kpis[:completion_rate]}%", 
      icon: 'trending-up', 
      color: 'bg-success/10',
      icon_color: 'text-success',
      trend: { value: @comparison.present? ? @comparison[:closed_change_rate] : 0, unit: '%' },
      status: {
        value: @core_kpis[:completion_rate],
        thresholds: { green: 80, yellow: 60 },
        reverse: false
      }
    },
    { 
      name: '平均时长', 
      value: "#{@core_kpis[:avg_duration_days]}天", 
      icon: 'clock', 
      color: 'bg-info/10',
      icon_color: 'text-info'
    }
  ] %>
  
  <%= render 'shared/dashboard_sticky_bar', metrics: sticky_metrics %>

  <!-- Page Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="page-title">案件数据分析仪表盘</h1>
      <p class="text-secondary">
        <% if @company %>
          <%= @company.name %> · 案件数据统计与分析报告
        <% else %>
          全部企业 · 综合案件数据分析
        <% end %>
      </p>
    </div>
    <div class="flex gap-3">
      <%= link_to export_report_case_analytics_path(
        company_id: params[:company_id],
        date_from: @date_from,
        date_to: @date_to
      ), class: "btn btn-success" do %>
        <%= lucide_icon "download", class: "w-5 h-5 mr-2" %>
        导出报表
      <% end %>
      <%= link_to cases_path, class: "btn btn-secondary" do %>
        <%= lucide_icon "arrow-left", class: "w-5 h-5 mr-2" %>
        返回列表
      <% end %>
    </div>
  </div>

  <!-- Date Range Filter with Quick Options and Comparison -->
  <div class="card card-elevated mb-6">
    <div class="card-body">
      <%= form_with url: dashboard_case_analytics_path, method: :get, local: true do |f| %>
        <div class="space-y-4">
          <!-- Quick Date Options -->
          <div class="flex gap-2 flex-wrap">
            <% today = Date.today %>
            <%= link_to "今天", dashboard_case_analytics_path(company_id: params[:company_id], date_from: today, date_to: today), class: "btn btn-sm btn-secondary" %>
            <%= link_to "本周", dashboard_case_analytics_path(company_id: params[:company_id], date_from: today.beginning_of_week, date_to: today.end_of_week), class: "btn btn-sm btn-secondary" %>
            <%= link_to "本月", dashboard_case_analytics_path(company_id: params[:company_id], date_from: today.beginning_of_month, date_to: today.end_of_month), class: "btn btn-sm btn-secondary" %>
            <%= link_to "本季度", dashboard_case_analytics_path(company_id: params[:company_id], date_from: today.beginning_of_quarter, date_to: today.end_of_quarter), class: "btn btn-sm btn-secondary" %>
            <%= link_to "本年", dashboard_case_analytics_path(company_id: params[:company_id], date_from: today.beginning_of_year, date_to: today.end_of_year), class: "btn btn-sm btn-secondary" %>
            <%= link_to "最近30天", dashboard_case_analytics_path(company_id: params[:company_id], date_from: 30.days.ago, date_to: today), class: "btn btn-sm btn-secondary" %>
            <%= link_to "全部", dashboard_case_analytics_path(company_id: params[:company_id]), class: "btn btn-sm btn-secondary" %>
          </div>

          <div class="flex flex-wrap items-end gap-4">
            <div class="form-group flex-1 min-w-[200px]">
              <%= label_tag "date_from", "开始日期", class: "form-label" %>
              <%= date_field_tag "date_from", @date_from, class: "form-input" %>
            </div>
            
            <div class="form-group flex-1 min-w-[200px]">
              <%= label_tag "date_to", "结束日期", class: "form-label" %>
              <%= date_field_tag "date_to", @date_to, class: "form-input" %>
            </div>
            
            <% if @company.nil? && lawyer? %>
              <div class="form-group flex-1 min-w-[200px]">
                <%= label_tag "company_id", "选择企业", class: "form-label" %>
                <%= select_tag "company_id", 
                    options_for_select([["全部企业", "all"]] + @companies.map { |c| [c.name, c.id] }, params[:company_id]),
                    class: "form-select" %>
              </div>
            <% end %>
            
            <%= f.submit "应用筛选", class: "btn btn-primary" %>
            <%= link_to "重置", dashboard_case_analytics_path(company_id: params[:company_id]), class: "btn btn-secondary" %>
          </div>

          <!-- Comparison Date Range (Collapsible) -->
          <details class="border-t pt-4" <%= 'open' if @comparison.present? %>>
            <summary class="cursor-pointer text-sm font-medium text-primary hover:text-primary/80 flex items-center gap-2">
              <%= lucide_icon "git-compare", class: "w-4 h-4" %>
              数据对比（可选）
            </summary>
            <div class="mt-4 flex flex-wrap items-end gap-4">
              <div class="form-group flex-1 min-w-[200px]">
                <%= label_tag "compare_date_from", "对比开始日期", class: "form-label" %>
                <%= date_field_tag "compare_date_from", params[:compare_date_from], class: "form-input" %>
              </div>
              
              <div class="form-group flex-1 min-w-[200px]">
                <%= label_tag "compare_date_to", "对比结束日期", class: "form-label" %>
                <%= date_field_tag "compare_date_to", params[:compare_date_to], class: "form-input" %>
              </div>
              
              <p class="text-xs text-secondary flex-1">
                选择对比日期后，系统将显示两个时间段的数据对比
              </p>
            </div>
          </details>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Comparison Results (if enabled) -->
  <% if @comparison.present? %>
    <div class="card card-elevated mb-6 border-info">
      <div class="card-header bg-info/10">
        <h3 class="card-title flex items-center gap-2 text-info">
          <%= lucide_icon "git-compare", class: "w-5 h-5" %>
          数据对比结果
        </h3>
      </div>
      <div class="card-body">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="text-center p-4 bg-surface-secondary rounded-lg">
            <p class="text-sm text-secondary mb-2">当期案件数</p>
            <p class="text-3xl font-bold text-primary mb-1"><%= @comparison[:period_total] %></p>
            <p class="text-sm <%= @comparison[:total_change] >= 0 ? 'text-success' : 'text-danger' %>">
              <%= @comparison[:total_change] >= 0 ? '↑' : '↓' %> <%= @comparison[:total_change].abs %> (<%= @comparison[:total_change_rate] %>%)
            </p>
          </div>
          
          <div class="text-center p-4 bg-surface-secondary rounded-lg">
            <p class="text-sm text-secondary mb-2">对比期案件数</p>
            <p class="text-3xl font-bold text-secondary"><%= @comparison[:compare_total] %></p>
          </div>
          
          <div class="text-center p-4 bg-surface-secondary rounded-lg">
            <p class="text-sm text-secondary mb-2">当期结案数</p>
            <p class="text-3xl font-bold text-primary mb-1"><%= @comparison[:period_closed] %></p>
            <p class="text-sm <%= @comparison[:closed_change] >= 0 ? 'text-success' : 'text-danger' %>">
              <%= @comparison[:closed_change] >= 0 ? '↑' : '↓' %> <%= @comparison[:closed_change].abs %> (<%= @comparison[:closed_change_rate] %>%)
            </p>
          </div>
          
          <div class="text-center p-4 bg-surface-secondary rounded-lg">
            <p class="text-sm text-secondary mb-2">对比期结案数</p>
            <p class="text-3xl font-bold text-secondary"><%= @comparison[:compare_closed] %></p>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- 🤖 智能洞察提示卡 -->
  <% if @urgent_alerts[:has_alerts] %>
    <%= render 'shared/smart_insight_card',
      type: 'danger',
      icon: 'alert-triangle',
      title: '需要立即关注',
      message: "检测到#{@urgent_alerts[:overdue_hearings] + @urgent_alerts[:overdue_judgements] + @urgent_alerts[:urgent_pending]}个紧急事项需要处理，包括#{@urgent_alerts[:overdue_hearings]}个逾期开庭、#{@urgent_alerts[:overdue_judgements]}个逾期判决书领取、#{@urgent_alerts[:urgent_pending]}个高优先级待处理案件。",
      action_text: '查看紧急案件',
      action_url: cases_path(filter: { priority: 'urgent' })
    %>
  <% elsif @core_kpis[:completion_rate] >= 85 %>
    <%= render 'shared/smart_insight_card',
      type: 'success',
      icon: 'trending-up',
      title: '表现优秀',
      message: "当前完成率达到#{@core_kpis[:completion_rate]}%，团队协作效率高于平均水平。平均处理时长#{@core_kpis[:avg_duration_days]}天，保持良好态势。"
    %>
  <% elsif @core_kpis[:current_month_new] > 20 %>
    <%= render 'shared/smart_insight_card',
      type: 'info',
      icon: 'lightbulb',
      title: '业务增长提示',
      message: "本月新增#{@core_kpis[:current_month_new]}个案件，业务量呈增长趋势。建议关注团队工作负载，必要时合理分配资源。",
      action_text: '查看团队工作量',
      action_url: team_workload_cases_path
    %>
  <% end %>

  <!-- 🎯 专业仪表盘组件区 -->
  <div class="grid lg:grid-cols-3 gap-6 mb-6">
    <!-- 完成率仪表盘 -->
    <% completion_gauge_data = {
      value: @core_kpis[:completion_rate],
      max: 100,
      name: '完成率'
    } %>
    <%= render 'shared/dashboard_chart_wrapper',
      type: 'gauge',
      data: completion_gauge_data,
      title: '案件完成率',
      height: '280px'
    %>

    <!-- 状态分布环形图 -->
    <% status_donut_data = {
      name: '案件状态',
      data: @distributions[:status_distribution].map do |status, count|
        status_names = {
          'preparing' => '准备立案',
          'filed' => '已立案待审',
          'trial' => '审理中',
          'judged' => '已判决',
          'execution' => '执行中',
          'settled' => '调解结案',
          'closed' => '已归档'
        }
        { name: status_names[status] || status, value: count }
      end
    } %>
    <%= render 'shared/dashboard_chart_wrapper',
      type: 'donut',
      data: status_donut_data,
      title: '状态分布',
      height: '280px'
    %>

    <!-- 阶段分布环形图 -->
    <% stage_donut_data = {
      name: '案件阶段',
      data: @distributions[:stage_distribution].map do |stage, count|
        stage_names = {
          'arbitration' => '仲裁',
          'first_trial' => '一审',
          'second_trial' => '二审',
          'execution' => '执行',
          'retrial' => '再审',
          'resume_execution' => '恢复执行'
        }
        { name: stage_names[stage] || stage, value: count }
      end
    } %>
    <%= render 'shared/dashboard_chart_wrapper',
      type: 'donut',
      data: stage_donut_data,
      title: '阶段分布',
      height: '280px'
    %>
  </div>

  <!-- Core KPI Panel with Enhanced Design -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <%= link_to cases_path, class: "card card-elevated hover:shadow-lg transition-shadow bg-gradient-to-br from-primary/5 to-primary/10" do %>
      <div class="card-body text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <%= lucide_icon "folder", class: "w-6 h-6 text-primary" %>
          <p class="text-sm text-secondary font-medium">案件总数</p>
        </div>
        <p class="font-heading text-5xl font-bold text-primary mb-2"><%= @core_kpis[:total_cases] %></p>
        <% if @core_kpis[:current_month_new] > 0 %>
          <div class="inline-flex items-center gap-1 px-3 py-1 bg-success/10 rounded-full">
            <%= lucide_icon "trending-up", class: "w-3 h-3 text-success" %>
            <span class="text-xs text-success font-medium">
              +<%= @core_kpis[:current_month_new] %> 本月
            </span>
          </div>
        <% end %>
      </div>
    <% end %>
    
    <%= link_to cases_path(filter: { status: ['investigating', 'in_court'] }), class: "card card-elevated hover:shadow-lg transition-shadow bg-gradient-to-br from-warning/5 to-warning/10" do %>
      <div class="card-body text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <%= lucide_icon "activity", class: "w-6 h-6 text-warning" %>
          <p class="text-sm text-secondary font-medium">活跃案件</p>
        </div>
        <p class="font-heading text-5xl font-bold text-warning mb-2"><%= @core_kpis[:active_cases] %></p>
        <p class="text-xs text-secondary">
          审理中 + 执行中
        </p>
      </div>
    <% end %>
    
    <%= link_to cases_path(filter: { status: 'closed' }), class: "card card-elevated hover:shadow-lg transition-shadow bg-gradient-to-br from-success/5 to-success/10" do %>
      <div class="card-body text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <%= lucide_icon "check-circle", class: "w-6 h-6 text-success" %>
          <p class="text-sm text-secondary font-medium">已归档</p>
        </div>
        <p class="font-heading text-5xl font-bold text-success mb-2"><%= @core_kpis[:closed_cases] %></p>
        <p class="text-xs text-secondary">
          平均 <%= @core_kpis[:avg_duration_days] %> 天
        </p>
      </div>
    <% end %>
    
    <div class="card card-elevated bg-gradient-to-br from-info/5 to-info/10">
      <div class="card-body text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <%= lucide_icon "target", class: "w-6 h-6 text-info" %>
          <p class="text-sm text-secondary font-medium">完成率</p>
        </div>
        <p class="font-heading text-5xl font-bold text-info mb-2"><%= @core_kpis[:completion_rate] %>%</p>
        <div class="w-full bg-surface-secondary rounded-full h-3 mt-3">
          <div class="bg-info h-3 rounded-full transition-all duration-1000" style="width: <%= @core_kpis[:completion_rate] %>%"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Trend Visualization with ECharts -->
  <% if @trends[:filing_daily].any? %>
    <% sorted_trend = @trends[:filing_daily].sort %>
    <% trend_line_data = {
      categories: sorted_trend.map { |date, _| date.strftime('%m/%d') },
      series: [{
        name: '立案数量',
        type: 'line',
        data: sorted_trend.map(&:last),
        smooth: true,
        areaStyle: { opacity: 0.3 },
        lineStyle: { width: 3 },
        itemStyle: { color: '#5470c6' }
      }]
    } %>
    <%= render 'shared/dashboard_chart_wrapper',
      type: 'line',
      data: trend_line_data,
      title: "立案趋势分析 (#{@date_from.strftime('%Y-%m-%d')} 至 #{@date_to.strftime('%Y-%m-%d')})",
      height: '350px'
    %>
  <% end %>

  <!-- 案件类型分布横向条形图 -->
  <% if @distributions[:case_type_distribution].any? %>
    <% case_type_bar_data = {
      categories: @distributions[:case_type_distribution].keys,
      series: [{
        name: '案件数量',
        type: 'bar',
        data: @distributions[:case_type_distribution].values,
        itemStyle: {
          color: '#5470c6',
          borderRadius: [0, 4, 4, 0]
        },
        label: {
          show: true,
          position: 'right'
        }
      }]
    } %>
    <%= render 'shared/dashboard_chart_wrapper',
      type: 'bar',
      data: case_type_bar_data,
      title: '案件类型分布（Top 10）',
      height: '400px'
    %>
  <% end %>

  <!-- Key Milestones Statistics -->
  <div class="card card-elevated mb-6">
    <div class="card-header">
      <h3 class="card-title flex items-center gap-2">
        <%= lucide_icon "calendar-check", class: "w-5 h-5" %>
        关键节点统计
      </h3>
    </div>
    <div class="card-body">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <%= link_to cases_path(filter: { hearing_month: Date.today.strftime('%Y-%m') }), class: "p-4 bg-surface-secondary rounded-lg hover:bg-surface-secondary/80 transition-all hover:scale-105" do %>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-info/20 flex items-center justify-center">
              <%= lucide_icon "calendar", class: "w-6 h-6 text-info" %>
            </div>
            <div>
              <p class="text-sm text-secondary">本月开庭</p>
              <p class="text-3xl font-bold text-primary"><%= @key_milestones[:month_hearings] %></p>
            </div>
          </div>
        <% end %>
        
        <%= link_to cases_path(filter: { judgement_month: Date.today.strftime('%Y-%m') }), class: "p-4 bg-surface-secondary rounded-lg hover:bg-surface-secondary/80 transition-all hover:scale-105" do %>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-success/20 flex items-center justify-center">
              <%= lucide_icon "file-check", class: "w-6 h-6 text-success" %>
            </div>
            <div>
              <p class="text-sm text-secondary">本月判决</p>
              <p class="text-3xl font-bold text-primary"><%= @key_milestones[:month_judgements] %></p>
            </div>
          </div>
        <% end %>
        
        <%= link_to cases_path(filter: { stage: 'execution', status: ['investigating', 'in_court'] }), class: "p-4 bg-surface-secondary rounded-lg hover:bg-surface-secondary/80 transition-all hover:scale-105" do %>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-warning/20 flex items-center justify-center">
              <%= lucide_icon "play-circle", class: "w-6 h-6 text-warning" %>
            </div>
            <div>
              <p class="text-sm text-secondary">待执行</p>
              <p class="text-3xl font-bold text-primary"><%= @key_milestones[:pending_execution] %></p>
            </div>
          </div>
        <% end %>
        
        <%= link_to cases_path(filter: { has_property_preservation: true }), class: "p-4 bg-surface-secondary rounded-lg hover:bg-surface-secondary/80 transition-all hover:scale-105" do %>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-danger/20 flex items-center justify-center">
              <%= lucide_icon "shield", class: "w-6 h-6 text-danger" %>
            </div>
            <div>
              <p class="text-sm text-secondary">财产保全</p>
              <p class="text-3xl font-bold text-primary"><%= @key_milestones[:property_preservation_count] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Team Workload & Company Rankings -->
  <div class="grid lg:grid-cols-2 gap-6">
    <!-- Team Workload with Heatmap Style -->
    <% if @team_workload.any? %>
      <div class="card card-elevated">
        <div class="card-header">
          <h3 class="card-title flex items-center gap-2">
            <%= lucide_icon "users", class: "w-5 h-5" %>
            团队工作量分析（Top 10）
          </h3>
        </div>
        <div class="card-body">
          <div class="space-y-3">
            <% max_workload = @team_workload.first[:total_cases] %>
            <% @team_workload.each_with_index do |workload, index| %>
              <% percentage = max_workload > 0 ? (workload[:total_cases].to_f / max_workload * 100).round(1) : 0 %>
              <% heat_intensity = (percentage / 100.0 * 0.2).round(2) %>
              <div class="p-3 rounded-lg transition-all hover:shadow-md" style="background: rgba(84, 112, 198, <%= heat_intensity %>);">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-surface-elevated flex items-center justify-center flex-shrink-0 shadow-sm">
                    <span class="text-sm font-bold text-primary"><%= index + 1 %></span>
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center justify-between mb-1">
                      <span class="text-sm font-semibold text-primary"><%= workload[:lawyer_name] %></span>
                      <span class="badge badge-primary">
                        <%= workload[:total_cases] %> 件
                      </span>
                    </div>
                    <div class="flex items-center gap-3 text-xs text-secondary">
                      <span class="flex items-center gap-1">
                        <%= lucide_icon "user-check", class: "w-3 h-3" %>
                        主办: <%= workload[:lead_cases] %>
                      </span>
                      <span class="flex items-center gap-1">
                        <%= lucide_icon "activity", class: "w-3 h-3" %>
                        活跃: <%= workload[:active_cases] %>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Company Rankings -->
    <% if @company_rankings.any? %>
      <div class="card card-elevated">
        <div class="card-header">
          <h3 class="card-title flex items-center gap-2">
            <%= lucide_icon "trophy", class: "w-5 h-5" %>
            企业案件数排行（Top 10）
          </h3>
        </div>
        <div class="card-body">
          <div class="space-y-2">
            <% @company_rankings.each_with_index do |ranking, index| %>
              <% medal_colors = ['bg-yellow-500', 'bg-gray-400', 'bg-amber-700'] %>
              <%= link_to dashboard_case_analytics_path(company_id: ranking[:company_id], date_from: @date_from, date_to: @date_to),
                  class: "flex items-center gap-3 p-3 bg-surface-secondary rounded-lg hover:bg-surface-secondary/80 transition-all hover:scale-102 hover:shadow-md" do %>
                <div class="w-10 h-10 rounded-full <%= index < 3 ? medal_colors[index] : 'bg-info/20' %> flex items-center justify-center flex-shrink-0">
                  <% if index < 3 %>
                    <%= lucide_icon "award", class: "w-5 h-5 text-white" %>
                  <% else %>
                    <span class="text-sm font-bold text-info"><%= index + 1 %></span>
                  <% end %>
                </div>
                <span class="text-sm font-medium text-primary flex-1 truncate"><%= ranking[:company_name] %></span>
                <span class="badge badge-info"><%= ranking[:cases_count] %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Floating Quick Navigation Button -->
  <%= render 'shared/analytics_quick_nav', current_module: 'case' %>
  </div>
</div>