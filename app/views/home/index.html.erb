<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="min-h-screen bg-surface">
  <!-- Top Navbar -->
  <nav class="bg-white/90 backdrop-blur-sm border-b border-gray-100 sticky top-0 z-50 shadow-sm">
    <div class="container-xl mx-auto px-6">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <div class="flex items-center gap-3">
          <%= lucide_icon "scale", class: "w-7 h-7 text-primary" %>
                    <span class="font-heading text-xl font-bold text-primary hidden sm:inline">极光法律服务管理系统</span>
          <span class="font-heading text-xl font-bold text-primary sm:hidden">极光法律</span>
          <span class="ml-1 text-xs text-gray-400 font-mono">v<%= AppVersion::VERSION %></span>
          

        </div>
        <!-- Login Button -->
        <%= link_to login_path, class: "btn-primary btn-sm flex items-center gap-2" do %>
          <%= lucide_icon "log-in", class: "w-4 h-4" %>
          <span>登录系统</span>
        <% end %>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary via-primary-dark to-primary-light text-surface py-24">
    <div class="container-xl mx-auto px-6">
      <div class="flex flex-col items-center text-center space-y-6">
        <%= lucide_icon "scale", class: "w-20 h-20 text-secondary" %>
        <h1 class="text-5xl md:text-6xl font-bold text-balance mb-6">
          重新定义企业合同法律服务
        </h1>
        <p class="text-2xl md:text-3xl font-bold text-amber-400 bg-white/10 backdrop-blur-sm px-8 py-4 rounded-lg shadow-lg border-2 border-amber-400 max-w-5xl">
          全流程护航，胜率直升80%，精细化管控，成本直降80%
        </p>
        <div class="mt-8 text-xl md:text-2xl italic text-surface-elevated">
          不做<span class="text-amber-400">"事后救火员"</span>，要做<span class="text-amber-400">"全程守护者"</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values Section -->
  <section class="py-16 bg-surface-elevated">
    <div class="container-xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-center text-primary mb-12">核心价值</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- 省心 -->
        <div class="card card-elevated p-8 text-center">
          <%= lucide_icon "heart", class: "w-12 h-12 text-primary mx-auto mb-4" %>
          <h3 class="text-2xl font-bold text-primary mb-3">省心</h3>
          <p class="text-secondary text-base leading-relaxed">
            律师全程陪跑，合同履行不再担心
          </p>
        </div>

        <!-- 省时 -->
        <div class="card card-elevated p-8 text-center">
          <%= lucide_icon "clock", class: "w-12 h-12 text-info mx-auto mb-4" %>
          <h3 class="text-2xl font-bold text-primary mb-3">省时</h3>
          <p class="text-secondary text-base leading-relaxed">
            证据自动固化，争议发生即刻应对
          </p>
        </div>

        <!-- 省钱 -->
        <div class="card card-elevated p-8 text-center">
          <%= lucide_icon "wallet", class: "w-12 h-12 text-success mx-auto mb-4" %>
          <h3 class="text-2xl font-bold text-primary mb-3">省钱</h3>
          <p class="text-secondary text-base leading-relaxed">
            沟通成本骤降，律师费用大幅优化
          </p>
        </div>

        <!-- 省力 -->
        <div class="card card-elevated p-8 text-center">
          <%= lucide_icon "zap", class: "w-12 h-12 text-warning mx-auto mb-4" %>
          <h3 class="text-2xl font-bold text-primary mb-3">省力</h3>
          <p class="text-secondary text-base leading-relaxed">
            系统一键导出，诉讼材料自动生成
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Customer Benefits Section -->
  <section class="py-16 bg-surface">
    <div class="container-xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-center text-primary mb-12">客户获益</h2>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="card card-flat p-6 flex items-start gap-4">
          <%= lucide_icon "check-circle", class: "w-8 h-8 text-success flex-shrink-0 mt-1" %>
          <div>
            <h3 class="text-xl font-semibold text-primary mb-2">合同风险早发现、早预防</h3>
            <p class="text-secondary">律师在合同签订前全面审查，识别潜在风险点，提前制定应对策略</p>
          </div>
        </div>

        <div class="card card-flat p-6 flex items-start gap-4">
          <%= lucide_icon "check-circle", class: "w-8 h-8 text-success flex-shrink-0 mt-1" %>
          <div>
            <h3 class="text-xl font-semibold text-primary mb-2">履约过程有记录、有证据</h3>
            <p class="text-secondary">全流程跟踪合同履行，自动固化关键证据链，确保每一步都有据可查</p>
          </div>
        </div>

        <div class="card card-flat p-6 flex items-start gap-4">
          <%= lucide_icon "check-circle", class: "w-8 h-8 text-success flex-shrink-0 mt-1" %>
          <div>
            <h3 class="text-xl font-semibold text-primary mb-2">发生争议有准备、有底气</h3>
            <p class="text-secondary">律师持续跟进合同状态，一旦出现争议立即响应，无需慌乱准备</p>
          </div>
        </div>

        <div class="card card-flat p-6 flex items-start gap-4">
          <%= lucide_icon "check-circle", class: "w-8 h-8 text-success flex-shrink-0 mt-1" %>
          <div>
            <h3 class="text-xl font-semibold text-primary mb-2">诉讼启动有材料、有优势</h3>
            <p class="text-secondary">系统一键导出完整诉讼材料，大幅降低律师费，缩短诉讼准备时间</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Platform Modules Section -->
  <section class="py-16 bg-gradient-to-br from-surface-elevated to-surface">
    <div class="container-xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-center text-primary mb-12">平台四大板块</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Contract Management -->
        <div class="card card-elevated p-8">
          <div class="flex flex-col items-center text-center">
            <%= lucide_icon "file-text", class: "w-16 h-16 text-primary mb-4" %>
            <h3 class="text-2xl font-bold text-primary mb-4">合同管理</h3>
            <p class="text-secondary mb-6">
              建立合同库，每月定期提醒对账。系统自动跟踪合同履行全周期，确保每一步都在掌控之中。
            </p>
            <ul class="space-y-3 text-left w-full">
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">合同审查与归档</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">月度对账单提醒</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">履约进度跟踪</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">证据链自动固化</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Case Management -->
        <div class="card card-elevated p-8">
          <div class="flex flex-col items-center text-center">
            <%= lucide_icon "briefcase", class: "w-16 h-16 text-info mb-4" %>
            <h3 class="text-2xl font-bold text-primary mb-4">案件管理</h3>
            <p class="text-secondary mb-6">
              由律师团队负责案件进展更新，企业客户实时查看案情动态，全程透明可追溯。
            </p>
            <ul class="space-y-3 text-left w-full">
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">案件进度实时更新</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">开庭时间自动提醒</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">材料文档集中管理</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">判决书归档查询</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Major Issues Discussion -->
        <div class="card card-elevated p-8">
          <div class="flex flex-col items-center text-center">
            <%= lucide_icon "message-circle", class: "w-16 h-16 text-warning mb-4" %>
            <h3 class="text-2xl font-bold text-primary mb-4">重大事项研讨</h3>
            <p class="text-secondary mb-6">
              服务期内遇到重大问题，建立专项档案进行针对性讨论，律师团队提供专业解决方案。
            </p>
            <ul class="space-y-3 text-left w-full">
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">问题专项建档</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">@律师即时响应</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">文件资料共享</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">方案讨论与决策</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Data Analytics Center -->
        <div class="card card-elevated p-8">
          <div class="flex flex-col items-center text-center">
            <%= lucide_icon "bar-chart-3", class: "w-16 h-16 text-success mb-4" %>
            <h3 class="text-2xl font-bold text-primary mb-4">数据分析中心</h3>
            <p class="text-secondary mb-6">
              智能分析，科学决策。多维度数据看板，助力企业精准把控法律风险，优化管理流程。
            </p>
            <ul class="space-y-3 text-left w-full">
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">合同数据分析看板</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">案件数据统计报表</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">风险预警智能提示</span>
              </li>
              <li class="flex items-center gap-2">
                <%= lucide_icon "arrow-right", class: "w-4 h-4 text-secondary" %>
                <span class="text-secondary text-sm">数据导出CSV报表</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-primary" data-controller="wechat-modal" data-action="keydown@window->wechat-modal#handleKeydown">
    <div class="container-md mx-auto px-6 text-center">
      <h2 class="text-4xl font-bold text-surface mb-6">
        让专业律师成为您企业的法律守护者
      </h2>
      <p class="text-xl text-surface-elevated mb-10">
        让每份合同都有律师陪伴 · 让每个风险都被提前化解
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <%= link_to login_path, class: "btn-secondary btn-lg" do %>
          <%= lucide_icon "log-in", class: "w-5 h-5 mr-2" %>
          <span>登录系统</span>
        <% end %>
        <button type="button" class="btn-secondary btn-lg">
          <%= lucide_icon "sparkles", class: "w-5 h-5 mr-2" %>
          <span>免费试用</span>
        </button>
        <button type="button" data-action="click->wechat-modal#open" class="btn-outline btn-lg border-surface text-surface hover:bg-surface hover:text-primary">
          <%= lucide_icon "calendar", class: "w-5 h-5 mr-2" %>
          <span>预约演示</span>
        </button>
      </div>
    </div>

    <!-- WeChat QR Code Modal -->
    <div data-wechat-modal-target="modal" class="hidden fixed inset-0 z-50 overflow-y-auto" data-action="click->wechat-modal#closeOnBackdrop">
      <div class="flex min-h-screen items-center justify-center p-4">
        <!-- Backdrop -->
        <div class="fixed inset-0 bg-black/50 backdrop-blur-sm transition-opacity"></div>
        
        <!-- Modal Content -->
        <div class="relative bg-surface rounded-2xl shadow-2xl max-w-md w-full p-8 transform transition-all">
          <!-- Close Button -->
          <button type="button" data-action="click->wechat-modal#close" class="absolute top-4 right-4 text-muted hover:text-primary transition-colors">
            <%= lucide_icon "x", class: "w-6 h-6" %>
          </button>
          
          <!-- Content -->
          <div class="text-center">
            <%= lucide_icon "message-circle", class: "w-12 h-12 text-success mx-auto mb-4" %>
            <h3 class="text-2xl font-bold text-primary mb-2">添加微信预约演示</h3>
            <p class="text-secondary mb-6">扫描下方二维码添加梁家航律师微信</p>
            
            <!-- QR Code Image -->
            <div class="bg-surface-elevated rounded-xl p-6 mb-4">
              <%= image_tag "wechat_qr.png", alt: "梁家航律师微信二维码", class: "w-full max-w-xs mx-auto" %>
            </div>
            
            <p class="text-sm text-muted">
              <%= lucide_icon "info", class: "w-4 h-4 inline-block mr-1" %>
              工作时间内将在2小时内回复
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer with Contact Information -->
  <footer class="py-12 bg-surface-elevated border-t border-border">
    <div class="container-xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 mb-8">
        <!-- Left: Brand -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <%= lucide_icon "scale", class: "w-8 h-8 text-primary" %>
            <span class="text-primary font-bold text-xl">极光法律服务管理系统</span>
          </div>
          <p class="text-secondary text-sm mb-4">
            全程把控 · 风险预防 · 争议化解 · 成本优化
          </p>
        </div>
        
        <!-- Right: Contact Information -->
        <div>
          <h3 class="text-primary font-bold text-lg mb-4">联系我们</h3>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <%= lucide_icon "map-pin", class: "w-5 h-5 text-primary flex-shrink-0 mt-0.5" %>
              <div class="text-secondary text-sm">
                <p class="font-semibold text-primary mb-1">办公地址</p>
                <p>广东省四会市东城街道广场南路0号</p>
                <p>德宝广场3座408-411</p>
                <p class="text-muted mt-1">（广东诺赢律师事务所）</p>
              </div>
            </div>
            
            <div class="flex items-center gap-3">
              <%= lucide_icon "phone", class: "w-5 h-5 text-primary flex-shrink-0" %>
              <div class="text-secondary text-sm">
                <p class="font-semibold text-primary mb-1">联系电话</p>
                <a href="tel:18718708876" class="hover:text-primary transition-colors">18718708876</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Copyright -->
      <div class="pt-6 border-t border-border text-center">
        <p class="text-muted text-sm">© 2024 极光法律服务管理系统 版权所有</p>
      </div>
    </div>
  </footer>
</div>
