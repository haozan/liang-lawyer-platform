<div class="min-h-screen bg-surface py-8">
  <div class="container-md mx-auto px-6">
    <div class="mb-6">
      <%= link_to contracts_path, class: "inline-flex items-center gap-2 text-secondary hover:text-primary transition-colors" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4" %>
        <span>返回列表</span>
      <% end %>
    </div>

    <div class="card card-elevated">
      <div class="card-header border-b border-border">
        <h2 class="font-heading text-2xl font-bold text-primary"><%= @contract.persisted? ? '编辑合同档案' : '新建合同档案' %></h2>
      </div>
      <div class="card-body">
        <%= form_with model: @contract, class: "space-y-6", multipart: true do |f| %>
          <% if lawyer? %>
            <div>
              <%= f.label :company_id, "所属企业 *", class: "form-label" %>
              <%= f.select :company_id, 
                  options_for_select(@companies.map { |c| [c.name, c.id] }, @selected_company&.id),
                  { prompt: "请选择企业" },
                  { class: "form-select", required: true } %>
            </div>
          <% end %>
          
          <!-- Tab Navigation and Content -->
          <div data-controller="tabs" data-tabs-active-tab-value="basic">
            <!-- Tab Navigation -->
            <div class="border-b border-border">
            <nav class="flex gap-6" role="tablist" data-controller="horizontal-scroll">
              <button type="button" 
                      role="tab"
                      data-tabs-target="button"
                      data-action="click->tabs#select"
                      data-tab="basic" 
                      aria-controls="basic-panel"
                      class="tab-button active px-4 py-3 border-b-2 border-primary text-primary font-semibold">
                基本信息
              </button>
              <button type="button" 
                      role="tab"
                      data-tabs-target="button"
                      data-action="click->tabs#select"
                      data-tab="performance" 
                      aria-controls="performance-panel"
                      class="tab-button px-4 py-3 border-b-2 border-transparent text-secondary hover:text-primary hover:border-secondary">
                履行跟踪
              </button>
              <button type="button" 
                      role="tab"
                      data-tabs-target="button"
                      data-action="click->tabs#select"
                      data-tab="risk" 
                      aria-controls="risk-panel"
                      class="tab-button px-4 py-3 border-b-2 border-transparent text-secondary hover:text-primary hover:border-secondary">
                风险管控
              </button>
              <button type="button" 
                      role="tab"
                      data-tabs-target="button"
                      data-action="click->tabs#select"
                      data-tab="internal" 
                      aria-controls="internal-panel"
                      class="tab-button px-4 py-3 border-b-2 border-transparent text-secondary hover:text-primary hover:border-secondary">
                内部管理
              </button>
            </nav>
          </div>
          
          <!-- Tab Content -->
          <div class="tab-content-wrapper">
            <!-- 基本信息 Tab -->
            <div id="basic-panel" 
                 role="tabpanel"
                 data-tabs-target="panel"
                 data-tab="basic"
                 class="tab-content space-y-6">
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2">合同基本信息</h3>
              
              <div>
                <%= f.label :name, "合同档案名称 *", class: "form-label" %>
                <%= f.text_field :name, required: true, class: "form-input", placeholder: "例如：与XX公司的采购合同" %>
                <p class="form-help">用于内部管理的档案名称，可与合同原始标题不同</p>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :contract_number, "合同编号", class: "form-label" %>
                  <%= f.text_field :contract_number, class: "form-input", placeholder: "例如：2024-HT-001" %>
                  <p class="form-help">企业内部合同编号</p>
                </div>
                <div>
                  <%= f.label :contract_title, "合同原始标题", class: "form-label" %>
                  <%= f.text_field :contract_title, class: "form-input", placeholder: "合同文本上的标题" %>
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :contract_type, "合同类型 *", class: "form-label" %>
                  <%= f.select :contract_type, 
                      ['买卖合同', '服务合同', '租赁合同', '借款合同', '建设工程合同', '技术合同', '承揽合同', '运输合同', '保管合同', '委托合同', '其他'],
                      { prompt: "请选择合同类型" },
                      { class: "form-select", required: true } %>
                </div>
                <div>
                  <%= f.label :signing_location, "签订地点", class: "form-label" %>
                  <%= f.text_field :signing_location, class: "form-input", placeholder: "例如：广东省广州市" %>
                  <p class="form-help">确定管辖法院的重要依据</p>
                </div>
              </div>
              
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">合同双方</h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :our_party_role, "我方地位 *", class: "form-label" %>
                  <%= f.text_field :our_party_role, required: true, class: "form-input", placeholder: "例如：买方、甲方、承租方" %>
                </div>
                <div>
                  <%= f.label :our_signatory, "我方签约代表", class: "form-label" %>
                  <%= f.text_field :our_signatory, class: "form-input", placeholder: "签字人姓名" %>
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :counterparty_name, "对方名称 *", class: "form-label" %>
                  <%= f.text_field :counterparty_name, required: true, class: "form-input", placeholder: "对方公司或个人名称" %>
                </div>
                <div>
                  <%= f.label :counterparty_role, "对方地位 *", class: "form-label" %>
                  <%= f.text_field :counterparty_role, required: true, class: "form-input", placeholder: "例如：卖方、乙方、出租方" %>
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :counterparty_type, "对方类型", class: "form-label" %>
                  <%= f.select :counterparty_type, 
                      ['企业', '个人', '政府机关', '其他'],
                      { prompt: "请选择" },
                      { class: "form-select" } %>
                </div>
                <div>
                  <%= f.label :counterparty_unified_code, "对方统一社会信用代码", class: "form-label" %>
                  <%= f.text_field :counterparty_unified_code, class: "form-input", placeholder: "18位统一社会信用代码" %>
                  <p class="form-help">用于主体资格审查和信用查询</p>
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :counterparty_legal_rep, "对方法定代表人", class: "form-label" %>
                  <%= f.text_field :counterparty_legal_rep, class: "form-input" %>
                </div>
                <div>
                  <%= f.label :counterparty_address, "对方地址", class: "form-label" %>
                  <%= f.text_field :counterparty_address, class: "form-input" %>
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :counterparty_contact, "对方联系人", class: "form-label" %>
                  <%= f.text_field :counterparty_contact, class: "form-input" %>
                </div>
                <div>
                  <%= f.label :counterparty_phone, "对方联系电话", class: "form-label" %>
                  <%= f.text_field :counterparty_phone, class: "form-input" %>
                </div>
              </div>
              
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">金额与期限</h3>
              
              <div class="grid md:grid-cols-3 gap-6">
                <div>
                  <%= f.label :contract_amount, "合同金额", class: "form-label" %>
                  <%= f.number_field :contract_amount, step: 0.01, class: "form-input", placeholder: "0.00" %>
                </div>
                <div>
                  <%= f.label :currency, "币种", class: "form-label" %>
                  <%= f.select :currency, 
                      ['人民币', '美元', '港币', '欧元', '日元'],
                      {},
                      { class: "form-select" } %>
                </div>
                <div>
                  <%= f.label :payment_method, "付款方式", class: "form-label" %>
                  <%= f.select :payment_method, 
                      ['转账', '支票', '汇票', '现金', '其他'],
                      { prompt: "请选择" },
                      { class: "form-select" } %>
                </div>
              </div>
              
              <div>
                <%= f.label :payment_terms, "付款条款", class: "form-label" %>
                <%= f.text_area :payment_terms, rows: 3, class: "form-textarea", placeholder: "例如：签订后3日内支付30%，交付后7日内支付60%，质保期结束支付10%" %>
              </div>
              
              <div class="grid md:grid-cols-3 gap-6">
                <div>
                  <%= f.label :signed_at, "签订日期 *", class: "form-label" %>
                  <%= f.date_field :signed_at, required: true, class: "form-input" %>
                </div>
                <div>
                  <%= f.label :end_at, "到期日期 *", class: "form-label" %>
                  <%= f.date_field :end_at, required: true, class: "form-input" %>
                </div>
                <div>
                  <%= f.label :status, "合同状态 *", class: "form-label" %>
                  <%= f.select :status, [['执行中', 'active'], ['已完成', 'completed'], ['已违约', 'breach'], ['诉讼中', 'litigation']], {}, class: "form-select" %>
                </div>
              </div>
              
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">合同文件</h3>
              
              <div>
                <%= f.label :file, "主合同文件 (PDF) *", class: "form-label" %>
                <%= f.file_field :file, accept: 'application/pdf', class: "form-input", required: !@contract.persisted? %>
                <p class="form-help">请上传双方盖章的PDF扫描版</p>
                <% if @contract.file.attached? %>
                  <p class="mt-2 text-sm text-success">已上传：<%= @contract.file.filename %></p>
                <% end %>
              </div>
              
              <div>
                <%= f.label :supplement_files, "补充协议", class: "form-label" %>
                <%= f.file_field :supplement_files, multiple: true, accept: 'application/pdf', class: "form-input" %>
                <p class="form-help">可上传多个补充协议</p>
              </div>
              
              <div>
                <%= f.label :annex_files, "合同附件", class: "form-label" %>
                <%= f.file_field :annex_files, multiple: true, class: "form-input" %>
                <p class="form-help">技术文档、清单等附件</p>
              </div>
            </div>
            
            <!-- 履行跟踪 Tab -->
            <div id="performance-panel" 
                 role="tabpanel"
                 data-tabs-target="panel"
                 data-tab="performance"
                 class="tab-content hidden space-y-6">
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2">履行状态</h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :performance_status, "履行状态", class: "form-label" %>
                  <%= f.select :performance_status, 
                      ['未开始履行', '正常履行中', '部分履行', '履行完毕', '对方违约', '我方违约', '协商变更中', '已解除', '已终止'],
                      {},
                      { class: "form-select" } %>
                </div>
                <div>
                  <%= f.label :performance_progress, "履行进度 (%)", class: "form-label" %>
                  <%= f.number_field :performance_progress, min: 0, max: 100, class: "form-input", placeholder: "0-100" %>
                </div>
              </div>
              
              <div>
                <%= f.label :performance_notes, "履行备注", class: "form-label" %>
                <%= f.text_area :performance_notes, rows: 3, class: "form-textarea", placeholder: "记录履行过程中的重要事项" %>
              </div>
              
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">履行期限</h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :performance_start_date, "履行开始日期", class: "form-label" %>
                  <%= f.date_field :performance_start_date, class: "form-input" %>
                </div>
                <div>
                  <%= f.label :performance_end_date, "履行截止日期", class: "form-label" %>
                  <%= f.date_field :performance_end_date, class: "form-input" %>
                </div>
              </div>
              
              <div class="grid md:grid-cols-3 gap-6">
                <div>
                  <%= f.label :delivery_date, "交付日期", class: "form-label" %>
                  <%= f.date_field :delivery_date, class: "form-input" %>
                </div>
                <div>
                  <%= f.label :delivery_location, "交付地点", class: "form-label" %>
                  <%= f.text_field :delivery_location, class: "form-input" %>
                </div>
                <div>
                  <%= f.label :acceptance_date, "验收日期", class: "form-label" %>
                  <%= f.date_field :acceptance_date, class: "form-input" %>
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :warranty_period, "质保期", class: "form-label" %>
                  <%= f.text_field :warranty_period, class: "form-input", placeholder: "例如：12个月" %>
                </div>
                <div>
                  <%= f.label :warranty_end_date, "质保期截止日期", class: "form-label" %>
                  <%= f.date_field :warranty_end_date, class: "form-input" %>
                </div>
              </div>
              
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">跟进记录</h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :last_contact_date, "最后联系日期", class: "form-label" %>
                  <%= f.date_field :last_contact_date, class: "form-input" %>
                </div>
                <div>
                  <%= f.label :next_follow_up_date, "下次跟进日期", class: "form-label" %>
                  <%= f.date_field :next_follow_up_date, class: "form-input" %>
                  <p class="form-help">系统将在该日期前提醒</p>
                </div>
              </div>
              
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">证据材料</h3>
              
              <div>
                <%= f.label :delivery_proofs, "交付凭证", class: "form-label" %>
                <% if @contract.persisted? && @contract.delivery_proofs.attached? %>
                  <div class="mb-3 p-3 bg-surface-elevated rounded">
                    <p class="text-sm text-muted mb-2">已上传文件：</p>
                    <div class="flex flex-col gap-2">
                      <% @contract.delivery_proofs.each do |file| %>
                        <%= smart_file_link(file, show_size: true, action_buttons: true, deletable: true) %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
                <%= f.file_field :delivery_proofs, multiple: true, class: "form-input" %>
                <p class="form-help">签收单、验收报告等<%= @contract.persisted? ? "（选择文件将追加到现有文件）" : "" %></p>
              </div>
              
              <div>
                <%= f.label :payment_proofs, "付款/收款凭证", class: "form-label" %>
                <% if @contract.persisted? && @contract.payment_proofs.attached? %>
                  <div class="mb-3 p-3 bg-surface-elevated rounded">
                    <p class="text-sm text-muted mb-2">已上传文件：</p>
                    <div class="flex flex-col gap-2">
                      <% @contract.payment_proofs.each do |file| %>
                        <%= smart_file_link(file, show_size: true, action_buttons: true, deletable: true) %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
                <%= f.file_field :payment_proofs, multiple: true, class: "form-input" %>
                <p class="form-help">转账凭证、发票等<%= @contract.persisted? ? "（选择文件将追加到现有文件）" : "" %></p>
              </div>
              
              <div>
                <%= f.label :correspondence_files, "往来函件", class: "form-label" %>
                <% if @contract.persisted? && @contract.correspondence_files.attached? %>
                  <div class="mb-3 p-3 bg-surface-elevated rounded">
                    <p class="text-sm text-muted mb-2">已上传文件：</p>
                    <div class="flex flex-col gap-2">
                      <% @contract.correspondence_files.each do |file| %>
                        <%= smart_file_link(file, show_size: true, action_buttons: true, deletable: true) %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
                <%= f.file_field :correspondence_files, multiple: true, class: "form-input" %>
                <p class="form-help">邮件、通知、函件等<%= @contract.persisted? ? "（选择文件将追加到现有文件）" : "" %></p>
              </div>
              
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">续约管理</h3>
              
              <div class="grid md:grid-cols-3 gap-6">
                <div>
                  <%= f.label :auto_renewal, "是否自动续约", class: "form-label" %>
                  <%= f.select :auto_renewal, [['是', true], ['否', false]], { prompt: "请选择" }, { class: "form-select" } %>
                </div>
                <div>
                  <%= f.label :renewal_notice_period, "不续约通知期（天）", class: "form-label" %>
                  <%= f.number_field :renewal_notice_period, min: 1, class: "form-input", placeholder: "例如：30" %>
                  <p class="form-help">到期前多少天需通知对方</p>
                </div>
                <div>
                  <%= f.label :renewal_intention, "续约意向", class: "form-label" %>
                  <%= f.select :renewal_intention, ['续约', '不续约', '待定'], { prompt: "请选择" }, { class: "form-select" } %>
                </div>
              </div>
              
              <div>
                <%= f.label :renewal_notes, "续约备注", class: "form-label" %>
                <%= f.text_area :renewal_notes, rows: 2, class: "form-textarea" %>
              </div>
            </div>
            
            <!-- 风险管控 Tab -->
            <div id="risk-panel" 
                 role="tabpanel"
                 data-tabs-target="panel"
                 data-tab="risk"
                 class="tab-content hidden space-y-6">
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2">律师审查</h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :legal_review_status, "审查状态", class: "form-label" %>
                  <%= f.select :legal_review_status, 
                      ['待审查', '已审查', '有风险', '高风险'],
                      {},
                      { class: "form-select" } %>
                </div>
                <div>
                  <%= f.label :legal_risk_level, "风险等级", class: "form-label" %>
                  <%= f.select :legal_risk_level, 
                      ['低', '中', '高', '极高'],
                      { prompt: "请选择" },
                      { class: "form-select" } %>
                </div>
              </div>
              
              <div>
                <%= f.label :legal_risk_summary, "风险摘要", class: "form-label" %>
                <%= f.text_area :legal_risk_summary, rows: 3, class: "form-textarea", placeholder: "律师审查发现的主要风险点" %>
              </div>
              
              <div>
                <%= f.label :lawyer_suggestions, "律师建议", class: "form-label" %>
                <%= f.text_area :lawyer_suggestions, rows: 3, class: "form-textarea", placeholder: "律师给出的建议和注意事项" %>
              </div>
              
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">违约责任</h3>
              
              <div>
                <%= f.label :penalty_clause, "违约金条款", class: "form-label" %>
                <%= f.text_area :penalty_clause, rows: 3, class: "form-textarea", placeholder: "合同中约定的违约金条款内容" %>
              </div>
              
              <div>
                <%= f.label :liquidated_damages, "约定违约金金额", class: "form-label" %>
                <%= f.number_field :liquidated_damages, step: 0.01, class: "form-input", placeholder: "0.00" %>
                <p class="form-help">如有明确金额，请填写</p>
              </div>
              
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">争议解决</h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :dispute_resolution, "争议解决方式", class: "form-label" %>
                  <%= f.select :dispute_resolution, 
                      ['协商', '调解', '仲裁', '诉讼'],
                      { prompt: "请选择" },
                      { class: "form-select" } %>
                </div>
                <div>
                  <%= f.label :arbitration_institution, "仲裁机构", class: "form-label" %>
                  <%= f.text_field :arbitration_institution, class: "form-input", placeholder: "如选择仲裁，请填写仲裁机构" %>
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :jurisdiction_court, "管辖法院", class: "form-label" %>
                  <%= f.text_field :jurisdiction_court, class: "form-input", placeholder: "如选择诉讼，请填写管辖法院" %>
                </div>
                <div>
                  <%= f.label :applicable_law, "适用法律", class: "form-label" %>
                  <%= f.text_field :applicable_law, class: "form-input", placeholder: "涉外合同填写" %>
                </div>
              </div>
              
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">争议与诉讼</h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :dispute_status, "争议状态", class: "form-label" %>
                  <%= f.select :dispute_status, 
                      ['无争议', '协商中', '调解中', '仲裁中', '诉讼中', '已结案'],
                      {},
                      { class: "form-select" } %>
                </div>
                <div>
                  <%= f.label :dispute_occurred_at, "争议发生日期", class: "form-label" %>
                  <%= f.date_field :dispute_occurred_at, class: "form-input" %>
                </div>
              </div>
              
              <% if lawyer? %>
                <div>
                  <%= f.label :related_case_id, "关联案件ID", class: "form-label" %>
                  <%= f.number_field :related_case_id, class: "form-input", placeholder: "如已立案，填写案件ID" %>
                  <p class="form-help">关联到案件管理模块中的案件</p>
                </div>
              <% end %>
              
              <div>
                <%= f.label :litigation_amount, "诉讼标的额", class: "form-label" %>
                <%= f.number_field :litigation_amount, step: 0.01, class: "form-input", placeholder: "0.00" %>
              </div>
              
              <div>
                <%= f.label :litigation_notes, "诉讼备注", class: "form-label" %>
                <%= f.text_area :litigation_notes, rows: 3, class: "form-textarea" %>
              </div>
            </div>
            
            <!-- 内部管理 Tab -->
            <div id="internal-panel" 
                 role="tabpanel"
                 data-tabs-target="panel"
                 data-tab="internal"
                 class="tab-content hidden space-y-6">
              <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2">客户对接</h3>
              
              <div class="grid md:grid-cols-3 gap-6">
                <div>
                  <%= f.label :client_contact, "客户联系人", class: "form-label" %>
                  <%= f.text_field :client_contact, class: "form-input" %>
                  <p class="form-help">企业方对接人</p>
                </div>
                <div>
                  <%= f.label :client_contact_phone, "联系人电话", class: "form-label" %>
                  <%= f.text_field :client_contact_phone, class: "form-input" %>
                </div>
                <div>
                  <%= f.label :client_dept, "所属部门", class: "form-label" %>
                  <%= f.text_field :client_dept, class: "form-input" %>
                </div>
              </div>
              
              <% if lawyer? %>
                <h3 class="font-heading text-lg font-semibold text-primary border-b pb-2 mt-8">律师分工</h3>
                
                <div>
                  <%= f.label :assigned_lawyer_id, "指派律师（主办）", class: "form-label" %>
                  <%= f.select :assigned_lawyer_id, 
                      LawyerAccount.where(role: ['lawyer', 'senior_lawyer', 'team_leader']).order(:name).map { |l| ["#{l.name}（#{l.role_display}）", l.id] },
                      { prompt: "请选择主办律师" },
                      { class: "form-select" } %>
                </div>
                
                <div>
                  <%= f.label :assistant_lawyer_ids, "律师助理", class: "form-label" %>
                  <%= f.select :assistant_lawyer_ids, 
                      LawyerAccount.where(role: 'assistant').order(:name).map { |l| [l.name, l.id] },
                      { prompt: "请选择律师助理（可多选）" },
                      { class: "form-select", multiple: true } %>
                  <p class="form-help">可按住 Ctrl/Cmd 键选择多个律师助理</p>
                </div>
                
                <div>
                  <%= f.label :internal_notes, "内部备注", class: "form-label" %>
                  <%= f.text_area :internal_notes, rows: 4, class: "form-textarea", placeholder: "仅律师内部可见的备注信息" %>
                  <p class="form-help">⚠️ 该信息仅律师可见，客户无法查看</p>
                </div>
              <% end %>
              
              <div>
                <%= f.label :reconciliation_cycle_days, "对账周期 (天)", class: "form-label" %>
                <div class="space-y-3">
                  <div class="flex flex-wrap gap-2" data-controller="reconciliation-cycle">
                    <button type="button" data-action="click->reconciliation-cycle#selectCycle" data-days="30" 
                      class="px-4 py-2 rounded-lg border border-border bg-surface hover:bg-primary hover:text-white hover:border-primary transition-colors">
                      30天
                    </button>
                    <button type="button" data-action="click->reconciliation-cycle#selectCycle" data-days="45" 
                      class="px-4 py-2 rounded-lg border border-border bg-surface hover:bg-primary hover:text-white hover:border-primary transition-colors">
                      45天
                    </button>
                    <button type="button" data-action="click->reconciliation-cycle#selectCycle" data-days="60" 
                      class="px-4 py-2 rounded-lg border border-border bg-surface hover:bg-primary hover:text-white hover:border-primary transition-colors">
                      60天
                    </button>
                    <button type="button" data-action="click->reconciliation-cycle#selectCycle" data-days="90" 
                      class="px-4 py-2 rounded-lg border border-border bg-surface hover:bg-primary hover:text-white hover:border-primary transition-colors">
                      90天
                    </button>
                  </div>
                  <%= f.number_field :reconciliation_cycle_days, 
                      data: { reconciliation_cycle_target: "input" },
                      placeholder: "或手动输入天数...", 
                      min: 1, 
                      class: "form-input" %>
                  <p class="form-help">设置合同对账周期，例如每30天对账一次</p>
                </div>
              </div>
            </div>
          </div>

          <div class="flex gap-3 pt-6 border-t border-border">
            <%= f.submit @contract.persisted? ? '更新档案' : '创建档案', class: "btn-primary" %>
            <%= link_to "取消", @contract.persisted? ? contract_path(@contract) : contracts_path, class: "btn-outline" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>


