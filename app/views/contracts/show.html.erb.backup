<% 
  # ==========================================
  # PERFORMANCE OPTIMIZATION
  # ==========================================
  # Batch preload ALL attachments' blob data (avoid N+1 queries for file metadata)
  all_attachment_ids = [
    @contract.file.attached? ? @contract.file.id : nil,
    @contract.reconciliations.flat_map { |r| r.attachments.attached? ? r.attachments.map(&:id) : [] },
    @comments.flat_map { |c| c.attachments.attached? ? c.attachments.map(&:id) : [] }
  ].flatten.compact
  
  if all_attachment_ids.any?
    ActiveStorage::Attachment.includes(:blob).where(id: all_attachment_ids).load
  end
%>

<% if @user_mode == :lawyer %>
  <%= render 'contracts/show_lawyer_mode' %>
<% else %>
  <%= render 'contracts/show_company_mode' %>
<% end %>
