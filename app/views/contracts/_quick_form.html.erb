<div class="min-h-screen bg-surface py-8">
  <div class="container-md mx-auto px-6">
    <div class="mb-6">
      <%= link_to contracts_path, class: "inline-flex items-center gap-2 text-secondary hover:text-primary transition-colors" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4" %>
        <span>返回列表</span>
      <% end %>
    </div>

    <div class="card card-elevated max-w-3xl mx-auto">
      <div class="card-header border-b border-border">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="font-heading text-2xl font-bold text-primary">快速创建合同档案</h2>
            <p class="text-sm text-secondary mt-1">只需填写核心信息，3分钟完成创建</p>
          </div>
          <%= link_to new_contract_path(mode: 'full'), class: "btn-ghost btn-sm" do %>
            <%= lucide_icon "settings", class: "w-4 h-4" %>
            <span>切换到完整模式</span>
          <% end %>
        </div>
      </div>
      
      <div class="card-body">
        <div class="mb-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
          <div class="flex items-start gap-3">
            <%= lucide_icon "info", class: "w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" %>
            <div class="flex-1">
              <p class="text-sm font-semibold text-blue-900 mb-1">💡 快速创建模式</p>
              <p class="text-sm text-blue-800">
                只需填写10个核心字段即可创建合同档案。创建后，您可以随时在详情页补充完整信息。
              </p>
            </div>
          </div>
        </div>

        <%= form_with model: @contract, class: "space-y-6", multipart: true do |f| %>
          <%= f.hidden_field :mode, value: 'quick' %>
          
          <% if lawyer? %>
            <div class="form-group">
              <%= f.label :company_id, class: "form-label" do %>
                <span>所属企业</span>
                <span class="text-red-600 ml-1">*</span>
              <% end %>
              <%= f.select :company_id, 
                  options_for_select(@companies.map { |c| [c.name, c.id] }, @selected_company&.id),
                  { prompt: "请选择企业" },
                  { class: "form-select", required: true } %>
              <p class="form-help">选择该合同所属的企业</p>
            </div>
          <% end %>

          <div class="form-group">
            <%= f.label :name, class: "form-label" do %>
              <span>合同档案名称</span>
              <span class="text-red-600 ml-1">*</span>
            <% end %>
            <%= f.text_field :name, 
                required: true, 
                class: "form-input", 
                placeholder: "例如：与XX公司的采购合同" %>
            <p class="form-help">用于内部管理的档案名称</p>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div class="form-group">
              <%= f.label :contract_type, class: "form-label" do %>
                <span>合同类型</span>
                <span class="text-red-600 ml-1">*</span>
              <% end %>
              <%= f.select :contract_type, 
                  ['买卖合同', '服务合同', '租赁合同', '借款合同', '建设工程合同', '技术合同', '承揽合同', '运输合同', '保管合同', '委托合同', '其他'],
                  { prompt: "请选择合同类型" },
                  { class: "form-select", required: true } %>
            </div>

            <div class="form-group">
              <%= f.label :contract_number, class: "form-label" do %>
                <span>合同编号</span>
              <% end %>
              <%= f.text_field :contract_number, 
                  class: "form-input", 
                  placeholder: "例如：2024-HT-001" %>
              <p class="form-help">企业内部合同编号（选填）</p>
            </div>
          </div>

          <div class="border-t border-border pt-6 mt-6">
            <h3 class="font-heading text-lg font-semibold text-primary mb-4">合同双方</h3>
            
            <div class="grid md:grid-cols-2 gap-6">
              <div class="form-group">
                <%= f.label :our_party_role, class: "form-label" do %>
                  <span>我方地位</span>
                  <span class="text-red-600 ml-1">*</span>
                <% end %>
                <%= f.text_field :our_party_role, 
                    required: true, 
                    class: "form-input", 
                    placeholder: "例如：买方、甲方、承租方" %>
              </div>

              <div class="form-group">
                <%= f.label :counterparty_name, class: "form-label" do %>
                  <span>对方名称</span>
                  <span class="text-red-600 ml-1">*</span>
                <% end %>
                <%= f.text_field :counterparty_name, 
                    required: true, 
                    class: "form-input", 
                    placeholder: "对方公司或个人名称" %>
              </div>
            </div>

            <div class="form-group">
              <%= f.label :counterparty_role, class: "form-label" do %>
                <span>对方地位</span>
                <span class="text-red-600 ml-1">*</span>
              <% end %>
              <%= f.text_field :counterparty_role, 
                  required: true, 
                  class: "form-input", 
                  placeholder: "例如：卖方、乙方、出租方" %>
            </div>
          </div>

          <div class="border-t border-border pt-6 mt-6">
            <h3 class="font-heading text-lg font-semibold text-primary mb-4">日期与状态</h3>
            
            <div class="grid md:grid-cols-3 gap-6">
              <div class="form-group">
                <%= f.label :signed_at, class: "form-label" do %>
                  <span>签订日期</span>
                  <span class="text-red-600 ml-1">*</span>
                <% end %>
                <%= f.date_field :signed_at, 
                    required: true, 
                    class: "form-input",
                    value: @contract.signed_at || Date.today %>
              </div>

              <div class="form-group">
                <%= f.label :end_at, class: "form-label" do %>
                  <span>到期日期</span>
                  <span class="text-red-600 ml-1">*</span>
                <% end %>
                <%= f.date_field :end_at, 
                    required: true, 
                    class: "form-input",
                    value: @contract.end_at || 1.year.from_now.to_date %>
              </div>

              <div class="form-group">
                <%= f.label :status, class: "form-label" do %>
                  <span>合同状态</span>
                  <span class="text-red-600 ml-1">*</span>
                <% end %>
                <%= f.select :status, 
                    [['执行中', 'active'], ['已完成', 'completed'], ['已违约', 'breach'], ['诉讼中', 'litigation']], 
                    { selected: @contract.status || 'active' },
                    { class: "form-select", required: true } %>
              </div>
            </div>
          </div>

          <div class="border-t border-border pt-6 mt-6">
            <h3 class="font-heading text-lg font-semibold text-primary mb-4">合同文件</h3>
            
            <div class="form-group">
              <%= f.label :file, class: "form-label" do %>
                <span>主合同文件（PDF）</span>
                <span class="text-red-600 ml-1">*</span>
              <% end %>
              <%= f.file_field :file, 
                  accept: 'application/pdf', 
                  class: "form-input", 
                  required: !@contract.persisted? %>
              <p class="form-help">请上传双方盖章的PDF扫描版</p>
              <% if @contract.file.attached? %>
                <div class="mt-2 flex items-center gap-2 text-sm text-success">
                  <%= lucide_icon "check-circle", class: "w-4 h-4" %>
                  <span>已上传：<%= @contract.file.filename %></span>
                </div>
              <% end %>
            </div>
          </div>

          <div class="border-t border-border pt-6 mt-6 flex items-center justify-between">
            <div class="flex gap-3">
              <%= f.submit "快速创建", 
                  class: "btn-primary",
                  data: { turbo_submits_with: "创建中..." } %>
              
              <%= link_to contracts_path, class: "btn-ghost" do %>
                <span>取消</span>
              <% end %>
            </div>

            <%= link_to new_contract_path(mode: 'full'), class: "text-sm text-secondary hover:text-primary flex items-center gap-2" do %>
              <%= lucide_icon "settings", class: "w-4 h-4" %>
              <span>需要填写完整信息？切换到完整模式</span>
            <% end %>
          </div>

          <div class="bg-gray-50 rounded-lg p-4 text-sm text-secondary">
            <p class="flex items-start gap-2">
              <%= lucide_icon "lightbulb", class: "w-4 h-4 flex-shrink-0 mt-0.5" %>
              <span>
                <strong>提示：</strong>创建后您可以在合同详情页补充更多信息，包括金额、付款方式、履行跟踪、风险管控等详细内容。
              </span>
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
