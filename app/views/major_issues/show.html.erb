<div class="container-main">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm text-secondary mb-4">
    <%= link_to major_issues_path, class: "hover:text-primary" do %>
      重大事项研讨
    <% end %>
    <%= lucide_icon "chevron-right", class: "w-4 h-4" %>
    <span><%= truncate(@major_issue.title, length: 40) %></span>
  </div>

  <!-- Page Header -->
  <div class="flex items-start justify-between mb-6">
    <div class="flex-1">
      <div class="flex items-center gap-3 mb-2">
        <h1 class="font-heading text-3xl font-bold text-primary"><%= @major_issue.title %></h1>
        
        <!-- Status Badge -->
        <% status_class = case @major_issue.status
             when 'pending' then 'badge-warning'
             when 'discussing' then 'badge-info'
             when 'resolved' then 'badge-success'
             when 'archived' then 'badge-secondary'
             else 'badge-secondary'
             end %>
        <span class="badge <%= status_class %> badge-lg"><%= @major_issue.status_display %></span>
        
        <!-- Lawyer Review Status Badge -->
        <% if @major_issue.reviewed_by_lawyer %>
          <span class="badge badge-success badge-lg">已答复</span>
        <% elsif lawyer? %>
          <span class="badge badge-warning badge-lg">待答复</span>
        <% end %>
        
        <!-- Priority Badge -->
        <% priority_class = case @major_issue.priority
             when 'low' then 'badge-secondary'
             when 'medium' then 'badge-info'
             when 'high' then 'badge-warning'
             when 'urgent' then 'badge-danger'
             else 'badge-secondary'
             end %>
        <span class="badge <%= priority_class %> badge-lg">优先级: <%= @major_issue.priority_display %></span>
      </div>
      
      <div class="flex items-center gap-4 text-sm text-secondary">
        <span><%= lucide_icon "tag", class: "w-4 h-4 inline mr-1" %><%= @major_issue.issue_type %></span>
        <% if @major_issue.mentioned_lawyer.present? %>
          <span><%= lucide_icon "at-sign", class: "w-4 h-4 inline mr-1" %>@<%= @major_issue.mentioned_lawyer.name %></span>
        <% end %>
        <span><%= lucide_icon "calendar", class: "w-4 h-4 inline mr-1" %>创建于 <%= l(@major_issue.created_at, format: :long) %></span>
      </div>
    </div>
    
    <% if lawyer? && !@major_issue.reviewed_by_lawyer %>
      <%= link_to mark_as_reviewed_major_issue_path(@major_issue),
        data: { turbo_method: :post, turbo_confirm: "确认标记此重大事项为已答复？" },
        class: "btn btn-success btn-sm" do %>
        <%= lucide_icon "check-circle", class: "w-4 h-4" %>
        <span>标记为已答复</span>
      <% end %>
    <% end %>
  </div>

  <!-- Main Content Grid -->
  <div class="grid lg:grid-cols-3 gap-6">
    <!-- Left Column: Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Description Section -->
      <div class="card card-elevated">
        <div class="card-header">
          <h2 class="card-title">事项描述</h2>
        </div>
        <div class="card-body">
          <div class="prose prose-sm max-w-none">
            <%= simple_format(@major_issue.description) %>
          </div>
        </div>
      </div>

      <!-- Conclusion Section -->
      <div class="card card-elevated">
        <div class="card-header">
          <h2 class="card-title">
            <%= lucide_icon "file-check", class: "w-5 h-5 mr-2" %>
            事项结论
          </h2>
        </div>
        <div class="card-body">
          <% if @major_issue.has_conclusion? %>
            <!-- 显示现有结论 -->
            <div class="bg-surface-secondary rounded-lg p-4 mb-4">
              <div class="prose prose-sm max-w-none mb-3">
                <%= simple_format(@major_issue.conclusion) %>
              </div>
              <div class="flex items-center gap-2 text-sm text-secondary">
                <% if @major_issue.conclusion_updated_by %>
                  <span>
                    <%= lucide_icon "user", class: "w-4 h-4 inline" %>
                    <%= @major_issue.conclusion_updated_by.try(:name) || @major_issue.conclusion_updated_by.try(:display_name) %>
                  </span>
                <% end %>
                <% if @major_issue.conclusion_updated_at %>
                  <span>
                    <%= lucide_icon "clock", class: "w-4 h-4 inline" %>
                    <%= l(@major_issue.conclusion_updated_at, format: :long) %>
                  </span>
                <% end %>
              </div>
            </div>
            
            <!-- 更新结论表单 -->
            <% if lawyer? %>
              <details class="border-t pt-4">
                <summary class="cursor-pointer font-semibold text-primary mb-3">更新结论</summary>
                <%= form_with url: update_conclusion_major_issue_path(@major_issue), method: :patch, local: true do |f| %>
                  <div class="form-group">
                    <%= label_tag "conclusion", "结论内容", class: "form-label" %>
                    <%= text_area_tag "conclusion", @major_issue.conclusion,
                        class: "form-textarea", 
                        rows: 4, 
                        placeholder: "请输入更新后的结论...",
                        required: true %>
                  </div>
                  <div class="flex justify-end">
                    <%= f.submit "保存结论", class: "btn btn-primary" %>
                  </div>
                <% end %>
              </details>
            <% end %>
          <% else %>
            <!-- 添加结论表单 -->
            <% if lawyer? %>
              <p class="text-secondary text-sm mb-4">此重大事项尚未添加结论，请添加结论以便后续查阅。</p>
              <%= form_with url: update_conclusion_major_issue_path(@major_issue), method: :patch, local: true do |f| %>
                <div class="form-group">
                  <%= label_tag "conclusion", "结论内容", class: "form-label" %>
                  <%= text_area_tag "conclusion", nil,
                      class: "form-textarea", 
                      rows: 4, 
                      placeholder: "请输入事项结论...",
                      required: true %>
                </div>
                <div class="flex justify-end">
                  <%= f.submit "添加结论", class: "btn btn-primary" %>
                </div>
              <% end %>
            <% else %>
              <p class="text-secondary text-center py-4">暂无结论</p>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Execution Tasks Section -->
      <div class="card card-elevated">
        <div class="card-header">
          <h2 class="card-title">
            <%= lucide_icon "list-checks", class: "w-5 h-5 mr-2" %>
            执行任务 (<%= @major_issue.todo_items.count %>)
          </h2>
        </div>
        <div class="card-body">
          <% if @major_issue.todo_items.any? %>
            <!-- 任务列表 -->
            <div class="space-y-3 mb-6">
              <% @major_issue.todo_items.order(created_at: :desc).each do |todo| %>
                <div class="flex items-start gap-3 p-4 bg-surface-secondary rounded-lg border <%= todo.status == 'completed' ? 'border-green-200 dark:border-green-800' : 'border-border' %>">
                  <!-- Checkbox -->
                  <div class="mt-1">
                    <%= button_to complete_todo_item_major_issue_path(@major_issue, todo_id: todo.id),
                        method: :patch,
                        data: { turbo_method: :patch },
                        class: "bg-transparent border-0 p-0 cursor-pointer",
                        disabled: todo.status == 'completed' do %>
                      <% if todo.status == 'completed' %>
                        <%= lucide_icon "check-circle", class: "w-6 h-6 text-green-600" %>
                      <% else %>
                        <%= lucide_icon "circle", class: "w-6 h-6 text-gray-400 hover:text-primary" %>
                      <% end %>
                    <% end %>
                  </div>
                  
                  <!-- Task Content -->
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-2 mb-2">
                      <h4 class="font-semibold text-primary <%= todo.status == 'completed' ? 'line-through opacity-60' : '' %>">
                        <%= todo.title %>
                      </h4>
                      <% if current_lawyer || (current_company_user && todo.creator_id == current_company_user.id) %>
                        <%= button_to delete_todo_item_major_issue_path(@major_issue, todo_id: todo.id),
                            method: :delete,
                            data: { turbo_method: :delete, turbo_confirm: "确定删除该任务吗？" },
                            class: "text-danger hover:text-danger-hover p-1" do %>
                          <%= lucide_icon "trash-2", class: "w-4 h-4" %>
                        <% end %>
                      <% end %>
                    </div>
                    
                    <% if todo.description.present? %>
                      <p class="text-sm text-secondary mb-2 <%= todo.status == 'completed' ? 'line-through opacity-60' : '' %>">
                        <%= todo.description %>
                      </p>
                    <% end %>
                    
                    <div class="flex flex-wrap items-center gap-3 text-xs text-secondary">
                      <% if todo.assignee %>
                        <span class="flex items-center gap-1">
                          <%= lucide_icon "user", class: "w-3 h-3" %>
                          <%= todo.assignee.try(:name) || todo.assignee.try(:display_name) %>
                        </span>
                      <% end %>
                      
                      <% if todo.due_date %>
                        <% overdue = todo.overdue? %>
                        <span class="flex items-center gap-1 <%= overdue ? 'text-danger' : '' %>">
                          <%= lucide_icon "calendar", class: "w-3 h-3" %>
                          <%= todo.due_date.strftime('%Y-%m-%d') %>
                          <% if overdue %>
                            <span class="ml-1">（已逾期）</span>
                          <% end %>
                        </span>
                      <% end %>
                      
                      <% if todo.status == 'completed' && todo.completed_at %>
                        <span class="flex items-center gap-1 text-green-600">
                          <%= lucide_icon "check", class: "w-3 h-3" %>
                          <%= todo.completed_at.strftime('%Y-%m-%d') %> 已完成
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-secondary text-center py-4">暂无执行任务</p>
          <% end %>
          
          <!-- Add New Task Form -->
          <% if current_lawyer || current_company_user %>
            <div class="border-t pt-4">
              <h4 class="font-semibold text-primary mb-3">添加执行任务</h4>
              <%= form_with url: create_todo_item_major_issue_path(@major_issue), method: :post, class: "space-y-4" do |f| %>
                <div class="grid md:grid-cols-2 gap-4">
                  <div class="form-control">
                    <%= label_tag "title", "任务标题", class: "form-label required" %>
                    <%= text_field_tag "title", nil, class: "form-input", placeholder: "例如：起草补充协议", required: true %>
                  </div>
                  
                  <div class="form-control">
                    <%= label_tag "due_date", "截止日期", class: "form-label" %>
                    <%= date_field_tag "due_date", nil, class: "form-input" %>
                  </div>
                </div>
                
                <div class="form-control">
                  <%= label_tag "description", "任务描述", class: "form-label" %>
                  <%= text_area_tag "description", nil, class: "form-textarea", rows: 2, placeholder: "请输入任务详情（可选）" %>
                </div>
                
                <div class="form-control">
                  <%= label_tag "assignee_type", "指派给", class: "form-label" %>
                  <%= select_tag "assignee_type",
                      options_for_select([
                        ["不指派", ""],
                        ["律师", "LawyerAccount"],
                        ["企业用户", "CompanyUser"]
                      ]),
                      class: "form-select" %>
                </div>
                
                <div class="form-control" id="assignee-id-container" style="display: none;">
                  <%= label_tag "assignee_id", "选择人员", class: "form-label" %>
                  <%= select_tag "assignee_id", "", class: "form-select" %>
                </div>
                
                <%= f.submit "添加任务", class: "btn-primary" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Attachments Section -->
      <% if @major_issue.attachments.attached? %>
        <div class="card card-elevated">
          <div class="card-header">
            <h2 class="card-title">
              <%= lucide_icon "paperclip", class: "w-5 h-5 mr-2" %>
              相关材料 (<%= @major_issue.attachments.count %>)
            </h2>
          </div>
          <div class="card-body">
            <div class="space-y-2">
              <% @major_issue.attachments.each do |attachment| %>
                <%= smart_file_link(attachment, action_buttons: true, show_size: true, css_class: "p-3 bg-surface-secondary rounded-lg w-full", deletable: true) %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Comments Section -->
      <div class="card card-elevated" 
           data-controller="major-issue"
           data-major-issue-stream-name-value="major_issue_<%= @major_issue.id %>"
           data-major-issue-current-user-name-value="<%= (current_lawyer || current_company_user)&.display_name %>"
           data-major-issue-current-user-role-value="<%= (current_lawyer&.role || current_company_user&.role) %>">
        <div class="card-header">
          <h2 class="card-title">
            <%= lucide_icon "message-square", class: "w-5 h-5 mr-2" %>
            讨论意见 (<%= @comments.count %>)
          </h2>
        </div>
        <div class="card-body">
          <!-- 打字提示 -->
          <div data-major-issue-target="typingIndicator" class="hidden text-sm text-secondary italic mb-2"></div>
          
          <!-- 评论列表 -->
          <div data-major-issue-target="commentsList" class="space-y-4 mb-6 max-h-[500px] overflow-y-auto">
            <% if @comments.any? %>
              <!-- 置顶评论 -->
              <% pinned_comments = @comments.select(&:is_pinned) %>
              <% if pinned_comments.any? %>
                <div class="mb-6">
                  <h4 class="text-sm font-semibold text-secondary mb-3 flex items-center gap-2">
                    <%= lucide_icon "pin", class: "w-4 h-4" %>
                    置顶评论
                  </h4>
                  <% pinned_comments.each do |comment| %>
                    <div class="comment-item border-l-4 border-yellow-500 bg-yellow-50 pl-4 py-2 mb-3">
                      <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2">
                          <span class="badge badge-warning badge-sm">置顶</span>
                          <span class="font-semibold text-primary"><%= comment.author_name %></span>
                          <%= comment_author_role_badge(comment.author_role) %>
                          <span class="text-sm text-secondary"><%= time_ago_in_words(comment.created_at) %>前</span>
                        </div>
                        <div class="flex items-center gap-2">
                          <% if lawyer? %>
                            <%= link_to unpin_comment_path(comment),
                                data: { turbo_method: :post, turbo_confirm: "确认取消置顶？" },
                                class: "text-secondary hover:text-primary text-xs",
                                title: "取消置顶" do %>
                              <%= lucide_icon "pin-off", class: "w-4 h-4" %>
                            <% end %>
                          <% end %>
                          <% current_user = current_lawyer || current_company_user %>
                          <% if comment.deletable_by?(current_user) %>
                            <%= link_to comment_path(comment), 
                              data: { turbo_method: :delete, turbo_confirm: "确定删除该评论吗？" },
                              class: "text-danger hover:text-danger-hover text-xs",
                              title: "删除评论（30分钟内可删）" do %>
                              <%= lucide_icon "trash-2", class: "w-4 h-4" %>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                      <div class="prose prose-sm">
                        <%= simple_format(comment.content) %>
                      </div>
                      <% if comment.attachments.attached? %>
                        <div class="flex flex-col gap-2 mt-3">
                          <% comment.attachments.each do |attachment| %>
                            <%= smart_file_link(attachment, action_buttons: true, show_size: true, deletable: true) %>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
              
              <!-- 关键意见评论 -->
              <% key_opinion_comments = @comments.select { |c| c.is_key_opinion && !c.is_pinned } %>
              <% if key_opinion_comments.any? %>
                <div class="mb-6">
                  <h4 class="text-sm font-semibold text-secondary mb-3 flex items-center gap-2">
                    <%= lucide_icon "star", class: "w-4 h-4" %>
                    关键意见
                  </h4>
                  <% key_opinion_comments.each do |comment| %>
                    <div class="comment-item border-l-4 border-blue-500 bg-blue-50 pl-4 py-2 mb-3">
                      <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2">
                          <span class="badge badge-info badge-sm">关键意见</span>
                          <span class="font-semibold text-primary"><%= comment.author_name %></span>
                          <%= comment_author_role_badge(comment.author_role) %>
                          <span class="text-sm text-secondary"><%= time_ago_in_words(comment.created_at) %>前</span>
                        </div>
                        <div class="flex items-center gap-2">
                          <% if lawyer? %>
                            <%= link_to pin_comment_path(comment),
                                data: { turbo_method: :post, turbo_confirm: "确认置顶此评论？" },
                                class: "text-secondary hover:text-primary text-xs",
                                title: "置顶" do %>
                              <%= lucide_icon "pin", class: "w-4 h-4" %>
                            <% end %>
                            <%= link_to unmark_as_key_opinion_comment_path(comment),
                                data: { turbo_method: :post, turbo_confirm: "确认取消关键意见标记？" },
                                class: "text-secondary hover:text-primary text-xs",
                                title: "取消关键意见" do %>
                              <%= lucide_icon "star-off", class: "w-4 h-4" %>
                            <% end %>
                          <% end %>
                          <% current_user = current_lawyer || current_company_user %>
                          <% if comment.deletable_by?(current_user) %>
                            <%= link_to comment_path(comment), 
                              data: { turbo_method: :delete, turbo_confirm: "确定删除该评论吗？" },
                              class: "text-danger hover:text-danger-hover text-xs",
                              title: "删除评论（30分钟内可删）" do %>
                              <%= lucide_icon "trash-2", class: "w-4 h-4" %>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                      <div class="prose prose-sm">
                        <%= simple_format(comment.content) %>
                      </div>
                      <% if comment.attachments.attached? %>
                        <div class="flex flex-col gap-2 mt-3">
                          <% comment.attachments.each do |attachment| %>
                            <%= smart_file_link(attachment, action_buttons: true, show_size: true, deletable: true) %>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
              
              <!-- 普通评论 -->
              <% regular_comments = @comments.reject { |c| c.is_pinned || c.is_key_opinion } %>
              <% if regular_comments.any? %>
                <div>
                  <h4 class="text-sm font-semibold text-secondary mb-3">全部意见</h4>
                  <% regular_comments.each do |comment| %>
                    <div class="comment-item border-l-4 border-primary pl-4 py-2 mb-3">
                      <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2">
                          <span class="font-semibold text-primary"><%= comment.author_name %></span>
                          <%= comment_author_role_badge(comment.author_role) %>
                          <span class="text-sm text-secondary"><%= time_ago_in_words(comment.created_at) %>前</span>
                        </div>
                        <div class="flex items-center gap-2">
                          <% if lawyer? %>
                            <%= link_to pin_comment_path(comment),
                                data: { turbo_method: :post, turbo_confirm: "确认置顶此评论？" },
                                class: "text-secondary hover:text-primary text-xs",
                                title: "置顶" do %>
                              <%= lucide_icon "pin", class: "w-4 h-4" %>
                            <% end %>
                            <%= link_to mark_as_key_opinion_comment_path(comment),
                                data: { turbo_method: :post, turbo_confirm: "确认标记为关键意见？" },
                                class: "text-secondary hover:text-primary text-xs",
                                title: "标记为关键意见" do %>
                              <%= lucide_icon "star", class: "w-4 h-4" %>
                            <% end %>
                          <% end %>
                          <% current_user = current_lawyer || current_company_user %>
                          <% if comment.deletable_by?(current_user) %>
                            <%= link_to comment_path(comment), 
                              data: { turbo_method: :delete, turbo_confirm: "确定删除该评论吗？" },
                              class: "text-danger hover:text-danger-hover text-xs",
                              title: "删除评论（30分钟内可删）" do %>
                              <%= lucide_icon "trash-2", class: "w-4 h-4" %>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                      <div class="prose prose-sm">
                        <%= simple_format(comment.content) %>
                      </div>
                      <% if comment.attachments.attached? %>
                        <div class="flex flex-col gap-2 mt-3">
                          <% comment.attachments.each do |attachment| %>
                            <%= smart_file_link(attachment, action_buttons: true, show_size: true, deletable: true) %>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <p class="text-secondary text-center py-4">暂无讨论意见</p>
            <% end %>
          </div>
          <!-- Comment Form -->
          <% if current_lawyer || current_company_user %>
            <div class="border-t pt-4">
              <h3 class="font-semibold text-primary mb-3">发表意见</h3>
              <%= form_with url: major_issue_comments_path(@major_issue), method: :post, local: true, multipart: true do |f| %>
                <div class="form-group">
                  <%= label_tag "comment[content]", "意见内容", class: "form-label" %>
                  <%= text_area_tag "comment[content]", nil,
                      class: "form-textarea", 
                      rows: 4, 
                      placeholder: "请输入您的意见和建议...",
                      required: true,
                      data: { major_issue_target: "commentInput", action: "input->major-issue#onTyping" } %>
                </div>

                <div class="form-group">
                  <%= label_tag "comment[attachments][]", "附件上传 (可选)", class: "form-label" %>
                  <%= file_field_tag "comment[attachments][]", multiple: true, class: "form-input", accept: ".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png" %>
                  <p class="form-help">支持PDF、Word、Excel、图片等格式，单个文件不超过40MB</p>
                </div>

                <div class="flex justify-end">
                  <%= f.submit "提交意见", class: "btn btn-primary" %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Right Column: Sidebar -->
    <div class="space-y-6">
      <!-- Return Button -->
      <%= link_to major_issues_path, class: "btn-outline w-full justify-center" do %>
        <%= lucide_icon "arrow-left", class: "w-5 h-5" %>
        <span>返回列表</span>
      <% end %>
      
      <!-- Timeline Card -->
      <div class="card card-elevated">
        <div class="card-header">
          <h3 class="card-title">
            <%= lucide_icon "clock", class: "w-5 h-5 mr-2" %>
            时间线
          </h3>
        </div>
        <div class="card-body">
          <div class="space-y-4">
            <!-- Created -->
            <div class="flex gap-3">
              <div class="flex flex-col items-center">
                <div class="w-3 h-3 rounded-full bg-primary"></div>
                <div class="w-0.5 h-full bg-border"></div>
              </div>
              <div class="flex-1 pb-4">
                <p class="font-semibold text-primary text-sm">创建</p>
                <p class="text-xs text-secondary"><%= l(@major_issue.created_at, format: :long) %></p>
              </div>
            </div>

            <!-- Resolved -->
            <% if @major_issue.resolved_at.present? %>
              <div class="flex gap-3">
                <div class="flex flex-col items-center">
                  <div class="w-3 h-3 rounded-full bg-green-500"></div>
                  <div class="w-0.5 h-full bg-border"></div>
                </div>
                <div class="flex-1 pb-4">
                  <p class="font-semibold text-primary text-sm">解决</p>
                  <p class="text-xs text-secondary"><%= l(@major_issue.resolved_at, format: :long) %></p>
                </div>
              </div>
            <% end %>

            <!-- Archived -->
            <% if @major_issue.status == 'archived' %>
              <div class="flex gap-3">
                <div class="flex flex-col items-center">
                  <div class="w-3 h-3 rounded-full bg-gray-500"></div>
                </div>
                <div class="flex-1">
                  <p class="font-semibold text-primary text-sm">归档</p>
                  <p class="text-xs text-secondary">状态：已归档</p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Actions Card -->
      <div class="card card-elevated">
        <div class="card-header">
          <h3 class="card-title">快捷操作</h3>
        </div>
        <div class="card-body space-y-2">
          <!-- 状态管理按钮 -->
          <% if @major_issue.may_resolve? %>
            <%= link_to resolve_major_issue_path(@major_issue),
                data: { turbo_method: :post, turbo_confirm: "确认标记此重大事项为已解决？" },
                class: "btn btn-success w-full justify-start" do %>
              <%= lucide_icon "check-circle", class: "w-4 h-4 mr-2" %>
              标记为已解决
            <% end %>
          <% end %>
          
          <% if @major_issue.may_archive? %>
            <%= link_to archive_major_issue_path(@major_issue),
                data: { turbo_method: :post, turbo_confirm: "确认归档此重大事项？" },
                class: "btn btn-secondary w-full justify-start" do %>
              <%= lucide_icon "archive", class: "w-4 h-4 mr-2" %>
              归档事项
            <% end %>
          <% end %>
          
          <% if @major_issue.may_reopen? %>
            <%= link_to reopen_major_issue_path(@major_issue),
                data: { turbo_method: :post, turbo_confirm: "确认重新开启此重大事项？" },
                class: "btn btn-warning w-full justify-start" do %>
              <%= lucide_icon "rotate-ccw", class: "w-4 h-4 mr-2" %>
              重新开启
            <% end %>
          <% end %>
          
          <!-- 分隔线 -->
          <% if @major_issue.may_resolve? || @major_issue.may_archive? || @major_issue.may_reopen? %>
            <div class="border-t border-border my-2"></div>
          <% end %>
          
          <!-- 关注/取消关注按钮 -->
          <% current_actor = current_lawyer || current_company_user %>
          <% if current_actor %>
            <% if @major_issue.followed_by?(current_actor) %>
              <%= link_to unfollow_major_issue_path(@major_issue),
                  data: { turbo_method: :post, turbo_confirm: "确认取消关注？" },
                  class: "btn btn-secondary w-full justify-start" do %>
                <%= lucide_icon "star-off", class: "w-4 h-4 mr-2" %>
                取消关注
              <% end %>
            <% else %>
              <%= link_to follow_major_issue_path(@major_issue),
                  data: { turbo_method: :post },
                  class: "btn btn-info w-full justify-start" do %>
                <%= lucide_icon "star", class: "w-4 h-4 mr-2" %>
                关注此事项
              <% end %>
            <% end %>
            <div class="border-t border-border my-2"></div>
          <% end %>
          
          <%= link_to export_archive_major_issue_path(@major_issue), class: "btn btn-success w-full justify-start" do %>
            <%= lucide_icon "download", class: "w-4 h-4 mr-2" %>
            导出全部资料
          <% end %>
          
          <%= link_to edit_major_issue_path(@major_issue), class: "btn btn-warning w-full justify-start" do %>
            <%= lucide_icon "edit", class: "w-4 h-4 mr-2" %>
            编辑事项
          <% end %>
          
          <%= link_to major_issue_path(@major_issue), 
              data: { turbo_method: :delete, turbo_confirm: '确定要删除这个重大事项吗？此操作不可恢复。' },
              class: "btn btn-danger w-full justify-start" do %>
            <%= lucide_icon "trash-2", class: "w-4 h-4 mr-2" %>
            <span>删除档案</span>
          <% end %>
        </div>
      </div>

      <!-- Info Card -->
      <div class="card card-elevated">
        <div class="card-header">
          <h3 class="card-title">信息</h3>
        </div>
        <div class="card-body space-y-3 text-sm">
          <div>
            <p class="text-secondary mb-1">创建时间</p>
            <p class="text-primary"><%= l(@major_issue.created_at, format: :long) %></p>
          </div>
          <div>
            <p class="text-secondary mb-1">最后更新</p>
            <p class="text-primary"><%= l(@major_issue.updated_at, format: :long) %></p>
          </div>
          <% if @major_issue.reviewed_by_lawyer && @major_issue.reviewed_at %>
            <div>
              <p class="text-secondary mb-1">律师答复时间</p>
              <p class="text-primary"><%= l(@major_issue.reviewed_at, format: :long) %></p>
            </div>
          <% end %>
          <div>
            <p class="text-secondary mb-1">讨论次数</p>
            <p class="text-primary"><%= @comments.count %> 条意见</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
