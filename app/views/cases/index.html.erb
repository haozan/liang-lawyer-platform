<div class="min-h-screen bg-surface py-8">
  <div class="container-xl mx-auto px-6">
    
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="font-heading text-4xl font-bold text-primary mb-2">案件管理</h1>
        <p class="text-secondary">
          <% if @company %>
            <%= @company.name %> · 管理和跟踪所有案件进展
          <% else %>
            全部企业 · 统一管理和跟踪所有案件进展
          <% end %>
        </p>
      </div>
      <div class="flex items-center gap-3">
        <% if current_lawyer %>
          <%= link_to my_cases_cases_path, class: "btn-secondary" do %>
            <%= lucide_icon "user", class: "w-5 h-5" %>
            <span>我的案件</span>
          <% end %>
          <%= link_to my_lead_cases_cases_path, class: "btn-secondary" do %>
            <%= lucide_icon "crown", class: "w-5 h-5" %>
            <span>主办案件</span>
          <% end %>
          <%= link_to team_workload_cases_path, class: "btn-secondary" do %>
            <%= lucide_icon "users", class: "w-5 h-5" %>
            <span>团队工作量</span>
          <% end %>
        <% end %>
        <%= link_to calendar_cases_path, class: "btn-info" do %>
          <%= lucide_icon "calendar-days", class: "w-5 h-5" %>
          <span>日历视图</span>
        <% end %>
        <% if current_lawyer %>
          <%= link_to new_case_path, class: "btn-primary" do %>
            <%= lucide_icon "plus", class: "w-5 h-5" %>
            <span>新建案件</span>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Stats Overview -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
      <div class="card card-elevated">
        <div class="card-body flex items-center gap-3">
          <div class="stat-card-icon bg-primary/10"><%= lucide_icon "briefcase", class: "w-5 h-5 text-primary" %></div>
          <div><p class="stat-card-label">全部案件</p><p class="stat-card-value text-primary"><%= @cases.total_count %></p></div>
        </div>
      </div>
      <div class="card card-elevated">
        <div class="card-body flex items-center gap-3">
          <div class="stat-card-icon bg-warning/10"><%= lucide_icon "file-plus", class: "w-5 h-5 text-warning" %></div>
          <div>
            <p class="stat-card-label">准备立案</p>
            <p class="stat-card-value text-warning">
              <% if @company %><%= @company.cases.not_deleted.where(status: 'preparing').count %><% else %><%= Case.not_deleted.where(status: 'preparing').count %><% end %>
            </p>
          </div>
        </div>
      </div>
      <div class="card card-elevated">
        <div class="card-body flex items-center gap-3">
          <div class="stat-card-icon bg-info/10"><%= lucide_icon "search", class: "w-5 h-5 text-info" %></div>
          <div>
            <p class="stat-card-label">调查中</p>
            <p class="stat-card-value text-info">
              <% if @company %><%= @company.cases.not_deleted.where(status: 'investigating').count %><% else %><%= Case.not_deleted.where(status: 'investigating').count %><% end %>
            </p>
          </div>
        </div>
      </div>
      <div class="card card-elevated">
        <div class="card-body flex items-center gap-3">
          <div class="stat-card-icon bg-warning/10"><%= lucide_icon "gavel", class: "w-5 h-5 text-warning" %></div>
          <div>
            <p class="stat-card-label">审理中</p>
            <p class="stat-card-value text-warning">
              <% if @company %><%= @company.cases.not_deleted.where(status: 'trial').count %><% else %><%= Case.not_deleted.where(status: 'trial').count %><% end %>
            </p>
          </div>
        </div>
      </div>
      <div class="card card-elevated">
        <div class="card-body flex items-center gap-3">
          <div class="stat-card-icon bg-success/10"><%= lucide_icon "archive", class: "w-5 h-5 text-success" %></div>
          <div>
            <p class="stat-card-label">已归档</p>
            <p class="stat-card-value text-success">
              <% if @company %><%= @company.cases.not_deleted.where(status: 'closed').count %><% else %><%= Case.not_deleted.where(status: 'closed').count %><% end %>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Filter Panel -->
    <%= render 'filter_panel' %>

    <!-- Cases List -->
    <% if @cases.any? %>
      <div class="space-y-4">
        <% @cases.each do |kase| %>
          <div class="card card-elevated hover:shadow-lg transition-shadow">
            <div class="card-body">
              <div class="flex items-start justify-between mb-4">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <% if @company.nil? %>
                      <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-sm font-medium text-secondary">
                        <%= lucide_icon "building-2", class: "w-4 h-4 mr-1" %>
                        <%= kase.company.name %>
                      </span>
                    <% end %>
                    <h3 class="font-heading text-xl font-bold text-primary"><%= kase.name %></h3>
                    <% case kase.status %>
                    <% when 'preparing' %>
                      <span class="badge badge-warning">准备立案</span>
                    <% when 'filed' %>
                      <span class="badge badge-info">已立案待审</span>
                    <% when 'trial' %>
                      <span class="badge badge-danger">审理中</span>
                    <% when 'judged' %>
                      <span class="badge badge-primary">已判决</span>
                    <% when 'execution' %>
                      <span class="badge badge-warning">执行中</span>
                    <% when 'settled' %>
                      <span class="badge badge-success">调解结案</span>
                    <% when 'closed' %>
                      <span class="badge badge-neutral">已归档</span>
                    <% end %>
                    <% if kase.stage.present? %>
                      <span class="badge badge-secondary"><%= kase.stage_display %></span>
                    <% end %>
                  </div>
                  <div class="flex items-center gap-4 text-sm text-secondary">
                    <span><%= lucide_icon "hash", class: "w-4 h-4 inline" %> <%= kase.case_number.present? ? kase.case_number : '准备立案' %></span>
                    <span><%= lucide_icon "folder", class: "w-4 h-4 inline" %> <%= kase.case_type %></span>
                    <% if kase.stage.present? %>
                      <span><%= lucide_icon "layers", class: "w-4 h-4 inline" %> <%= kase.stage_display %></span>
                    <% end %>
                    <% if kase.court_name.present? %>
                      <span><%= lucide_icon "landmark", class: "w-4 h-4 inline" %> <%= kase.court_name %></span>
                    <% end %>
                    <% if kase.filing_at.present? %>
                      <span><%= lucide_icon "calendar", class: "w-4 h-4 inline" %> 立案：<%= kase.filing_at.strftime('%Y-%m-%d') %></span>
                    <% end %>
                  </div>
                </div>
                <%= link_to kase, class: "btn-info" do %>
                  <%= lucide_icon "eye", class: "w-5 h-5" %>
                  <span>查看详情</span>
                <% end %>
              </div>
              
              <% if kase.summary.present? %>
                <p class="text-secondary text-sm mb-4"><%= truncate(kase.summary, length: 200) %></p>
              <% end %>

              <div class="flex items-center justify-between text-sm">
                <div class="flex items-center gap-4 text-muted">
                  <% if kase.hearing_at.present? %>
                    <span class="<%= kase.hearing_at < Time.current ? 'text-success' : 'text-warning' %>">
                      <%= lucide_icon "calendar-clock", class: "w-4 h-4 inline" %>
                      开庭：<%= kase.hearing_at.strftime('%Y-%m-%d %H:%M') %>
                    </span>
                  <% end %>
                  <% if kase.judgement_received_at.present? %>
                    <span><%= lucide_icon "file-check", class: "w-4 h-4 inline" %> 领取判决：<%= kase.judgement_received_at.strftime('%Y-%m-%d') %></span>
                  <% end %>
                </div>
                <span class="text-muted">创建于 <%= kase.created_at.strftime('%Y-%m-%d') %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Pagination -->
      <div class="mt-8">
        <%= paginate @cases %>
      </div>
    <% else %>
      <div class="card card-elevated">
        <div class="card-body text-center py-12">
          <%= lucide_icon "briefcase", class: "w-16 h-16 text-muted mx-auto mb-4" %>
          <h3 class="font-heading text-xl font-semibold text-secondary mb-2">暂无案件</h3>
          <p class="text-muted mb-6">点击上方按钮创建第一个案件</p>
          <% if current_lawyer %>
            <%= link_to new_case_path, class: "btn-primary" do %>
              <%= lucide_icon "plus", class: "w-5 h-5" %>
              <span>新建案件</span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
