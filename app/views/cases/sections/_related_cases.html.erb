<details open data-controller="collapsible">
  <summary class="cursor-pointer hover:bg-surface-hover rounded-lg p-4 flex items-center justify-between transition-colors">
    <div class="flex items-center gap-3">
      <%= lucide_icon "git-branch", class: "w-5 h-5 text-primary" %>
      <h4 class="font-semibold text-primary text-lg">关联案件</h4>
      <% total_relations = case_record.case_relations_as_from.count + case_record.case_relations_as_to.count %>
      <% if total_relations > 0 %>
        <span class="badge badge-neutral"><%= total_relations %></span>
      <% end %>
    </div>
    <%= lucide_icon "chevron-down", class: "w-5 h-5 text-secondary transition-transform", data: { collapsible_target: "icon" } %>
  </summary>
  
  <div class="p-4 pt-0" data-collapsible-target="content">
    <% if case_record.case_relations_as_from.any? || case_record.case_relations_as_to.any? %>
      <div class="space-y-3 mb-6">
        <% case_record.case_relations_as_from.each do |relation| %>
          <div class="flex items-center justify-between p-3 bg-surface-hover rounded-lg border border-muted">
            <div class="flex items-center gap-3 flex-1">
              <%= lucide_icon "arrow-right", class: "w-5 h-5 text-primary" %>
              <div class="flex-1">
                <p class="text-sm text-secondary"><%= relation.relation_display %></p>
                <p class="font-semibold text-primary"><%= relation.to_case.name %></p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <%= link_to case_path(relation.to_case), class: "btn-sm btn-outline", target: "_blank" do %>
                <%= lucide_icon "external-link", class: "w-4 h-4" %>
              <% end %>
              <% if current_lawyer %>
                <%= button_to remove_relation_case_path(case_record, relation_id: relation.id),
                    method: :delete,
                    data: { turbo_confirm: '确定取消此关联吗？' },
                    class: "btn-sm btn-outline text-danger hover:bg-danger/10" do %>
                  <%= lucide_icon "x", class: "w-4 h-4" %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
        <% case_record.case_relations_as_to.each do |relation| %>
          <div class="flex items-center justify-between p-3 bg-surface-hover rounded-lg border border-muted">
            <div class="flex items-center gap-3 flex-1">
              <%= lucide_icon "arrow-left", class: "w-5 h-5 text-secondary" %>
              <div class="flex-1">
                <p class="text-sm text-secondary">被关联为 <%= relation.relation_display %></p>
                <p class="font-semibold text-primary"><%= relation.from_case.name %></p>
              </div>
            </div>
            <%= link_to case_path(relation.from_case), class: "btn-sm btn-outline", target: "_blank" do %>
              <%= lucide_icon "external-link", class: "w-4 h-4" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted text-sm mb-6">暂无关联案件</p>
    <% end %>
    
    <% if current_lawyer %>
      <div class="pt-4 border-t border-border">
        <h5 class="font-semibold text-primary mb-4">添加关联案件</h5>
        <%= form_with url: add_relation_case_path(case_record), method: :post, class: "space-y-4" do |f| %>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="form-control">
              <%= label_tag "to_case_id", "选择案件", class: "form-label required" %>
              <%= select_tag "to_case_id", 
                  options_from_collection_for_select(Case.not_deleted.where.not(id: case_record.id).order(name: :asc), :id, :name),
                  { prompt: '请选择要关联的案件', class: "form-select", required: true } %>
            </div>
            
            <div class="form-control">
              <%= label_tag "relation_type", "关系类型", class: "form-label required" %>
              <%= select_tag "relation_type",
                  options_for_select(CaseRelation::RELATION_TYPES.invert),
                  { prompt: '请选择关系类型', class: "form-select", required: true } %>
            </div>
          </div>
          <%= f.submit "添加关联", class: "btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</details>
