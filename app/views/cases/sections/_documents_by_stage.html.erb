<details open data-controller="collapsible">
  <summary class="cursor-pointer hover:bg-surface-hover rounded-lg p-4 flex items-center justify-between transition-colors">
    <div class="flex items-center gap-3">
      <%= lucide_icon "folder-tree", class: "w-5 h-5 text-primary" %>
      <h4 class="font-semibold text-primary text-lg">案件文档（按阶段分类）</h4>
      <% total_count = (case_record.filing_attachments.attached? ? case_record.filing_attachments.count : 0) +
                       (case_record.hearing_attachments.attached? ? case_record.hearing_attachments.count : 0) +
                       (case_record.judgement_attachments.attached? ? case_record.judgement_attachments.count : 0) +
                       (case_record.archived_attachments.attached? ? case_record.archived_attachments.count : 0) +
                       case_record.attachments.count %>
      <% if total_count > 0 %>
        <span class="badge badge-primary"><%= total_count %></span>
      <% end %>
    </div>
    <%= lucide_icon "chevron-down", class: "w-5 h-5 text-secondary transition-transform", data: { collapsible_target: "icon" } %>
  </summary>
  
  <div class="p-4 pt-0 space-y-6" data-collapsible-target="content">
    <!-- 立案材料 -->
    <div class="border border-border rounded-lg p-4">
      <div class="flex items-center gap-2 mb-3">
        <%= lucide_icon "file-plus", class: "w-5 h-5 text-primary" %>
        <h5 class="font-semibold text-primary"><%= case_record.filing_attachment_label || '立案材料' %></h5>
        <% if case_record.filing_attachments.attached? %>
          <span class="badge badge-sm badge-info"><%= case_record.filing_attachments.count %></span>
        <% end %>
      </div>
      <% if case_record.filing_attachments.attached? %>
        <div class="space-y-2">
          <% case_record.filing_attachments.each do |attachment| %>
            <%= smart_file_link(attachment, action_buttons: true, show_size: true, deletable: true) %>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted text-sm text-center py-4">暂无立案材料</p>
      <% end %>
    </div>

    <!-- 开庭材料 -->
    <div class="border border-border rounded-lg p-4">
      <div class="flex items-center gap-2 mb-3">
        <%= lucide_icon "gavel", class: "w-5 h-5 text-primary" %>
        <h5 class="font-semibold text-primary">开庭材料</h5>
        <% if case_record.hearing_attachments.attached? %>
          <span class="badge badge-sm badge-warning"><%= case_record.hearing_attachments.count %></span>
        <% end %>
      </div>
      <% if case_record.hearing_attachments.attached? %>
        <div class="space-y-2">
          <% case_record.hearing_attachments.each do |attachment| %>
            <%= smart_file_link(attachment, action_buttons: true, show_size: true, deletable: true) %>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted text-sm text-center py-4">暂无开庭材料</p>
      <% end %>
    </div>

    <!-- 判决文书 -->
    <div class="border border-border rounded-lg p-4">
      <div class="flex items-center gap-2 mb-3">
        <%= lucide_icon "file-check", class: "w-5 h-5 text-primary" %>
        <h5 class="font-semibold text-primary">判决文书</h5>
        <% if case_record.judgement_attachments.attached? %>
          <span class="badge badge-sm badge-success"><%= case_record.judgement_attachments.count %></span>
        <% end %>
      </div>
      <% if case_record.judgement_attachments.attached? %>
        <div class="space-y-2">
          <% case_record.judgement_attachments.each do |attachment| %>
            <%= smart_file_link(attachment, action_buttons: true, show_size: true, deletable: true) %>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted text-sm text-center py-4">暂无判决文书</p>
      <% end %>
    </div>

    <!-- 归档材料 -->
    <div class="border border-border rounded-lg p-4">
      <div class="flex items-center gap-2 mb-3">
        <%= lucide_icon "archive", class: "w-5 h-5 text-primary" %>
        <h5 class="font-semibold text-primary">归档材料</h5>
        <% if case_record.archived_attachments.attached? %>
          <span class="badge badge-sm badge-neutral"><%= case_record.archived_attachments.count %></span>
        <% end %>
      </div>
      <% if case_record.archived_attachments.attached? %>
        <div class="space-y-2">
          <% case_record.archived_attachments.each do |attachment| %>
            <%= smart_file_link(attachment, action_buttons: true, show_size: true, deletable: true) %>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted text-sm text-center py-4">暂无归档材料</p>
      <% end %>
    </div>

    <!-- 其他材料 -->
    <div class="border border-border rounded-lg p-4">
      <div class="flex items-center gap-2 mb-3">
        <%= lucide_icon "folder", class: "w-5 h-5 text-primary" %>
        <h5 class="font-semibold text-primary">其他材料</h5>
        <% if case_record.attachments.attached? %>
          <span class="badge badge-sm badge-secondary"><%= case_record.attachments.count %></span>
        <% end %>
      </div>
      <% if case_record.attachments.attached? %>
        <%= collapsible_section(
          title: '其他案件材料',
          count: case_record.attachments.count,
          threshold: 5,
          icon: 'folder'
        ) do %>
          <div class="space-y-2">
            <% case_record.attachments.each do |attachment| %>
              <%= smart_file_link(attachment, action_buttons: true, show_size: true, deletable: true) %>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-muted text-sm text-center py-4">暂无其他材料</p>
      <% end %>
      
      <!-- 追加其他材料表单（仅律师） -->
      <% if current_lawyer %>
        <div class="<%= case_record.attachments.attached? ? 'pt-4 mt-4 border-t border-border' : '' %>">
          <h6 class="font-semibold text-primary mb-3 text-sm">追加其他材料</h6>
          <%= form_with url: append_attachments_case_path(case_record), method: :post, class: "space-y-3", multipart: true do |f| %>
            <div class="form-control">
              <%= label_tag "case[attachments][]", "附件", class: "form-label required text-sm" %>
              <%= file_field_tag "case[attachments][]", multiple: true, class: "form-input", accept: "image/*,.pdf,.doc,.docx,.xls,.xlsx", required: true %>
              <p class="text-xs text-muted mt-1">支持上传图片、PDF、Word、Excel文件，单文件不超过40MB，可同时选择多个文件</p>
            </div>
            <%= f.submit "上传附件", class: "btn-sm btn-primary" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</details>
