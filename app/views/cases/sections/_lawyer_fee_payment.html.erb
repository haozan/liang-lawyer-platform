<% if case_record.lawyer_fee.present? %>
  <details open data-controller="collapsible">
    <summary class="cursor-pointer hover:bg-surface-hover rounded-lg p-4 flex items-center justify-between transition-colors">
      <div class="flex items-center gap-3">
        <%= lucide_icon "dollar-sign", class: "w-5 h-5 text-primary" %>
        <h4 class="font-semibold text-primary text-lg">律师费回款情况</h4>
      </div>
      <%= lucide_icon "chevron-down", class: "w-5 h-5 text-secondary transition-transform", data: { collapsible_target: "icon" } %>
    </summary>
    
    <div class="p-4 pt-0" data-collapsible-target="content">
      <!-- 律师费总额和付款状态 -->
      <div class="grid md:grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-secondary/10 rounded-lg">
          <div class="flex items-center justify-between mb-1">
            <p class="text-sm text-secondary">律师费总额</p>
            <% case case_record.lawyer_fee_payment_status %>
            <% when 'completed' %>
              <span class="badge badge-success">已付清</span>
            <% when 'partial' %>
              <span class="badge badge-warning">部分付款</span>
            <% when 'pending' %>
              <span class="badge badge-neutral">待付款</span>
            <% end %>
          </div>
          <p class="text-2xl font-bold text-primary"><%= mask_amount(case_record.lawyer_fee) %></p>
        </div>

        <div class="p-4 bg-surface-hover rounded-lg">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs text-muted mb-1">已回款</p>
              <p class="text-xl font-bold text-success">
                <% if case_record.lawyer_fee_received.present? && case_record.lawyer_fee_received > 0 %>
                  <%= mask_amount(case_record.lawyer_fee_received) %>
                <% else %>
                  <span class="text-sm text-muted">¥0.00</span>
                <% end %>
              </p>
            </div>
            <div class="text-right">
              <p class="text-xs text-muted mb-1">待回款</p>
              <p class="text-xl font-bold text-warning">
                <% pending_amount = case_record.lawyer_fee - (case_record.lawyer_fee_received || 0) %>
                <%= mask_amount(pending_amount) %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- 回款进度条 -->
      <% if case_record.lawyer_fee_received.present? && case_record.lawyer_fee_received > 0 %>
        <div class="mb-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-secondary">回款进度</span>
            <span class="text-sm font-semibold text-primary">
              <%= ((case_record.lawyer_fee_received / case_record.lawyer_fee) * 100).round(1) %>%
            </span>
          </div>
          <div class="w-full bg-surface-secondary rounded-full h-3">
            <div class="bg-success rounded-full h-3 transition-all" 
                 style="width: <%= [((case_record.lawyer_fee_received / case_record.lawyer_fee) * 100).round(1), 100].min %>%"></div>
          </div>
        </div>
      <% end %>

      <!-- 回款详情 -->
      <% if case_record.lawyer_fee_received.present? && case_record.lawyer_fee_received > 0 %>
        <div class="bg-info/10 rounded-lg p-4 mb-4">
          <h5 class="text-sm font-semibold text-primary mb-3 flex items-center gap-2">
            <%= lucide_icon "credit-card", class: "w-4 h-4" %>
            回款记录
          </h5>
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-sm text-secondary">回款金额：</span>
              <span class="text-sm font-semibold text-primary">
                <%= mask_amount(case_record.lawyer_fee_received) %>
              </span>
            </div>
            <% if case_record.lawyer_fee_received_at.present? %>
              <div class="flex items-center justify-between">
                <span class="text-sm text-secondary">回款日期：</span>
                <span class="text-sm font-semibold text-primary">
                  <%= case_record.lawyer_fee_received_at.strftime('%Y年%m月%d日') %>
                </span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- 开票信息 -->
      <div class="bg-green-50 dark:bg-green-950/20 rounded-lg p-4">
        <h5 class="text-sm font-semibold text-primary mb-3 flex items-center gap-2">
          <%= lucide_icon "file-text", class: "w-4 h-4" %>
          开票信息
          <% if case_record.lawyer_fee_invoice_issued %>
            <span class="badge badge-success">已开票</span>
          <% else %>
            <span class="badge badge-neutral">未开票</span>
          <% end %>
        </h5>
        
        <% if case_record.lawyer_fee_invoice_issued %>
          <div class="space-y-2">
            <% if case_record.lawyer_fee_invoice_number.present? %>
              <div class="flex items-center justify-between">
                <span class="text-sm text-secondary">发票号码：</span>
                <span class="text-sm font-semibold text-primary">
                  <%= case_record.lawyer_fee_invoice_number %>
                </span>
              </div>
            <% end %>
            <% if case_record.lawyer_fee_invoice_amount.present? %>
              <div class="flex items-center justify-between">
                <span class="text-sm text-secondary">开票金额：</span>
                <span class="text-sm font-semibold text-primary">
                  <%= mask_amount(case_record.lawyer_fee_invoice_amount) %>
                </span>
              </div>
            <% end %>
            <% if case_record.lawyer_fee_invoice_issued_at.present? %>
              <div class="flex items-center justify-between">
                <span class="text-sm text-secondary">开票日期：</span>
                <span class="text-sm font-semibold text-primary">
                  <%= case_record.lawyer_fee_invoice_issued_at.strftime('%Y年%m月%d日') %>
                </span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-muted">暂无开票记录</p>
        <% end %>
      </div>

      <!-- 付款条款（如有） -->
      <% if case_record.lawyer_fee_payment_terms.present? %>
        <div class="mt-4 p-4 bg-surface-hover rounded-lg">
          <h5 class="text-sm font-semibold text-primary mb-2 flex items-center gap-2">
            <%= lucide_icon "info", class: "w-4 h-4" %>
            付款条款
          </h5>
          <p class="text-sm text-secondary whitespace-pre-wrap"><%= case_record.lawyer_fee_payment_terms %></p>
        </div>
      <% end %>
    </div>
  </details>
<% end %>
