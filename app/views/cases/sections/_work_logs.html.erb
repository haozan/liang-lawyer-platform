<details open data-controller="collapsible">
  <summary class="cursor-pointer hover:bg-surface-hover rounded-lg p-4 flex items-center justify-between transition-colors">
    <div class="flex items-center gap-3">
      <%= lucide_icon "clipboard-list", class: "w-5 h-5 text-primary" %>
      <h4 class="font-semibold text-primary text-lg">工作大事记</h4>
      <% if work_logs.any? %>
        <span class="badge badge-primary"><%= work_logs.count %></span>
      <% end %>
    </div>
    <%= lucide_icon "chevron-down", class: "w-5 h-5 text-secondary transition-transform", data: { collapsible_target: "icon" } %>
  </summary>
  
  <div class="p-4 pt-0" data-collapsible-target="content">
    <% if work_logs.any? %>
      <div class="space-y-4 mb-6">
        <% work_logs.each do |work_log| %>
          <div class="p-4 bg-surface-hover rounded-lg border border-border">
            <div class="flex items-start justify-between mb-2">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-1">
                  <%= lucide_icon "calendar", class: "w-4 h-4 text-primary" %>
                  <span class="text-sm text-muted"><%= work_log.date.strftime('%Y年%m月%d日') %></span>
                  <span class="text-xs text-muted px-2 py-0.5 bg-surface rounded">
                    <%= work_log.submitter_name %>
                  </span>
                </div>
                <h5 class="font-semibold text-primary text-lg mb-2"><%= work_log.title %></h5>
              </div>
              <% if current_lawyer || (current_company_user && case_record.can_company_user_edit_work_logs?(current_company_user)) %>
                <%= button_to case_work_log_path(case_record, work_log), 
                  method: :delete, 
                  data: { turbo_confirm: '确定删除该工作记录吗？' },
                  class: "text-danger hover:text-danger-hover" do %>
                  <%= lucide_icon "trash-2", class: "w-4 h-4" %>
                <% end %>
              <% end %>
            </div>
            <div class="text-secondary whitespace-pre-wrap mb-3"><%= work_log.content %></div>
            
            <% if work_log.attachments.attached? && work_log.attachments.any? %>
              <div class="mt-3 pt-3 border-t border-border">
                <%= render 'shared/collapsible_attachments', 
                    attachments: work_log.attachments, 
                    title: '工作记录附件', 
                    threshold: 3,
                    icon: 'paperclip' %>
                
                <% if current_lawyer || (current_company_user && case_record.can_company_user_edit_work_logs?(current_company_user)) %>
                  <div class="mt-3 pt-3 border-t border-border">
                    <%= form_with url: append_attachments_case_work_log_path(case_record, work_log), method: :post, class: "flex items-end gap-2", multipart: true do |f| %>
                      <div class="form-control flex-1">
                        <%= label_tag "work_log[attachments][]", "追加附件", class: "form-label text-xs" %>
                        <%= file_field_tag "work_log[attachments][]", multiple: true, class: "form-input form-input-sm", accept: "image/*,.pdf,.doc,.docx,.xls,.xlsx" %>
                        <p class="text-xs text-muted mt-1">支持图片、PDF、Word、Excel文件，单文件不超过40MB</p>
                      </div>
                      <%= f.submit "上传", class: "btn-sm btn-outline" %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <% if current_lawyer || (current_company_user && case_record.can_company_user_edit_work_logs?(current_company_user)) %>
                <div class="mt-3 pt-3 border-t border-border">
                  <p class="text-xs text-muted mb-2">附件：暂无</p>
                  <%= form_with url: append_attachments_case_work_log_path(case_record, work_log), method: :post, class: "flex items-end gap-2", multipart: true do |f| %>
                    <div class="form-control flex-1">
                      <%= label_tag "work_log[attachments][]", "追加附件", class: "form-label text-xs" %>
                      <%= file_field_tag "work_log[attachments][]", multiple: true, class: "form-input form-input-sm", accept: "image/*,.pdf,.doc,.docx,.xls,.xlsx" %>
                      <p class="text-xs text-muted mt-1">支持图片、PDF、Word、Excel文件，单文件不超过40MB</p>
                    </div>
                    <%= f.submit "上传", class: "btn-sm btn-outline" %>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted text-center py-8">暂无工作大事记</p>
    <% end %>

    <% if current_lawyer || (current_company_user && case_record.can_company_user_edit_work_logs?(current_company_user)) %>
      <div class="pt-4 border-t border-border">
        <h5 class="font-semibold text-primary mb-4">添加工作记录</h5>
        <%= form_with url: case_work_logs_path(case_record), class: "space-y-4", multipart: true do |f| %>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="form-control">
              <%= label_tag "work_log[date]", "日期", class: "form-label required" %>
              <%= date_field_tag "work_log[date]", nil, class: "form-input", required: true %>
            </div>
            <div class="form-control">
              <%= label_tag "work_log[title]", "标题", class: "form-label required" %>
              <%= text_field_tag "work_log[title]", nil, class: "form-input", placeholder: "如：提交诉讼状、证据交换等", required: true %>
            </div>
          </div>
          <div class="form-control">
            <%= label_tag "work_log[content]", "详细内容", class: "form-label required" %>
            <%= text_area_tag "work_log[content]", nil, rows: 4, class: "form-textarea", placeholder: "请详细描述该项工作的具体情况...", required: true %>
          </div>
          <div class="form-control">
            <%= label_tag "work_log[attachments][]", "附件", class: "form-label" %>
            <%= file_field_tag "work_log[attachments][]", multiple: true, class: "form-input", accept: "image/*,.pdf,.doc,.docx,.xls,.xlsx" %>
            <p class="text-xs text-muted mt-1">支持上传图片、PDF、Word、Excel文件，单文件不超过40MB</p>
          </div>
          <%= f.submit "添加记录", class: "btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</details>
