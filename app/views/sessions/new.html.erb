<% content_for :title, '登录 - 极光法律服务管理系统' %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-preview, no-cache">
<% end %>

<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50/30 to-slate-50 flex flex-col">
  <!-- Top Navbar -->
  <nav class="bg-white/90 backdrop-blur-sm border-b border-gray-100 sticky top-0 z-50 shadow-sm">
    <div class="container-xl mx-auto px-6">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <%= link_to root_path, class: "flex items-center gap-3 text-primary hover:text-primary-dark transition-colors" do %>
          <%= lucide_icon "scale", class: "w-7 h-7 text-primary" %>
          <span class="font-heading text-xl font-bold text-primary hidden sm:inline">极光法律服务管理系统</span>
          <span class="font-heading text-xl font-bold text-primary sm:hidden">极光法律</span>
        <% end %>
        <!-- Back to Home -->
        <%= link_to root_path, class: "btn-outline btn-sm flex items-center gap-2" do %>
          <%= lucide_icon "arrow-left", class: "w-4 h-4" %>
          <span>返回首页</span>
        <% end %>
      </div>
    </div>
  </nav>

  <!-- Main Login Section -->
  <div class="flex-1 flex items-center justify-center px-4 pb-12">
    <div class="w-full max-w-md">
      <!-- Login Card -->
      <div class="card card-elevated bg-surface p-8 relative">
        <!-- Decorative Legal Symbol -->
        <div class="absolute -top-6 left-1/2 -translate-x-1/2 w-12 h-12 bg-primary rounded-full flex items-center justify-center shadow-lg">
          <%= lucide_icon "shield-check", class: "w-7 h-7 text-surface" %>
        </div>

        <div class="mt-4">
          <h1 class="text-2xl font-bold text-center text-primary mb-2">登录系统</h1>
          <p class="text-center text-secondary mb-6">欢迎回来，请选择登录方式</p>

          <%= render 'shared/flash_messages' %>

          <div data-controller="login-tab">
            <!-- Login Type Tabs -->
            <div class="flex gap-2 mb-6 bg-surface-elevated rounded-lg p-1">
              <button type="button"
                      data-login-tab-target="userTab"
                      data-action="click->login-tab#showUser"
                      class="flex-1 py-2.5 px-4 rounded-md text-sm font-medium transition-all duration-200 bg-primary text-surface shadow-sm">
                <%= lucide_icon "building-2", class: "w-4 h-4 inline-block mr-2" %>
                用户登录
              </button>
              <button type="button"
                      data-login-tab-target="lawyerTab"
                      data-action="click->login-tab#showLawyer"
                      class="flex-1 py-2.5 px-4 rounded-md text-sm font-medium text-secondary hover:text-primary transition-all duration-200">
                <%= lucide_icon "briefcase", class: "w-4 h-4 inline-block mr-2" %>
                律师登录
              </button>
            </div>

            <!-- User Login Form -->
            <div data-login-tab-target="userForm">
              <%= form_with url: login_path, method: :post, class: "space-y-5" do |f| %>
                <%= hidden_field_tag :login_type, 'user' %>

                <div>
                  <%= f.label :phone, "手机号", class: "form-label" %>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                      <%= lucide_icon "smartphone", class: "w-4 h-4 text-muted" %>
                    </div>
                    <%= f.telephone_field :phone,
                        autofocus: true,
                        required: true,
                        class: "form-input pl-10",
                        placeholder: "请输入11位手机号" %>
                  </div>
                </div>

                <div>
                  <%= f.label :password, "密码", class: "form-label" %>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                      <%= lucide_icon "lock", class: "w-4 h-4 text-muted" %>
                    </div>
                    <%= f.password_field :password,
                        required: true,
                        class: "form-input pl-10",
                        placeholder: "请输入密码" %>
                  </div>
                </div>

                <div class="pt-2">
                  <%= f.submit "登录", class: "btn-primary w-full py-3 text-base" %>
                </div>
              <% end %>
            </div>

            <!-- Lawyer Login Form -->
            <div data-login-tab-target="lawyerForm" style="display: none;">
              <%= form_with url: login_path, method: :post, class: "space-y-5" do |f| %>
                <%= hidden_field_tag :login_type, 'lawyer' %>

                <div>
                  <%= f.label :phone, "手机号", class: "form-label" %>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                      <%= lucide_icon "smartphone", class: "w-4 h-4 text-muted" %>
                    </div>
                    <%= f.telephone_field :phone,
                        required: true,
                        class: "form-input pl-10",
                        placeholder: "请输入11位手机号" %>
                  </div>
                </div>

                <div>
                  <%= f.label :password, "密码", class: "form-label" %>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                      <%= lucide_icon "lock", class: "w-4 h-4 text-muted" %>
                    </div>
                    <%= f.password_field :password,
                        required: true,
                        class: "form-input pl-10",
                        placeholder: "请输入密码" %>
                  </div>
                </div>

                <div class="pt-2">
                  <%= f.submit "登录", class: "btn-primary w-full py-3 text-base" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer Links -->
      <div class="mt-6 text-center space-y-3">
        <%= link_to root_path, class: "inline-flex items-center gap-2 text-secondary hover:text-primary transition-colors text-sm" do %>
          <%= lucide_icon "arrow-left", class: "w-4 h-4" %>
          <span>返回首页了解更多</span>
        <% end %>

        <div class="flex items-center justify-center gap-4 text-xs text-muted">
          <div class="flex items-center gap-1">
            <%= lucide_icon "shield", class: "w-3.5 h-3.5" %>
            <span>数据加密传输</span>
          </div>
          <div class="flex items-center gap-1">
            <%= lucide_icon "lock", class: "w-3.5 h-3.5" %>
            <span>隐私保护</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative Elements -->
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>

  <!-- Subtle Background Pattern -->
  <div class="fixed inset-0 pointer-events-none opacity-[0.02] z-0"
       style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, hsl(var(--color-primary)) 35px, hsl(var(--color-primary)) 36px);"></div>
</div>
