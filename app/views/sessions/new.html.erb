<div class="min-h-screen flex items-center justify-center bg-surface py-12 px-4 sm:px-6 lg:px-8">
  <div class="container-sm">
    <div class="card card-elevated">
      <div class="card-body">
        <div class="text-center mb-8">
          <h1 class="text-4xl font-heading font-bold text-primary mb-2">
            梁家航律师法务风险管理平台
          </h1>
          <p class="text-secondary text-lg">企业法务管理系统登录</p>
        </div>

        <%= form_with url: login_path, method: :post, class: "space-y-6" do |f| %>
          <div>
            <%= f.label :email, "邮箱", class: "form-label" %>
            <%= f.email_field :email, required: true, autofocus: true, class: "form-input", placeholder: "请输入邮箱" %>
          </div>

          <div>
            <%= f.label :password, "密码", class: "form-label" %>
            <%= f.password_field :password, required: true, class: "form-input", placeholder: "请输入密码" %>
          </div>

          <div>
            <%= f.submit "登录", class: "btn-primary w-full" %>
          </div>
        <% end %>

        <div class="mt-6 text-center">
          <%= link_to "返回首页", root_path, class: "text-primary hover:text-primary-dark transition-colors" %>
        </div>
      </div>
    </div>
  </div>
</div>
