<nav class="bg-surface border-b-2 border-primary/30">
  <div class="container-xl mx-auto px-6">
    <div class="flex items-center justify-between h-16 gap-4">
      <!-- Logo/Brand -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <%= link_to root_path, class: "flex items-center gap-2 text-primary hover:text-primary-dark transition-colors" do %>
          <%= lucide_icon "scale", class: "w-6 h-6" %>
          <span class="font-heading text-xl font-bold hidden xl:inline">极光法律服务管理系统</span>
          <span class="font-heading text-xl font-bold xl:hidden">法律平台</span>

        <% end %>
      </div>

      <!-- Spacer -->
      <div class="flex-1"></div>

      <!-- Right: User Info + Hamburger Menu -->
      <% if current_user %>
        <div class="flex items-center gap-2 flex-shrink-0">

          <!-- User Info -->
          <div class="hidden md:flex items-center gap-2 text-secondary text-sm max-w-[200px]">
            <%= lucide_icon "user", class: "w-4 h-4 flex-shrink-0" %>
            <span class="truncate">
              <% if lawyer? %>
                <%= current_lawyer.name %>（律师）
              <% elsif company_user? %>
                <% _membership = current_membership %>
                <% _role_label = _membership&.boss? ? '企业主' : '员工' %>
                <%= viewing_company&.name %> · <%= _role_label %>
              <% end %>
            </span>
          </div>

          <!-- Announcement Badge (律师专属，独立保留，否则容易被漏看) -->
          <% if lawyer? %>
            <% announcement_count = lawyer_announcement_count %>
            <% if announcement_count > 0 %>
              <%= link_to lawyer_companies_path,
                    class: "relative flex items-center gap-1 px-3 py-1.5 bg-info text-white rounded-lg text-sm font-medium hover:bg-info/90 transition-colors" do %>
                <%= lucide_icon "megaphone", class: "w-4 h-4" %>
                <span class="hidden sm:inline">公告</span>
                <span class="absolute -top-1.5 -right-1.5 inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1 bg-danger text-white rounded-full text-xs font-bold border-2 border-surface animate-pulse">
                  <%= announcement_count %>
                </span>
              <% end %>
            <% end %>
          <% end %>

          <!-- ☰ 汉堡菜单 -->
          <div class="relative" data-controller="dropdown">
            <button type="button"
                    data-action="click->dropdown#toggle"
                    class="flex items-center gap-2 px-3 py-2 bg-primary text-white hover:bg-primary-dark rounded-lg shadow-md transition-all duration-200 font-medium">
              <%= lucide_icon "menu", class: "w-5 h-5" %>
            </button>

            <!-- Dropdown Panel -->
            <div data-dropdown-target="menu"
                 class="hidden absolute right-0 mt-2 w-60 bg-surface border border-border rounded-xl shadow-xl z-50 overflow-hidden">

              <!-- Section 1: 模块导航 -->
              <div class="px-3 pt-3 pb-1">
                <p class="text-xs font-semibold text-muted uppercase tracking-wider px-1 mb-1">模块导航</p>
              </div>
              <div class="pb-1">
                <% if company_user? %>
                  <%= link_to root_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors text-sm" do %>
                    <%= lucide_icon "home", class: "w-4 h-4" %>
                    <span>首页</span>
                  <% end %>
                  <%= link_to contracts_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors text-sm" do %>
                    <%= lucide_icon "folder-open", class: "w-4 h-4" %>
                    <span>合同管理</span>
                  <% end %>
                  <%= link_to cases_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors text-sm" do %>
                    <%= lucide_icon "briefcase", class: "w-4 h-4" %>
                    <span>案件管理</span>
                  <% end %>
                  <%= link_to major_issues_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors text-sm" do %>
                    <%= lucide_icon "message-square", class: "w-4 h-4" %>
                    <span>重大事项</span>
                  <% end %>
                <% elsif lawyer? %>
                  <%= link_to lawyer_companies_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors text-sm" do %>
                    <%= lucide_icon "home", class: "w-4 h-4" %>
                    <span>首页</span>
                  <% end %>
                  <%= link_to contracts_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors text-sm" do %>
                    <%= lucide_icon "folder-open", class: "w-4 h-4" %>
                    <span>合同档案</span>
                  <% end %>
                  <%= link_to cases_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors text-sm" do %>
                    <%= lucide_icon "briefcase", class: "w-4 h-4" %>
                    <span>案件管理</span>
                  <% end %>
                  <%= link_to major_issues_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors text-sm" do %>
                    <%= lucide_icon "message-square", class: "w-4 h-4" %>
                    <span>重大事项</span>
                  <% end %>
                <% end %>
              </div>

              <!-- Section 2: 账户设置 -->
              <div class="border-t border-border px-3 pt-2 pb-1">
                <p class="text-xs font-semibold text-muted uppercase tracking-wider px-1 mb-1">账户</p>
              </div>
              <div class="pb-1">
                <% if lawyer? %>
                  <%= link_to edit_lawyer_profile_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors text-sm" do %>
                    <%= lucide_icon "settings", class: "w-4 h-4" %>
                    <span>账户设置</span>
                  <% end %>
                <% elsif company_user? %>
                  <%= link_to edit_profile_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors text-sm" do %>
                    <%= lucide_icon "settings", class: "w-4 h-4" %>
                    <span>账户设置</span>
                  <% end %>
                <% end %>
              </div>

              <!-- Section 3: 退出登录 -->
              <div class="border-t border-border p-2">
                <%= link_to logout_path,
                      data: { turbo_method: :delete },
                      class: "flex items-center gap-3 px-4 py-2 text-danger hover:bg-danger/10 rounded-lg transition-colors text-sm font-medium w-full" do %>
                  <%= lucide_icon "log-out", class: "w-4 h-4" %>
                  <span>退出登录</span>
                <% end %>
              </div>

            </div>
          </div>
          <!-- /汉堡菜单 -->

        </div>
      <% end %>
    </div>
  </div>
</nav>
