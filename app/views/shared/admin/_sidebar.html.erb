<!-- Dashboard Sidebar -->
<li>
  <%= link_to admin_root_path,
      class: "flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-100 hover:text-blue-700 dark:hover:bg-blue-900 dark:hover:text-blue-300 rounded-lg transition-colors #{'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' if current_path == admin_root_path}" do %>
