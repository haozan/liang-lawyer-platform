<!-- Admin Dashboard Sidebar -->
<li>
  <%= link_to admin_root_path,
      class: "flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-info/10 hover:text-info dark:hover:bg-blue-900 dark:hover:text-blue-300 rounded-lg transition-colors #{'bg-info/10 text-info dark:bg-blue-900 dark:text-blue-300' if current_path == admin_root_path}" do %>
    <%= lucide_icon "layout-dashboard", class: "w-5 h-5 mr-3" %>
    Dashboard
  <% end %>
</li>

