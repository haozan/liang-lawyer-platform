<!-- 方案一：专业商务风格 - 深蓝主调，橙色强调 -->
<nav class="bg-surface border-b-2 border-primary/30">
  <div class="container-xl mx-auto px-6">
    <div class="flex items-center justify-between h-16 gap-4">
      <!-- Logo/Brand -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <%= link_to root_path, class: "flex items-center gap-2 text-primary hover:text-primary-dark transition-colors" do %>
          <%= lucide_icon "scale", class: "w-6 h-6" %>
          <span class="font-heading text-xl font-bold hidden xl:inline">极光法律服务管理系统</span>
          <span class="font-heading text-xl font-bold xl:hidden">法律平台</span>
        <% end %>
      </div>

      <!-- Search Bar (Desktop only) -->
      <% if current_user %>
        <div class="hidden md:flex flex-1 max-w-2xl">
          <%= form_with url: cases_path, method: :get, class: "w-full" do |f| %>
            <div class="relative">
              <%= f.text_field :q, 
                placeholder: "搜索合同、案件、问题...", 
                class: "form-input w-full pr-24 bg-surface-elevated border-border focus:border-primary transition-colors",
                autocomplete: "off" %>
              <div class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center gap-2">
                <kbd class="hidden lg:inline-block px-2 py-1 text-xs bg-surface border border-border rounded text-muted">Ctrl+K</kbd>
                <%= lucide_icon "search", class: "w-4 h-4 text-muted" %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- User Menu -->
      <% if current_user %>
        <div class="flex items-center gap-4">
          <!-- User Info -->
          <div class="flex items-center gap-2 text-secondary">
            <%= lucide_icon "user", class: "w-5 h-5" %>
            <span>
              <% if lawyer? %>
                <%= current_lawyer.name %>（律师）
              <% elsif company_user? %>
                <% if current_membership&.boss? %>
                  <%= viewing_company&.name %> · 企业主
                <% elsif false %>
                  <%= viewing_company&.name %> · 高管
                <% else %>
                  <%= viewing_company&.name %> · 员工
                <% end %>
              <% end %>
            </span>
          </div>

          <!-- Navigation Links -->
          <% if company_user? %>
            <% if true %>
              <!-- 企业用户（老板/员工）下拉菜单 - 专业商务风格 -->
              <div class="relative" data-controller="dropdown">
                <button type="button" data-action="click->dropdown#toggle" class="flex items-center gap-2 px-4 py-2 bg-primary text-white hover:bg-primary-dark rounded-lg shadow-md transition-all duration-200 hover:shadow-lg font-medium">
                  <%= lucide_icon "layout-grid", class: "w-4 h-4" %>
                  <span>模块导航</span>
                  <%= lucide_icon "chevron-down", class: "w-4 h-4" %>
                </button>
                <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-56 bg-surface border border-border rounded-lg shadow-lg z-50">
                  <div class="py-2">
                    <%= link_to root_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors" do %>
                      <%= lucide_icon "home", class: "w-5 h-5" %>
                      <span>首页</span>
                    <% end %>
                    <div class="border-t border-border my-1"></div>
                    <%= link_to contracts_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors" do %>
                      <%= lucide_icon "folder-open", class: "w-5 h-5" %>
                      <span>合同管理</span>
                    <% end %>
                    <%= link_to cases_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors" do %>
                      <%= lucide_icon "briefcase", class: "w-5 h-5" %>
                      <span>案件管理</span>
                    <% end %>
                    <%= link_to major_issues_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors" do %>
                      <%= lucide_icon "message-square", class: "w-5 h-5" %>
                      <span>重大事项</span>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          <% elsif lawyer? %>
            <!-- 律师模块导航下拉菜单 - 专业商务风格 -->
            <div class="relative" data-controller="dropdown">
              <button type="button" data-action="click->dropdown#toggle" class="flex items-center gap-2 px-4 py-2 bg-primary text-white hover:bg-primary-dark rounded-lg shadow-md transition-all duration-200 hover:shadow-lg font-medium">
                <%= lucide_icon "layout-grid", class: "w-4 h-4" %>
                <span>模块导航</span>
                <%= lucide_icon "chevron-down", class: "w-4 h-4" %>
              </button>
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-56 bg-surface border border-border rounded-lg shadow-lg z-50">
                <div class="py-2">
                  <%= link_to lawyer_companies_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors" do %>
                    <%= lucide_icon "home", class: "w-5 h-5" %>
                    <span>首页</span>
                  <% end %>
                  <div class="border-t border-border my-1"></div>
                  <%= link_to contracts_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors" do %>
                    <%= lucide_icon "folder-open", class: "w-5 h-5" %>
                    <span>合同档案</span>
                  <% end %>
                  <%= link_to cases_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors" do %>
                    <%= lucide_icon "briefcase", class: "w-5 h-5" %>
                    <span>案件管理</span>
                  <% end %>
                  <%= link_to major_issues_path, class: "flex items-center gap-3 px-4 py-2 text-secondary hover:bg-surface-hover hover:text-primary transition-colors" do %>
                    <%= lucide_icon "message-square", class: "w-5 h-5" %>
                    <span>重大事项</span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Account Settings Button - 橙色高亮 -->
          <% if lawyer? %>
            <%= link_to edit_lawyer_profile_path, class: "flex items-center gap-2 px-4 py-2 bg-warning text-white hover:bg-warning/90 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg font-medium" do %>
              <%= lucide_icon "settings", class: "w-4 h-4" %>
              <span>账户设置</span>
            <% end %>
            
            <!-- Announcements Badge for Lawyer - 青色渐变 -->
            <% announcement_count = lawyer_announcement_count %>
            <% if announcement_count > 0 %>
              <%= link_to lawyer_companies_path, class: "flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-info to-info/80 text-white hover:from-info/90 hover:to-info/70 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg font-medium relative" do %>
                <%= lucide_icon "megaphone", class: "w-4 h-4" %>
                <span>公告</span>
                <span class="absolute -top-2 -right-2 inline-flex items-center justify-center min-w-[1.5rem] h-6 px-2 bg-danger text-white rounded-full text-xs font-bold border-2 border-surface shadow-lg animate-pulse">
                  <%= announcement_count %>
                </span>
              <% end %>
            <% end %>
          <% elsif company_user? %>
            <%= link_to edit_profile_path, class: "flex items-center gap-2 px-4 py-2 bg-warning text-white hover:bg-warning/90 rounded-lg shadow-md transition-all duration-200 hover:shadow-lg font-medium" do %>
              <%= lucide_icon "settings", class: "w-4 h-4" %>
              <span>账户设置</span>
            <% end %>
          <% end %>

          <!-- Logout Button - 红色边框醒目 -->
          <%= link_to logout_path, data: { turbo_method: :delete }, class: "flex items-center gap-2 px-4 py-2 bg-surface border-2 border-danger text-danger hover:bg-danger hover:text-white rounded-lg shadow-md transition-all duration-200 hover:shadow-lg font-medium" do %>
            <%= lucide_icon "log-out", class: "w-4 h-4" %>
            <span>退出登录</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
