<%
  # 浮动快捷导航按钮 - 增强型可选导航方式
  # 位于右下角固定位置，提供快速切换分析模块的入口
  
  analytics_modules = [
    { name: '重大事项分析', path_method: :dashboard_major_issue_analytics_path, icon: 'message-square', key: 'major_issue', color: 'text-secondary' },
    { name: '案件数据分析', path_method: :dashboard_case_analytics_path, icon: 'briefcase', key: 'case', color: 'text-info' },
    { name: '合同数据分析', path_method: :dashboard_contract_analytics_path, icon: 'folder-open', key: 'contract', color: 'text-success' }
  ]
  
  current_module = local_assigns[:current_module] || 'major_issue'
  current_module_data = analytics_modules.find { |m| m[:key] == current_module }
  
  # 构建带筛选参数的URL（保持状态）
  filter_params = {}
  filter_params[:company_id] = params[:company_id] if params[:company_id].present?
  filter_params[:date_from] = params[:date_from] if params[:date_from].present?
  filter_params[:date_to] = params[:date_to] if params[:date_to].present?
  filter_params[:compare_date_from] = params[:compare_date_from] if params[:compare_date_from].present?
  filter_params[:compare_date_to] = params[:compare_date_to] if params[:compare_date_to].present?
%>

<!-- 浮动快捷导航按钮 -->
<div class="fixed bottom-6 right-6 z-50" 
     data-controller="analytics-quick-nav"
     data-action="click@window->analytics-quick-nav#closeOnOutsideClick keydown@window->analytics-quick-nav#handleKeyboard">
  
  <!-- 展开的菜单 -->
  <div data-analytics-quick-nav-target="menu"
       class="hidden opacity-0 translate-y-2 transition-all duration-200 mb-3 bg-surface-elevated border border-border rounded-xl shadow-2xl p-2 min-w-[200px]">
    <div class="space-y-1">
      <% analytics_modules.each do |module_data| %>
        <% is_current = current_module == module_data[:key] %>
        <% module_url = send(module_data[:path_method], filter_params) %>
        
        <%= link_to module_url,
          class: "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all #{is_current ? 'bg-primary/10 text-primary' : 'text-secondary hover:bg-surface-hover hover:text-primary'}",
          data: { analytics_tab: module_data[:key] } do %>
          <%= lucide_icon module_data[:icon], class: "w-5 h-5 #{module_data[:color]}" %>
          <span class="font-medium text-sm"><%= module_data[:name] %></span>
          <% if is_current %>
            <%= lucide_icon "check", class: "w-4 h-4 ml-auto" %>
          <% end %>
        <% end %>
      <% end %>
    </div>
    
    <!-- 快捷键提示 -->
    <div class="mt-2 pt-2 border-t border-border">
      <p class="text-xs text-secondary px-3 py-1">快捷键：Alt + 1/2/3</p>
    </div>
  </div>
  
  <!-- 主按钮 -->
  <button type="button"
          data-action="click->analytics-quick-nav#toggle"
          class="flex items-center justify-center w-14 h-14 bg-primary hover:bg-primary/90 text-white rounded-full shadow-2xl hover:shadow-3xl transition-all hover:scale-110 active:scale-95"
          aria-label="数据分析快捷导航">
    <%= lucide_icon "bar-chart-3", class: "w-6 h-6" %>
  </button>
</div>
