<%
  # 当前激活的tab（通过local variable传入）
  current_tab = local_assigns[:current_tab] || 'major_issue'
  
  # 构建带筛选参数的URL（保持状态）
  filter_params = {}
  filter_params[:company_id] = params[:company_id] if params[:company_id].present?
  filter_params[:date_from] = params[:date_from] if params[:date_from].present?
  filter_params[:date_to] = params[:date_to] if params[:date_to].present?
  filter_params[:compare_date_from] = params[:compare_date_from] if params[:compare_date_from].present?
  filter_params[:compare_date_to] = params[:compare_date_to] if params[:compare_date_to].present?
  
  # 定义分析模块（使用方法名而非调用结果）
  analytics_tabs = [
    {
      name: '重大事项分析',
      path_method: :dashboard_major_issue_analytics_path,
      icon: 'message-square',
      key: 'major_issue'
    },
    {
      name: '案件数据分析',
      path_method: :dashboard_case_analytics_path,
      icon: 'briefcase',
      key: 'case'
    },
    {
      name: '合同数据分析',
      path_method: :dashboard_contract_analytics_path,
      icon: 'folder-open',
      key: 'contract'
    }
  ]
  
  # 律师用户可以看到律师费数据分析
  if lawyer?
    analytics_tabs << {
      name: '律师费数据分析',
      path_method: :dashboard_lawyer_fee_analytics_path,
      icon: 'dollar-sign',
      key: 'lawyer_fee'
    }
  end
%>

<!-- 数据分析Tab导航 -->
<div class="mb-6">
  <!-- 面包屑导航 -->
  <div class="flex items-center gap-2 text-sm text-secondary mb-4">
    <%= link_to lawyer_companies_path, class: "hover:text-primary transition-colors flex items-center gap-1" do %>
      <%= lucide_icon "home", class: "w-4 h-4" %>
      <span>首页</span>
    <% end %>
    <%= lucide_icon "chevron-right", class: "w-4 h-4" %>
    <span class="text-primary font-medium">数据分析</span>
  </div>
  
  <!-- Tab导航栏 -->
  <div class="card card-elevated">
    <div class="flex flex-wrap gap-2 p-3" role="tablist" aria-label="数据分析模块">
      <% analytics_tabs.each_with_index do |tab, index| %>
        <% is_active = current_tab == tab[:key] %>
        <% tab_url = send(tab[:path_method], filter_params) %>
        
        <%= link_to tab_url, 
          class: "flex items-center gap-2 px-4 py-2.5 rounded-lg font-medium transition-all duration-200 #{is_active ? 'bg-primary text-white shadow-md' : 'bg-surface-hover text-secondary hover:bg-surface-elevated hover:text-primary'}",
          role: "tab",
          "aria-selected" => is_active.to_s,
          "aria-label" => tab[:name],
          data: { analytics_tab: tab[:key] } do %>
          <%= lucide_icon tab[:icon], class: "w-5 h-5" %>
          <span><%= tab[:name] %></span>
          <% if is_active %>
            <%= lucide_icon "check", class: "w-4 h-4 ml-1" %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
  
  <!-- 提示信息：筛选条件保持 -->
  <% if filter_params.any? %>
    <div class="mt-3 flex items-center gap-2 text-xs text-secondary">
      <%= lucide_icon "info", class: "w-3.5 h-3.5" %>
      <span>切换分析模块时将保留当前的筛选条件</span>
    </div>
  <% end %>
</div>
