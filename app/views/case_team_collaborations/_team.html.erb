<div id="collaboration-team-<%= ownership.id %>" class="flex items-center justify-between p-3 bg-surface-hover rounded-lg border border-muted">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 rounded-full bg-info/10 flex items-center justify-center">
      <%= lucide_icon "users", class: "w-5 h-5 text-info" %>
    </div>
    <div>
      <p class="font-semibold text-primary"><%= ownership.lawyer_team.name %></p>
      <p class="text-xs text-secondary">
        <%= ownership.lawyer_team.lawyer_accounts.count %> 名成员 · 
        负责人: <%= ownership.lawyer_team.leader&.name || '未设置' %>
      </p>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <% case ownership.access_level %>
    <% when 'owner' %>
      <span class="badge badge-primary">主责团队</span>
    <% when 'collaborator' %>
      <span class="badge badge-info">协作者</span>
    <% when 'viewer' %>
      <span class="badge badge-secondary">查看者</span>
    <% end %>
    
    <span class="text-xs text-muted">
      <%= ownership.authorized_at.strftime('%Y-%m-%d') %> 加入
    </span>
    
    <% unless ownership.is_primary? %>
      <% if lawyer? && (case_record.is_lead_lawyer?(current_lawyer_account) || current_lawyer_account.team_leader? || current_lawyer_account.super_admin?) %>
        <%= button_to case_case_team_collaboration_path(case_record, ownership), 
              method: :delete,
              class: "btn-sm btn-outline text-danger hover:bg-danger/10 ml-2",
              title: "移除协作团队",
              data: { turbo_confirm: "确定要移除 #{ownership.lawyer_team.name} 的协作权限吗？" } do %>
          <%= lucide_icon "user-minus", class: "w-4 h-4" %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
